# =============================================================================
# MYLEADX PRODUCTION ENVIRONMENT
# =============================================================================
# Copy this to .env.production and fill in the values

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=myleadx
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=myleadx

# =============================================================================
# JWT AUTHENTICATION (generate with: openssl rand -hex 32)
# =============================================================================
JWT_SECRET=your_jwt_secret_32_chars_minimum
JWT_REFRESH_SECRET=your_refresh_secret_32_chars_min
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# ENCRYPTION KEY (generate with: openssl rand -hex 16)
# =============================================================================
CREDENTIALS_ENCRYPTION_KEY=your_32_char_encryption_key_here

# =============================================================================
# EXOTEL (Voice Calling)
# =============================================================================
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SUBDOMAIN=
EXOTEL_CALLER_ID=

# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# RAZORPAY (Payments)
# =============================================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@myleadx.ai

# =============================================================================
# WHATSAPP (Meta Business API)
# =============================================================================
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# =============================================================================
# AWS S3 (File Storage)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=myleadx-uploads
AWS_REGION=ap-south-1
AWS_RECORDINGS_BUCKET=myleadx-recordings

# =============================================================================
# DEEPGRAM (Speech-to-Text)
# =============================================================================
DEEPGRAM_API_KEY=

# =============================================================================
# ELEVENLABS (Text-to-Speech)
# =============================================================================
ELEVENLABS_API_KEY=
