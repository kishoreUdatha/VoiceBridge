generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core Tables
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  email     String
  phone     String?
  address   String?
  logo      String?
  settings  Json?    @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription fields
  activePlanId       String?   @default("starter")
  subscriptionStatus String?   @default("TRIAL") // TRIAL, ACTIVE, CANCELLED, EXPIRED
  trialEndsAt        DateTime?

  // Voice Minutes Pool
  voiceMinutesLimit   Int? // Override plan limit (null = use plan default)
  voiceMinutesUsed    Float     @default(0) // Total minutes used this month
  voiceMinutesResetAt DateTime? // When usage was last reset

  users                 User[]
  roles                 Role[]
  leads                 Lead[]
  customForms           CustomForm[]
  landingPages          LandingPage[]
  campaigns             Campaign[]
  adCampaigns           AdCampaign[]
  instagramIntegrations InstagramIntegration[]
  facebookIntegrations  FacebookIntegration[]
  linkedinIntegrations  LinkedInIntegration[]
  googleAdsIntegrations GoogleAdsIntegration[]
  youtubeAdsIntegrations YouTubeAdsIntegration[]
  twitterAdsIntegrations TwitterAdsIntegration[]
  tiktokAdsIntegrations  TikTokAdsIntegration[]
  chatbotConversations  ChatbotConversation[]
  payments              Payment[]
  leadStages            LeadStage[]
  taxonomies            Taxonomy[]
  channels              Channel[]
  customFields          CustomField[]
  voiceAgents           VoiceAgent[]
  voiceTemplates        OrganizationVoiceTemplate[]
  subscriptions         Subscription[]

  // B2B Partner Relations
  partner         Partner?         @relation("PartnerOrganization")
  partnerCustomer PartnerCustomer? @relation("CustomerOrganization")

  // Raw Import Records
  bulkImports      BulkImport[]
  rawImportRecords RawImportRecord[]

  // Phone Numbers
  phoneNumbers PhoneNumber[]

  // Inbound Call Features
  ivrFlows         IvrFlow[]
  ivrNodes         IvrNode[]
  callFlows        CallFlow[]
  callQueues       CallQueue[]
  voicemails       Voicemail[]
  callbackRequests CallbackRequest[]
  inboundCallLogs  InboundCallLog[]
  agentSkills      AgentSkill[]

  // Compliance & Analytics
  consentRecords            ConsentRecord[]
  complianceAuditLogs       ComplianceAuditLog[]
  recordingDisclosureConfig RecordingDisclosureConfig?
  funnelEvents              FunnelEvent[]
  agentPerformanceDaily     AgentPerformanceDaily[]

  // Billing & Usage
  usageTracking UsageTracking[]
  invoices      Invoice[]

  // Scheduled Calls & Appointments
  scheduledCalls ScheduledCall[]
  appointments   Appointment[]

  // Call Management
  doNotCallLists  DoNotCallList[]
  followUpRules   FollowUpRule[]
  transferConfigs TransferConfig[]
  analyticsDaily  AnalyticsDaily[]

  // Enterprise Features
  whiteLabelSettings WhiteLabelSettings?

  // Messaging
  scheduledMessages ScheduledMessage[]
  contactLists      ContactList[]
  conversations     Conversation[]

  // Tracking
  visitorTracking VisitorTracking[]
  adInteractions  AdInteraction[]

  // IVR & Monitoring
  ivrPhoneNumbers        IvrPhoneNumber[]
  callMonitoringSessions CallMonitoringSession[]

  // Integrations
  emailSequences      EmailSequence[]
  crmIntegrations     CrmIntegration[]
  paymentIntegrations PaymentIntegration[]
  customApiEndpoints  CustomApiEndpoint[]

  // Apify Web Scraping
  apifyIntegration ApifyIntegration?

  @@map("organizations")
}

model User {
  id                   String    @id @default(uuid())
  organizationId       String
  email                String
  password             String
  firstName            String
  lastName             String
  phone                String?
  avatar               String?
  roleId               String
  isActive             Boolean   @default(true)
  lastLoginAt          DateTime?
  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Voice Minutes Management
  voiceMinutesLimit   Int? // Max minutes per month (null = unlimited within org pool)
  voiceMinutesUsed    Float     @default(0) // Minutes used this month
  voiceMinutesResetAt DateTime? // When usage was last reset

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role             Role              @relation(fields: [roleId], references: [id])
  leadAssignments  LeadAssignment[]  @relation("AssignedTo")
  assignedBy       LeadAssignment[]  @relation("AssignedBy")
  studentProfile   StudentProfile?
  callLogs         CallLog[]         @relation("Caller")
  smsLogs          SmsLog[]
  emailLogs        EmailLog[]
  whatsappLogs     WhatsappLog[]
  createdCampaigns Campaign[]        @relation("CampaignCreator")
  paymentsCreated  Payment[]         @relation("PaymentCreator")
  leadNotes        LeadNote[]
  leadTasks        LeadTask[]        @relation("TaskAssignee")
  createdTasks     LeadTask[]        @relation("TaskCreator")
  followUps        FollowUp[]        @relation("FollowUpAssignee")
  createdFollowUps FollowUp[]        @relation("FollowUpCreator")
  leadActivities   LeadActivity[]
  telecallerQueue  TelecallerQueue[] @relation("TelecallerQueueAssignment")
  telecallerCalls  TelecallerCall[]  @relation("TelecallerCalls")

  // Raw Import Records
  bulkImportsUploaded   BulkImport[]      @relation("BulkImportUploader")
  rawImportsAssignedTo  RawImportRecord[] @relation("RawImportAssignedTo")
  rawImportsAssignedBy  RawImportRecord[] @relation("RawImportAssignedBy")
  rawImportsConvertedBy RawImportRecord[] @relation("RawImportConvertedBy")

  // Voice Agents
  voiceAgentsCreated   VoiceAgent[] @relation("VoiceAgentCreator")
  voiceAgentsPublished VoiceAgent[] @relation("VoiceAgentPublisher")
  callFlowsCreated     CallFlow[]   @relation("CallFlowCreator")

  // Messaging
  messageLogs MessageLog[]

  @@unique([organizationId, email])
  @@map("users")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String?
  name           String
  slug           String
  description    String?
  permissions    Json     @default("[]")
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users        User[]

  @@unique([organizationId, slug])
  @@map("roles")
}

// Lead Stages with Sub-Stages
model LeadStage {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  slug            String
  color           String?  @default("#3B82F6")
  order           Int      @default(0)
  requireFollowUp Boolean  @default(false)
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subStages    LeadSubStage[]
  leads        Lead[]

  @@unique([organizationId, slug])
  @@map("lead_stages")
}

model LeadSubStage {
  id        String   @id @default(uuid())
  stageId   String
  name      String
  slug      String
  color     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stage LeadStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@unique([stageId, slug])
  @@map("lead_sub_stages")
}

// Taxonomy (Courses, Branches, etc.)
model Taxonomy {
  id             String       @id @default(uuid())
  organizationId String
  type           TaxonomyType
  name           String
  slug           String
  parentId       String?
  order          Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Taxonomy?    @relation("TaxonomyHierarchy", fields: [parentId], references: [id])
  children     Taxonomy[]   @relation("TaxonomyHierarchy")
  leads        Lead[]       @relation("LeadCourse")
  leadBranches Lead[]       @relation("LeadBranch")

  @@unique([organizationId, type, slug])
  @@map("taxonomies")
}

// Channels/Sources
model Channel {
  id             String      @id @default(uuid())
  organizationId String
  name           String
  slug           String
  type           ChannelType @default(OTHER)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@unique([organizationId, slug])
  @@map("channels")
}

// Custom Fields
model CustomField {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  slug           String
  fieldType      FieldType
  options        Json?     @default("[]")
  isRequired     Boolean   @default(false)
  order          Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@map("custom_fields")
}

model Lead {
  id             String       @id @default(uuid())
  organizationId String
  firstName      String
  lastName       String?
  email          String?
  phone          String
  alternatePhone String?
  alternateEmail String?
  source         LeadSource   @default(MANUAL)
  sourceDetails  String?
  channelId      String?
  stageId        String?
  subStageId     String?
  priority       LeadPriority @default(MEDIUM)

  // Education specific fields
  courseId     String?
  branchId     String?
  centerName   String?
  gender       String?
  dateOfBirth  DateTime?
  fatherName   String?
  fatherMobile String?
  motherName   String?
  motherMobile String?
  address      String?
  city         String?
  state        String?
  country      String?
  pincode      String?

  // Fee related
  totalFees     Decimal? @db.Decimal(10, 2)
  paidAmount    Decimal? @default(0) @db.Decimal(10, 2)
  paymentStatus String?
  installment1  Decimal? @db.Decimal(10, 2)
  installment2  Decimal? @db.Decimal(10, 2)
  installment3  Decimal? @db.Decimal(10, 2)

  // Dates
  walkinDate DateTime?
  lineupDate DateTime?

  // Assignment
  agentName         String?
  facultyName       String?
  preferredLocation String?

  // Additional
  interests     Json?   @default("[]")
  customFields  Json?   @default("{}")
  phoneVerified Boolean @default(false)
  isReEnquiry   Boolean @default(false)

  isConverted Boolean   @default(false)
  convertedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization              Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel                   Channel?                 @relation(fields: [channelId], references: [id])
  stage                     LeadStage?               @relation(fields: [stageId], references: [id])
  subStage                  LeadSubStage?            @relation(fields: [subStageId], references: [id])
  course                    Taxonomy?                @relation("LeadCourse", fields: [courseId], references: [id])
  branch                    Taxonomy?                @relation("LeadBranch", fields: [branchId], references: [id])
  assignments               LeadAssignment[]
  formSubmission            FormSubmission?
  studentProfile            StudentProfile?
  callLogs                  CallLog[]
  smsLogs                   SmsLog[]
  emailLogs                 EmailLog[]
  whatsappLogs              WhatsappLog[]
  ivrsLogs                  IvrsLog[]
  adLead                    AdLead?
  notes                     LeadNote[]
  tasks                     LeadTask[]
  followUps                 FollowUp[]
  activities                LeadActivity[]
  attachments               LeadAttachment[]
  queries                   LeadQuery[]
  applications              LeadApplication[]
  voiceSessions             VoiceSession[]
  telecallerCalls           TelecallerCall[]         @relation("LeadTelecallerCalls")
  rawImportRecordsConverted RawImportRecord[]        @relation("RawImportConvertedLead")
  sequenceEnrollments       LeadSequenceEnrollment[]
  callFlowLogs              CallFlowLog[]
  leadScore                 LeadScore?
  consentRecords            ConsentRecord[]
  funnelEvents              FunnelEvent[]
  otpVerifications          OtpVerification[]
  adInteractionConversion   AdInteraction?             @relation("AdInteractionConversion")
  outboundCalls             OutboundCall[]             @relation("LeadOutboundCalls")
  messageLogs               MessageLog[]

  // Interaction tracking
  totalCalls       Int       @default(0)
  lastContactedAt  DateTime?
  nextFollowUpAt   DateTime?

  @@index([organizationId, phone])
  @@index([organizationId, email])
  @@index([organizationId, stageId])
  @@index([organizationId, nextFollowUpAt])
  @@map("leads")
}

model LeadAssignment {
  id           String    @id @default(uuid())
  leadId       String
  assignedToId String
  assignedById String?
  isActive     Boolean   @default(true)
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  lead       Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User  @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedBy User? @relation("AssignedBy", fields: [assignedById], references: [id])

  @@index([leadId, isActive])
  @@index([assignedToId, isActive])
  @@map("lead_assignments")
}

// Lead Notes
model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("lead_notes")
}

// Lead Tasks
model LeadTask {
  id          String       @id @default(uuid())
  leadId      String
  assigneeId  String
  createdById String
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee  User @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User @relation("TaskCreator", fields: [createdById], references: [id])

  @@map("lead_tasks")
}

// Follow-ups
model FollowUp {
  id              String         @id @default(uuid())
  leadId          String
  assigneeId      String
  createdById     String
  scheduledAt     DateTime
  message         String?
  notes           String?
  status          FollowUpStatus @default(UPCOMING)
  completedAt     DateTime?
  rescheduledFrom String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Follow-up type and AI call settings
  followUpType    FollowUpType   @default(MANUAL)
  voiceAgentId    String?        // AI agent to use for AI_CALL type
  outboundCallId  String?        // Resulting outbound call ID
  sourceCallId    String?        // The call that triggered this follow-up
  attemptCount    Int            @default(0)
  maxAttempts     Int            @default(3)
  lastAttemptAt   DateTime?

  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee   User        @relation("FollowUpAssignee", fields: [assigneeId], references: [id])
  createdBy  User        @relation("FollowUpCreator", fields: [createdById], references: [id])
  voiceAgent VoiceAgent? @relation(fields: [voiceAgentId], references: [id])

  @@index([assigneeId, status, scheduledAt])
  @@index([followUpType, status, scheduledAt])
  @@map("follow_ups")
}

// Lead Activity Timeline
model LeadActivity {
  id          String       @id @default(uuid())
  leadId      String
  userId      String?
  type        ActivityType
  title       String
  description String?
  metadata    Json?        @default("{}")
  createdAt   DateTime     @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

// Lead Attachments
model LeadAttachment {
  id         String   @id @default(uuid())
  leadId     String
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_attachments")
}

// Lead Queries
model LeadQuery {
  id          String      @id @default(uuid())
  leadId      String
  query       String
  response    String?
  status      QueryStatus @default(OPEN)
  respondedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_queries")
}

// Lead Applications
model LeadApplication {
  id            String            @id @default(uuid())
  leadId        String
  applicationNo String
  programName   String?
  status        ApplicationStatus @default(DRAFT)
  submittedAt   DateTime?
  documents     Json?             @default("[]")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_applications")
}

// Forms & Landing Pages
model CustomForm {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  description    String?
  fields         Json      @default("[]")
  settings       Json?     @default("{}")
  embedCode      String?
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submissions  FormSubmission[]
  urls         FormUrl[]

  @@map("custom_forms")
}

model FormUrl {
  id        String   @id @default(uuid())
  formId    String
  name      String
  slug      String   @unique
  channel   String?
  source    String?
  medium    String?
  isEnabled Boolean  @default(true)
  qrCode    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_urls")
}

model FormSubmission {
  id        String   @id @default(uuid())
  formId    String
  leadId    String?  @unique
  data      Json
  ipAddress String?
  userAgent String?
  source    String?
  createdAt DateTime @default(now())

  form CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  lead Lead?      @relation(fields: [leadId], references: [id])

  @@map("form_submissions")
}

model LandingPage {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  slug           String
  title          String
  description    String?
  content        Json      @default("{}")
  styles         Json?     @default("{}")
  seoSettings    Json?     @default("{}")
  formId         String?
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@map("landing_pages")
}

// Student Portal
model StudentProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  leadId             String?   @unique
  dateOfBirth        DateTime?
  gender             String?
  address            String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  highestEducation   String?
  currentInstitution String?
  graduationYear     Int?
  preferredCourse    String?
  preferredCountry   String?
  englishProficiency String?
  workExperience     Int?      @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead      Lead?              @relation(fields: [leadId], references: [id])
  documents AcademicDocument[]
  payments  Payment[]

  @@map("student_profiles")
}

model AcademicDocument {
  id               String       @id @default(uuid())
  studentProfileId String
  documentType     DocumentType
  fileName         String
  fileUrl          String
  fileSize         Int
  mimeType         String
  isVerified       Boolean      @default(false)
  verifiedAt       DateTime?
  uploadedAt       DateTime     @default(now())

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@map("academic_documents")
}

model Payment {
  id               String        @id @default(uuid())
  organizationId   String
  studentProfileId String
  createdById      String
  orderId          String        @unique
  paymentId        String?
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("INR")
  status           PaymentStatus @default(PENDING)
  paymentMethod    String?
  description      String?
  metadata         Json?         @default("{}")
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])
  createdBy      User           @relation("PaymentCreator", fields: [createdById], references: [id])
  splits         PaymentSplit[]

  @@map("payments")
}

model PaymentSplit {
  id           String        @id @default(uuid())
  paymentId    String
  splitNumber  Int
  amount       Decimal       @db.Decimal(10, 2)
  dueDate      DateTime
  status       PaymentStatus @default(PENDING)
  paidAt       DateTime?
  reminderSent Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_splits")
}

// Communication
model Campaign {
  id             String         @id @default(uuid())
  organizationId String
  createdById    String
  name           String
  type           CampaignType
  subject        String?
  content        String
  templateId     String?
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  stats          Json?          @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                @relation("CampaignCreator", fields: [createdById], references: [id])
  recipients   CampaignRecipient[]
  emailLogs    EmailLog[]

  @@map("campaigns")
}

model CampaignRecipient {
  id           String                  @id @default(uuid())
  campaignId   String
  phone        String?
  email        String?
  name         String?
  status       CampaignRecipientStatus @default(PENDING)
  sentAt       DateTime?
  deliveredAt  DateTime?
  failedReason String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_recipients")
}

model SmsLog {
  id            String           @id @default(uuid())
  leadId        String?
  userId        String
  phone         String
  message       String
  direction     MessageDirection
  status        MessageStatus    @default(PENDING)
  providerMsgId String?
  provider      String?          @default("TWILIO") // TWILIO or PLIVO
  sentAt        DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime         @default(now())

  lead Lead? @relation(fields: [leadId], references: [id])
  user User  @relation(fields: [userId], references: [id])

  @@map("sms_logs")
}

model EmailLog {
  id            String           @id @default(uuid())
  leadId        String?
  userId        String
  campaignId    String?
  toEmail       String
  subject       String
  body          String
  direction     MessageDirection
  status        MessageStatus    @default(PENDING)
  providerMsgId String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  metadata      Json?
  createdAt     DateTime         @default(now())

  lead           Lead?                @relation(fields: [leadId], references: [id])
  user           User                 @relation(fields: [userId], references: [id])
  campaign       Campaign?            @relation(fields: [campaignId], references: [id])
  trackingEvents EmailTrackingEvent[]

  @@map("email_logs")
}

model EmailTrackingEvent {
  id         String   @id @default(uuid())
  emailLogId String
  eventType  String // OPEN, CLICK, BOUNCE, UNSUBSCRIBE
  url        String? // For click events
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  emailLog EmailLog @relation(fields: [emailLogId], references: [id])

  @@index([emailLogId])
  @@map("email_tracking_events")
}

model WhatsappLog {
  id            String           @id @default(uuid())
  leadId        String?
  userId        String
  phone         String
  message       String
  mediaUrl      String?
  direction     MessageDirection
  status        MessageStatus    @default(PENDING)
  providerMsgId String?
  provider      String?          @default("TWILIO") // TWILIO or PLIVO
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  createdAt     DateTime         @default(now())

  lead Lead? @relation(fields: [leadId], references: [id])
  user User  @relation(fields: [userId], references: [id])

  @@map("whatsapp_logs")
}

model CallLog {
  id             String        @id @default(uuid())
  leadId         String?
  callerId       String
