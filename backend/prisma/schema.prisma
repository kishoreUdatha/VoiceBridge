}

enum ApifyScrapeJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model ApifyIntegration {
  id             String   @id @default(uuid())
  organizationId String   @unique
  apiToken       String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scraperConfigs ApifyScraperConfig[]
  scrapeJobs     ApifyScrapeJob[]

  @@map("apify_integrations")
}

model ApifyScraperConfig {
  id               String           @id @default(uuid())
  integrationId    String
  name             String
  scraperType      ApifyScraperType
  actorId          String
  inputConfig      Json             @default("{}")
  scheduleEnabled  Boolean          @default(false)
  scheduleInterval ScheduleInterval @default(DAILY)
  scheduleCron     String?          // For CUSTOM interval
  nextScheduledAt  DateTime?
  fieldMapping     Json             @default("{}")
  totalLeadsScraped Int             @default(0)
  lastRunStatus    String?
  lastRunAt        DateTime?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  integration ApifyIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  scrapeJobs  ApifyScrapeJob[]

  @@index([integrationId, isActive])
  @@map("apify_scraper_configs")
}

model ApifyScrapeJob {
  id            String               @id @default(uuid())
  integrationId String
  configId      String?
  apifyRunId    String               @unique
  actorId       String
  status        ApifyScrapeJobStatus @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  totalItems    Int                  @default(0)
  importedItems Int                  @default(0)
  duplicateItems Int                 @default(0)
  failedItems   Int                  @default(0)
  bulkImportId  String?
  errorMessage  String?
  inputSnapshot Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  integration ApifyIntegration    @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  config      ApifyScraperConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)

  @@index([integrationId, status])
  @@index([configId])
  @@map("apify_scrape_jobs")
}

// ==================== RAG KNOWLEDGE CHUNKS ====================

model KnowledgeChunk {
  id             String   @id @default(uuid())
  voiceAgentId   String   @map("voice_agent_id")
  sourceType     String   @map("source_type") // "knowledge_base", "faq", "document"
  sourceId       String?  @map("source_id")
  sourceName     String?  @map("source_name")
  content        String   @db.Text
  chunkIndex     Int      @map("chunk_index")
  totalChunks    Int      @map("total_chunks")
  embedding      Unsupported("vector(1536)")?
  embeddingModel String   @default("text-embedding-3-small") @map("embedding_model")
  metadata       Json     @default("{}")
  keywords       String[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  voiceAgent VoiceAgent @relation(fields: [voiceAgentId], references: [id], onDelete: Cascade)

  @@index([voiceAgentId])
  @@index([sourceType])
  @@map("knowledge_chunks")
}

// ==================== MESSAGING ====================

// Message Log for tracking all sent messages (SMS, WhatsApp, Email) during telecaller calls
model MessageLog {
  id             String  @id @default(uuid())
  organizationId String
  leadId         String?
  userId         String?

  // Message Details
  type       TemplateType // SMS, WHATSAPP, EMAIL
  to         String // Phone number or email
  subject    String? // For emails
  content    String       @db.Text
  templateId String?

  // Status
  status     MessageStatus @default(PENDING)
  externalId String? // Provider message ID
  error      String?

  // Timestamps
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([leadId])
  @@index([type, status])
  @@map("message_logs")
}

