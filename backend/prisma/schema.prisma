// Super Admin Users (Platform Owners)
model SuperAdmin {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}

// Platform Analytics for Admin Dashboard
model PlatformStats {
