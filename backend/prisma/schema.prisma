model EmailTrackingEvent {
  id         String   @id @default(uuid())
  emailLogId String
  eventType  String // OPEN, CLICK, BOUNCE, UNSUBSCRIBE
  url        String? // For click events
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  emailLog EmailLog @relation(fields: [emailLogId], references: [id])

  @@index([emailLogId])
  @@map("email_tracking_events")
}

model WhatsappLog {
  id            String           @id @default(uuid())
  leadId        String?
  userId        String
  phone         String
  message       String
