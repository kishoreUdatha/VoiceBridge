model Subscription {
  id             String             @id @default(uuid())
  organizationId String
  planId         String // starter, professional, business, enterprise
  billingCycle   BillingCycle
  userCount      Int                @default(1)
  status         SubscriptionStatus @default(PENDING)

  // Pricing
  amount   Float // Amount in INR
  currency String @default("INR")

  // Razorpay
  razorpayOrderId        String? @unique
  razorpayPaymentId      String?
  razorpaySignature      String?
  razorpaySubscriptionId String?

  // Period
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  // Scheduled changes
  scheduledPlanChange String?
  scheduledChangeDate DateTime?

  // Cancellation
  cancelledAt  DateTime?
  cancelReason String?

  // Timestamps
  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([razorpayOrderId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIAL
}

enum BillingCycle {
  monthly
  annual
}

model UsageTracking {
  id             String @id @default(uuid())
  organizationId String
  month          Int // 1-12
  year           Int

  // Counters
  leadsCount    Int   @default(0)
  usersCount    Int   @default(0)
  aiCallsCount  Int   @default(0)
  smsCount      Int   @default(0)
  emailsCount   Int   @default(0)
  whatsappCount Int   @default(0)
  storageUsedMb Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, month, year])
  @@index([organizationId])
  @@map("usage_tracking")
}

model UsageLimitEvent {
  id             String   @id @default(uuid())
  organizationId String
  type           String // leads, aiCalls, sms, emails, etc.
  message        String
  occurredAt     DateTime @default(now())
  acknowledged   Boolean  @default(false)

  @@index([organizationId, occurredAt])
  @@map("usage_limit_events")
}

model AddOnBalance {
  id             String @id @default(uuid())
  organizationId String
  type           String // aiCalls, sms, whatsapp, storage, leads
  balance        Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, type])
  @@map("addon_balances")
}

model AddOnPurchase {
  id             String @id @default(uuid())
  organizationId String
  type           String // aiCalls, sms, whatsapp, storage, leads
  quantity       Int
  pricePerUnit   Float
  totalAmount    Float

  // Razorpay
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String  @default("PENDING") // PENDING, COMPLETED, FAILED

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@map("addon_purchases")
}

model Invoice {
  id             String  @id @default(uuid())
  organizationId String
  subscriptionId String?
  invoiceNumber  String  @unique

  // Amounts
  subtotal    Float
  taxAmount   Float // GST 18%
  totalAmount Float
  currency    String @default("INR")

  // Details
  billingPeriod String?
  planName      String?
  userCount     Int?

  // Status
  status InvoiceStatus @default(DRAFT)
  paidAt DateTime?

  // Razorpay
  razorpayPaymentId String?

  // Timestamps
  issuedAt  DateTime  @default(now())
  dueDate   DateTime?
  createdAt DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

// ==================== ENTERPRISE FEATURES ====================

// White Label Settings for Organization Branding
model WhiteLabelSettings {
