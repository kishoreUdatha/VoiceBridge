  formId    String
  leadId    String?  @unique
  data      Json
  ipAddress String?
  userAgent String?
  source    String?
  createdAt DateTime @default(now())

  form CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  lead Lead?      @relation(fields: [leadId], references: [id])

