enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

// Wallet Transactions for Phone Number Purchases
model WalletTransaction {
  id             String   @id @default(uuid())
  organizationId String

  // Transaction Details
  type           WalletTransactionType
  amount         Float                    // Positive for credit, negative for debit
  currency       String                   @default("USD")
  balanceBefore  Float
  balanceAfter   Float

  // Reference (for phone number purchases, payments, etc.)
  referenceType  String?                  // 'phone_number', 'razorpay_payment', 'refund', etc.
  referenceId    String?                  // ID of the related record

  // Details
  description    String
  metadata       Json?                    @default("{}")

  // Payment Info (for top-ups)
  razorpayOrderId   String?
  razorpayPaymentId String?

  // Status
  status         WalletTransactionStatus  @default(COMPLETED)

  // Timestamps
  createdAt      DateTime                 @default(now())

  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  CREDIT      // Adding funds
  DEBIT       // Spending funds
  REFUND      // Refund for unused services
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

