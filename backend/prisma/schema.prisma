  accompaniedById   String?
  accompaniedBy     User?    @relation("VisitAccompaniedBy", fields: [accompaniedById], references: [id])

  // Travel
  travelArranged    Boolean  @default(false)
  travelExpense     Decimal? @db.Decimal(10, 2)

  // Outcome
  feedback          String?  @db.Text
  studentRating     Int?     // 1-5
  interestedInAdmission Boolean?

