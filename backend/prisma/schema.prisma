  extraPhoneNumberRate Float @default(999) // Per month per extra number
  extraAgentRate       Float @default(499) // Per month per extra agent
  extraUserRate        Float @default(299) // Per month per extra user

  // Features (JSON array of feature keys)
  features Json @default("[]")

  // Status
  isActive  Boolean @default(true)
  isPopular Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

