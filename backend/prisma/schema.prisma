// ==================== PUBLIC API SYSTEM ====================

// API Keys for External Access
model ApiKey {
  id             String @id @default(uuid())
  organizationId String

  // Key Details
  name      String
  key       String @unique // The actual API key (hashed)
  keyPrefix String // First 8 chars for identification

  // Permissions
  permissions Json @default("[]") // ["agents:read", "agents:call", "sessions:read"]

  // Allowed Agents
  allowedAgents Json @default("[]") // Empty = all agents, or specific agent IDs

  // Rate Limiting
  rateLimit       Int @default(1000) // Requests per hour
  rateLimitWindow Int @default(3600) // Window in seconds

  // IP Restrictions
  allowedIPs Json @default("[]") // Empty = all IPs allowed

  // Usage Stats
  totalRequests Int       @default(0)
  lastUsedAt    DateTime?

  // Status
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  // Metadata
  description String?
  environment String  @default("production") // production, sandbox

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  usageLogs ApiUsageLog[]

  @@index([organizationId, isActive])
  @@index([key])
  @@index([keyPrefix])
  @@map("api_keys")
}

// API Usage Logging
model ApiUsageLog {
  id       String @id @default(uuid())
  apiKeyId String

  // Request Details
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int // milliseconds

  // Request Info
  ipAddress String?
  userAgent String?

  // Payload Info (for billing)
  agentId   String?
  sessionId String?
  action    String? // call, message, session_start, etc.

  // Cost Tracking
  tokensUsed   Int   @default(0)
  costIncurred Float @default(0)

  // Error Info
  errorMessage String?

  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([agentId, createdAt])
  @@map("api_usage_logs")
}

// API Webhooks (for notifying external systems)
model ApiWebhook {
  id             String @id @default(uuid())
  organizationId String

  // Webhook Details
  name   String
  url    String
  secret String // For signature verification

  // Events to subscribe
  events Json @default("[]") // ["call.started", "call.ended", "session.created"]

  // Status
  isActive Boolean @default(true)

  // Stats
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  lastTriggeredAt DateTime?
  lastError       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  deliveryLogs WebhookDeliveryLog[]

  @@index([organizationId, isActive])
  @@map("api_webhooks")
}

model WebhookDeliveryLog {
  id        String @id @default(uuid())
  webhookId String

  // Event details
  eventType String
  eventId   String // Unique ID for the event
  payload   Json

  // Delivery details
  attempt     Int @default(1)
  maxAttempts Int @default(5)

  // Response
  statusCode   Int?
  responseBody String?
  responseTime Int? // in milliseconds

  // Status
  status      WebhookDeliveryStatus @default(PENDING)
  error       String?
  nextRetryAt DateTime?

  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  // Relations
  webhook ApiWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
  @@index([status, nextRetryAt])
  @@map("webhook_delivery_logs")
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// ==================== MESSAGE TEMPLATES ====================

