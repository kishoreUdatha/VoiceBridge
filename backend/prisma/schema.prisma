  // User & Lead Limits
  maxUsers Int @default(5)
  maxLeads Int @default(500)

  // Voice AI Limits
  maxPhoneNumbers      Int   @default(1) // Phone numbers included in plan
  maxVoiceAgents       Int   @default(2) // AI agents included
  voiceMinutesIncluded Int   @default(300) // Minutes included per month
  extraMinuteRate      Float @default(6.0) // Rate per extra minute (INR)

  // Communication Limits
  maxSMS      Int @default(100)
  maxEmails   Int @default(1000)
  maxWhatsapp Int @default(500)
  maxStorage  Int @default(1024) // MB

