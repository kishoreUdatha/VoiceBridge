// ==================== CONVERSATION TRACKING ====================

model Conversation {
  id             String @id @default(uuid())
  organizationId String

  // Conversation participants
  leadId       String?
  contactPhone String?
  contactEmail String?
  contactName  String?

  // Channel
  channel   ConversationChannel
  channelId String? // External channel ID (WhatsApp, etc.)

  // Status
  status   ConversationState    @default(OPEN)
  priority ConversationPriority @default(NORMAL)

  // Assignment
  assignedToId String?
  assignedAt   DateTime?

  // Metadata
  subject      String?
  tags         Json    @default("[]")
  customFields Json    @default("{}")

  // Stats
  messageCount    Int               @default(0)
  lastMessageAt   DateTime?
  lastMessageType MessageDirection?

  // Resolution
  resolvedAt   DateTime?
  resolvedById String?
  resolution   String?

  // SLA tracking
  firstResponseAt   DateTime?
  firstResponseTime Int? // seconds

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     ConversationMessage[]

  @@index([organizationId, status])
  @@index([organizationId, channel])
  @@index([leadId])
  @@index([contactPhone])
  @@index([contactEmail])
  @@index([assignedToId, status])
  @@map("conversations")
}

model ConversationMessage {
  id             String @id @default(uuid())
  conversationId String

  // Message details
  direction   MessageDirection
  content     String             @db.Text
  contentType MessageContentType @default(TEXT)

  // Media attachments
  attachments Json @default("[]") // [{url, type, name, size}]

  // Sender info
  senderType SenderType
  senderId   String? // User ID if from agent
  senderName String?

  // External references
  externalId     String? // Provider message ID
  providerStatus String? // Provider delivery status

  // Delivery status
  status        MessageDeliveryStatus @default(PENDING)
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  failedAt      DateTime?
  failureReason String?

  // Metadata
  metadata Json @default("{}")

  createdAt DateTime @default(now())

  // Relations
  conversation  Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  statusUpdates MessageStatusUpdate[]

  @@index([conversationId, createdAt])
  @@index([externalId])
  @@index([status])
  @@map("conversation_messages")
}

model MessageStatusUpdate {
  id        String @id @default(uuid())
  messageId String

  // Status info
  status    MessageDeliveryStatus
  timestamp DateTime              @default(now())

  // Provider info
  providerStatus String?
  providerData   Json?

  // Error info
  errorCode    String?
  errorMessage String?

  // Webhook delivery
  webhookSent   Boolean   @default(false)
  webhookSentAt DateTime?

  // Relations
