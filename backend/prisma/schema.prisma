// ==================== AD INTERACTION TRACKING ====================

enum AdInteractionType {
  CLICK       // User clicked ad and landed on page
  IMPRESSION  // Ad was shown (synced from platform)
  ENGAGEMENT  // User engagement (scroll, time on page, video watch)
  CONVERSION  // Click converted to lead
}

// Track ad clicks that may or may not result in form submissions
model AdInteraction {
  id             String            @id @default(uuid())
  organizationId String
  type           AdInteractionType
  visitorId      String            // From tracking pixel
  sessionId      String?           // Session tracking for deduplication

  // Click IDs from ad platforms
  gclid   String? // Google Click ID
  fbclid  String? // Facebook Click ID
  ttclid  String? // TikTok Click ID
  twclid  String? // Twitter Click ID
  liclid  String? // LinkedIn Click ID

  // UTM Parameters
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  // Page info
  landingPage String? @db.Text
  referrer    String? @db.Text

  // Device info
  userAgent  String? @db.Text
  ipAddress  String?
  deviceType String?
  browser    String?

  // Engagement tracking (for impressions and engagement events)
  scrollDepth     Int?  // Page scroll percentage (25, 50, 75, 100)
  timeOnPage      Int?  // Seconds spent on page
  videoWatchTime  Int?  // Seconds of video watched (for YouTube/TikTok)
  videoPercentage Int?  // Video completion percentage

  // Campaign relationship
  adCampaignId String?

  // Conversion tracking
  convertedToLeadId String?   @unique
  convertedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adCampaign   AdCampaign?  @relation(fields: [adCampaignId], references: [id], onDelete: SetNull)
  convertedTo  Lead?        @relation("AdInteractionConversion", fields: [convertedToLeadId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, visitorId])
  @@index([organizationId, sessionId])
  @@index([organizationId, type])
  @@index([gclid])
  @@index([fbclid])
  @@index([ttclid])
  @@index([twclid])
  @@index([convertedToLeadId])
  @@map("ad_interactions")
}

// Store historical daily metrics for ad campaigns
model AdCampaignDailyMetrics {
  id           String   @id @default(uuid())
  adCampaignId String
  date         DateTime @db.Date

  // Metrics
  impressions Int     @default(0)
  reach       Int     @default(0)
  clicks      Int     @default(0)
  conversions Int     @default(0)
  spend       Decimal? @db.Decimal(10, 2)
  cpc         Decimal? @db.Decimal(10, 4) // Cost per click
  cpm         Decimal? @db.Decimal(10, 4) // Cost per 1000 impressions
  ctr         Decimal? @db.Decimal(5, 4)  // Click-through rate

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  adCampaign AdCampaign @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)

  @@unique([adCampaignId, date])
  @@index([adCampaignId])
  @@index([date])
  @@map("ad_campaign_daily_metrics")
}

