  competitors       CollegeCompetitor[]

  @@index([organizationId])
  @@index([organizationId, assignedToId])
  @@index([organizationId, city])
  @@index([organizationId, category])
  @@index([organizationId, status])
  @@index([organizationId, state, district])
  @@index([organizationId, orgBranchId])
  @@map("colleges")
}

model CollegeContact {
  id        String @id @default(uuid())
  collegeId String

  // Contact Details
  name        String
  designation String
  department  String?
  phone       String
  altPhone    String?
  email       String?
  whatsapp    String?

  // Flags
  isPrimary      Boolean @default(false)
  isDecisionMaker Boolean @default(false)

  // Notes
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  college College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  visits  CollegeVisit[] @relation("VisitContacts")

  @@index([collegeId])
  @@map("college_contacts")
}

model CollegeVisit {
  id             String @id @default(uuid())
  collegeId      String? // Optional - null for ad-hoc visits
  organizationId String
  userId         String // Marketing person who visited

  // Ad-hoc visit details (when collegeId is null)
  visitCollegeName String?
  visitState       String?
  visitDistrict    String?
  visitCity        String?

  // Visit Timing
  visitDate    DateTime
  checkInTime  DateTime?
  checkOutTime DateTime?
  duration     Int?       // minutes (calculated)

  // Location Verification
  checkInLatitude   Float?
  checkInLongitude  Float?
  checkInAddress    String?
  locationVerified  Boolean @default(false)
  distanceFromCollege Float? // in meters

  // Visit Details
  purpose       VisitPurpose
  outcome       VisitOutcome?
  contactsMet   Json         @default("[]") // Array of contact IDs
  summary       String       @db.Text
  actionItems   String?      @db.Text

  // Follow-up
  nextVisitDate DateTime?
  nextAction    String?

  // Attachments
  photos     Json @default("[]") // Array of URLs
  documents  Json @default("[]") // Array of {name, url}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  college      College?         @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User             @relation("CollegeVisitUser", fields: [userId], references: [id])
  contacts     CollegeContact[] @relation("VisitContacts")
  expenses     CollegeExpense[]

  @@index([collegeId])
  @@index([organizationId, userId])
  @@index([organizationId, visitDate])
  @@index([organizationId, visitState, visitDistrict])
  @@map("college_visits")
}

model CollegeDeal {
  id             String @id @default(uuid())
  collegeId      String @unique // One active deal per college
  organizationId String
  ownerId        String

  // Deal Info
  dealName     String
  description  String?  @db.Text
  products     Json     @default("[]") // Array of products/services

  // Value
  dealValue        Decimal?  @db.Decimal(12, 2)
  currency         String    @default("INR")

  // Pipeline
  stage            DealStage @default(PROSPECTING)
  probability      Int       @default(10) // Percentage
  expectedCloseDate DateTime?
  actualCloseDate  DateTime?

  // Outcome
  wonLostReason    String?
  competitorWon    String?  // If lost, who won

  // History
  stageHistory     Json     @default("[]") // Array of {stage, changedAt, changedBy}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  college      College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User         @relation("CollegeDealOwner", fields: [ownerId], references: [id])

  @@index([organizationId])
  @@index([organizationId, stage])
  @@index([organizationId, ownerId])
  @@map("college_deals")
}

model CollegeExpense {
  id             String @id @default(uuid())
  collegeId      String
  visitId        String?
  organizationId String
  userId         String // Who incurred the expense

  // Expense Details
  category     ExpenseCategory
  subCategory  String?
  amount       Decimal    @db.Decimal(10, 2)
  currency     String     @default("INR")
  expenseDate  DateTime
  description  String?

  // Receipt
  receiptUrl    String?
  invoiceNumber String?
  vendorName    String?

  // Approval
  status        ExpenseStatus @default(DRAFT)
  approvedById  String?
  approvedAt    DateTime?
  rejectionReason String?
  paidAt        DateTime?
  paymentRef    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  college      College       @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  visit        CollegeVisit? @relation(fields: [visitId], references: [id], onDelete: SetNull)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation("CollegeExpenseUser", fields: [userId], references: [id])
  approvedBy   User?         @relation("CollegeExpenseApprover", fields: [approvedById], references: [id])
  logs         ExpenseLog[]

  @@index([collegeId])
  @@index([visitId])
  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@map("college_expenses")
}

// Expense Transaction/Audit Log - tracks all status changes
model ExpenseLog {
  id        String   @id @default(uuid())
  expenseId String
  userId    String   // Who performed the action

  // Action Details
  action       ExpenseLogAction
  fromStatus   ExpenseStatus?
  toStatus     ExpenseStatus?
  comments     String?  @db.Text

  // Additional data (payment ref, rejection reason, etc.)
  metadata     Json?

  createdAt DateTime @default(now())

  // Relations
  expense   CollegeExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User           @relation("ExpenseLogUser", fields: [userId], references: [id])

  @@index([expenseId])
  @@index([userId])
  @@map("expense_logs")
}

enum ExpenseLogAction {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  PAYMENT_PROCESSED
  RECEIPT_UPLOADED
}

model CollegeCompetitor {
  id        String @id @default(uuid())
  collegeId String

  // Competitor Info
  competitorName String
  contactPerson  String?
  products       Json    @default("[]") // What they're offering
  pricing        String?
  status         String  @default("ACTIVE") // ACTIVE, DISPLACED, LOST_TO

  // Intelligence
  strengths   String? @db.Text
  weaknesses  String? @db.Text
  notes       String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
  @@map("college_competitors")
}

// ==================== TELECALLER CALLS (Manual Calling with Recording) ====================

model TelecallerCall {
  id             String  @id @default(uuid())
  organizationId String
  telecallerId   String
  leadId         String?

  // Contact Info
  phoneNumber String
  contactName String?

  // Call Status
  status  TelecallerCallStatus   @default(INITIATED)
  outcome TelecallerCallOutcome?

  // Timing
  startedAt DateTime?
  endedAt   DateTime?
  duration  Int? // seconds

  // Recording & Transcript
  recordingUrl String?
  transcript   String? @db.Text
  sentiment    String? // positive, neutral, negative

  // Analysis
  qualification    Json?   @default("{}")
  summary          String? @db.Text
  aiAnalyzed       Boolean @default(false) // Whether AI analysis has been completed
  callQualityScore Int?    // AI-calculated call quality score (0-100)

  // Enhanced Call Summary Fields (same as OutboundCall)
  keyQuestionsAsked    Json?   @default("[]")   // Questions agent asked
  keyIssuesDiscussed   Json?   @default("[]")   // Issues discussed
  sentimentIntensity   String?                   // low/medium/high
  agentSpeakingTime    Int?                      // seconds
  customerSpeakingTime Int?                      // seconds
  nonSpeechTime        Int?                      // seconds
  enhancedTranscript   Json?                     // Per-message timestamps and sentiment

  // AI Coaching Suggestions
  coachingPositiveHighlights Json?               // What agent did well
  coachingAreasToImprove     Json?               // Areas needing improvement
  coachingNextCallTips       Json?   @default("[]") // Tips for next call
  coachingSummary            String? @db.Text    // Overall coaching summary
  coachingTalkListenFeedback String?             // Talk-to-listen ratio feedback
  coachingEmpathyScore       Int?                // 0-100
  coachingObjectionScore     Int?                // Objection handling 0-100
  coachingClosingScore       Int?                // Closing technique 0-100

  // Extracted Data from conversation
  extractedData Json? // Structured data extracted from call

  // Notes
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  telecaller User  @relation("TelecallerCalls", fields: [telecallerId], references: [id])
  lead       Lead? @relation("LeadTelecallerCalls", fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId, telecallerId])
  @@index([telecallerId, createdAt])
  @@index([leadId])
  @@map("telecaller_calls")
}

enum TelecallerCallStatus {
  INITIATED // Call started
  IN_PROGRESS // Currently on call
  COMPLETED // Call finished
  MISSED // No answer
  FAILED // Call failed
}

enum TelecallerCallOutcome {
  INTERESTED // Lead interested
  NOT_INTERESTED // Lead not interested
  CALLBACK // Requested callback
  CONVERTED // Lead converted
  NO_ANSWER // Couldn't reach
  WRONG_NUMBER // Invalid number
  BUSY // Line busy
}

// ==================== INBOUND CALL FEATURES ====================

// IVR Flow Configuration
model IvrFlow {
  id             String @id @default(uuid())
  organizationId String

  // Flow Details
  name        String
  description String?
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false)

  // Flow Structure (nodes and edges stored as JSON)
  nodes Json @default("[]") // Array of IvrNode-like objects with positions
  edges Json @default("[]") // Array of connections between nodes

  // Settings
  welcomeMessage      String? @db.Text
  timeoutSeconds      Int     @default(10)
  maxRetries          Int     @default(3)
  invalidInputMessage String?

  // Statistics
  totalCalls     Int @default(0)
  completedCalls Int @default(0)
  avgDuration    Int @default(0)

  // Version control
  version     Int       @default(1)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumbers IvrPhoneNumber[]
  callLogs     InboundCallLog[]

  @@index([organizationId, isActive])
  @@map("ivr_flows")
}

// IVR Node (Individual node in the flow)
model IvrNode {
  id             String @id @default(uuid())
  organizationId String

  // Node Details
  name String
  type IvrNodeType

  // Configuration based on type
  config Json @default("{}")
  // MENU: { options: [{digit: "1", label: "Sales", nextNodeId: "xxx"}] }
  // PLAY: { audioUrl: "...", text: "..." }
  // GATHER: { numDigits: 4, timeout: 5 }
  // ROUTE: { routeType: "skill", skillId: "xxx" }
  // QUEUE: { queueId: "xxx" }
  // TRANSFER: { transferType: "warm|cold", number: "..." }
  // VOICEMAIL: { mailboxId: "xxx" }

  // Text-to-speech or audio
  audioUrl String?
  ttsText  String? @db.Text
  ttsVoice String  @default("alloy")

  // Timeout and error handling
  timeoutSeconds         Int     @default(10)
  timeoutNextNodeId      String?
  invalidInputNextNodeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@map("ivr_nodes")
}

enum IvrNodeType {
  MENU // IVR menu with options
  PLAY // Play audio/TTS
  GATHER // Collect DTMF input
  ROUTE // Route based on skills/rules
  QUEUE // Add to queue
  TRANSFER // Transfer call
  VOICEMAIL // Send to voicemail
  WEBHOOK // Call external webhook
  CONDITION // Conditional branching
  SET_VARIABLE // Set call variable
  END // End call
}

// Map phone numbers to IVR flows
model IvrPhoneNumber {
  id             String @id @default(uuid())
  organizationId String

  phoneNumber   String // E.164 format
  phoneNumberId String? // Reference to PhoneNumber model if using managed numbers
  flowId        String

  isActive Boolean @default(true)

  // Override settings
  welcomeMessage   String? @db.Text
  afterHoursFlowId String? // Different flow for after hours

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flow         IvrFlow      @relation(fields: [flowId], references: [id])

  @@unique([organizationId, phoneNumber])
  @@index([phoneNumber])
  @@map("ivr_phone_numbers")
}

// Call Queue Configuration
model CallQueue {
  id             String @id @default(uuid())
  organizationId String

  // Queue Details
  name        String
  description String?
  isActive    Boolean @default(true)

  // Routing Strategy
  routingStrategy QueueRoutingStrategy @default(ROUND_ROBIN)

  // Queue Settings
  maxWaitTime  Int @default(300) // Max wait in seconds
  maxQueueSize Int @default(50) // Max callers in queue

  // Hold Experience
  holdMusicUrl        String?
  holdMessage         String? @db.Text
  holdMessageInterval Int     @default(60) // Seconds between position announcements
  announcePosition    Boolean @default(true)
  announceWaitTime    Boolean @default(true)

  // Overflow Handling
  overflowAction      OverflowAction @default(VOICEMAIL)
  overflowDestination String? // Phone number, voicemail box, or queue ID

  // Statistics
  totalCalls     Int   @default(0)
  answeredCalls  Int   @default(0)
  abandonedCalls Int   @default(0)
  avgWaitTime    Int   @default(0)
  avgHandleTime  Int   @default(0)
  serviceLevel   Float @default(0) // % answered within SLA

  // SLA Settings
  slaSeconds Int @default(30) // Target answer time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      QueueMember[]
  entries      QueueEntry[]
  schedules    QueueSchedule[]
  inboundCalls InboundCallLog[]

  @@index([organizationId, isActive])
  @@map("call_queues")
}

enum QueueRoutingStrategy {
  ROUND_ROBIN // Distribute evenly
  LONGEST_IDLE // Route to longest idle agent
  LEAST_CALLS // Route to agent with fewest calls
  SKILLS_BASED // Route based on skills matching
  PRIORITY_BASED // Route based on agent priority
  RANDOM // Random distribution
}

enum OverflowAction {
  VOICEMAIL // Send to voicemail
  TRANSFER // Transfer to number
  QUEUE // Move to another queue
  CALLBACK // Offer callback
  DISCONNECT // Disconnect with message
}

// Queue Member (Agent in queue)
model QueueMember {
  id      String @id @default(uuid())
  queueId String
  userId  String

  // Member Settings
  priority           Int @default(1) // 1 = highest priority
  maxConcurrentCalls Int @default(1)
  wrapUpTime         Int @default(30) // Seconds after call

  // Skills for skills-based routing
  skills Json @default("[]") // Array of skill IDs

  // Status
  status          AgentStatus @default(OFFLINE)
  statusChangedAt DateTime?
  lastCallAt      DateTime?

  // Statistics
  callsToday    Int @default(0)
  callsHandled  Int @default(0)
  avgHandleTime Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queue CallQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
  @@index([queueId, status])
  @@index([userId, status])
  @@map("queue_members")
}

enum AgentStatus {
  AVAILABLE // Ready to take calls
  ON_CALL // Currently on a call
  WRAP_UP // Post-call wrap up
  BUSY // Busy with other work
  AWAY // Away/break
  OFFLINE // Not logged in
}

// Queue Entry (Caller waiting in queue)
model QueueEntry {
  id            String  @id @default(uuid())
  queueId       String
  inboundCallId String? // Reference to InboundCallLog

  // Caller Info
  callerNumber String
  callerId     String? // Caller ID name if available
  leadId       String?

  // Queue Position
  position Int
  priority Int @default(5) // 1 = highest

  // Status
  status QueueEntryStatus @default(WAITING)

  // Timing
  enteredAt   DateTime  @default(now())
  answeredAt  DateTime?
  abandonedAt DateTime?

  // Assignment
  assignedAgentId String?
  assignedAt      DateTime?

  // IVR data collected
  ivrData Json @default("{}")

  // Callback option
  callbackRequested Boolean @default(false)
  callbackNumber    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queue CallQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId, status])
  @@index([status, enteredAt])
  @@map("queue_entries")
}

enum QueueEntryStatus {
  WAITING // In queue waiting
  RINGING // Ringing an agent
  CONNECTED // Connected to agent
  ABANDONED // Caller hung up
  CALLBACK // Callback requested
  OVERFLOW // Moved to overflow
}

// Queue Schedule (Business hours)
model QueueSchedule {
  id      String @id @default(uuid())
  queueId String

  // Day of week (0 = Sunday, 6 = Saturday)
  dayOfWeek Int

  // Time range (24-hour format)
  startTime String // "09:00"
  endTime   String // "18:00"

  // Timezone
  timezone String @default("Asia/Kolkata")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queue CallQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@unique([queueId, dayOfWeek])
  @@map("queue_schedules")
}

// Voicemail Box and Messages
model Voicemail {
  id             String @id @default(uuid())
  organizationId String

  // Voicemail Details
  callerNumber String
  callerName   String?
  leadId       String?

  // Source
  queueId     String? // If from queue overflow
  ivrFlowId   String? // If from IVR
  agentUserId String? // If direct to agent

  // Recording
  recordingUrl String
  duration     Int // Seconds

  // Transcription
  transcript          String?   @db.Text
  transcriptionStatus String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  transcribedAt       DateTime?

  // Status
  status VoicemailStatus @default(NEW)

  // Handling
  listenedAt    DateTime?
  listenedById  String?
  respondedAt   DateTime?
  respondedById String?

  // Notes
  notes String? @db.Text

  // Callback created
  callbackId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([queueId])
  @@index([agentUserId, status])
  @@map("voicemails")
}

enum VoicemailStatus {
  NEW // Not listened
  LISTENED // Listened but not responded
  RESPONDED // Response sent/called back
  ARCHIVED // Archived
  DELETED // Soft deleted
}

// Callback Requests
model CallbackRequest {
  id             String @id @default(uuid())
  organizationId String

  // Contact Info
  phoneNumber String
  contactName String?
  leadId      String?

  // Source
  source        CallbackSource
  queueId       String?
  voicemailId   String?
  ivrFlowId     String?
  inboundCallId String?

  // Scheduling
  requestedAt        DateTime  @default(now())
  scheduledAt        DateTime?
  preferredTimeStart DateTime?
  preferredTimeEnd   DateTime?
  timezone           String    @default("Asia/Kolkata")

  // Assignment
  assignedAgentId String?

  // Status
  status CallbackStatus @default(PENDING)

  // Attempts
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  nextAttemptAt DateTime?
  maxAttempts   Int       @default(3)

  // Outcome
  outcomeCallId String? // Reference to the callback call made
  completedAt   DateTime?
  completedById String?
  outcome       String? // CONNECTED, NO_ANSWER, BUSY, CANCELLED
  notes         String?   @db.Text

  // Priority
  priority Int @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([scheduledAt, status])
  @@index([assignedAgentId, status])
  @@map("callback_requests")
}

enum CallbackSource {
  QUEUE_OVERFLOW // From queue overflow
  VOICEMAIL // From voicemail
  IVR // From IVR option
  MANUAL // Manually created
  ABANDONED // From abandoned call
  WEB_FORM // From website form
}

enum CallbackStatus {
  PENDING // Waiting to be called
  SCHEDULED // Scheduled for specific time
  IN_PROGRESS // Currently being called
  COMPLETED // Successfully called back
  FAILED // All attempts failed
  CANCELLED // Cancelled by user/agent
  EXPIRED // Expired without callback
}

// Detailed Inbound Call Log
model InboundCallLog {
  id             String @id @default(uuid())
  organizationId String

  // Call Identifiers
  providerCallSid String? @unique
  provider        String  @default("EXOTEL") // EXOTEL, TWILIO, PLIVO

  // Caller Info
  callerNumber String
  callerName   String?
  calledNumber String // DID/inbound number called
  leadId       String?

  // Call Path
  ivrFlowId        String?
  queueId          String?
  answeredByUserId String?

  // IVR Data
  ivrPath   Json @default("[]") // Path through IVR nodes
  ivrInputs Json @default("{}") // DTMF inputs collected

  // Queue Data
  queueEntryId  String?
  queueWaitTime Int? // Seconds waited in queue

  // Call Status
  status InboundCallStatus @default(INITIATED)

  // Timing
  startedAt  DateTime?
  queuedAt   DateTime?
  answeredAt DateTime?
  endedAt    DateTime?
  duration   Int? // Total duration
  talkTime   Int? // Actual talk time with agent

  // Recording
  recordingUrl String?
  recordingSid String?

  // Transcription
  transcript Json?   @default("[]")
  summary    String? @db.Text
  sentiment  String?

  // Transfer Info
  wasTransferred Boolean   @default(false)
  transferType   String? // warm, cold, queue
  transferredTo  String?
  transferredAt  DateTime?

  // Outcome
  outcome         InboundCallOutcome?
  outcomeNotes    String?
  dispositionCode String?

  // After-call work
  wrapUpTime Int? // Seconds in wrap-up
  tags       Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ivrFlow      IvrFlow?     @relation(fields: [ivrFlowId], references: [id])
  queue        CallQueue?   @relation(fields: [queueId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([organizationId, status, createdAt])
  @@index([callerNumber])
  @@index([calledNumber])
  @@index([leadId])
  @@index([queueId, status])
  @@index([answeredByUserId, createdAt])
  @@map("inbound_call_logs")
}

enum InboundCallStatus {
  INITIATED // Call started
  IN_IVR // In IVR flow
  IN_QUEUE // Waiting in queue
  RINGING_AGENT // Ringing an agent
  IN_PROGRESS // Connected to agent
  ON_HOLD // On hold during call
  TRANSFERRING // Being transferred
  COMPLETED // Call ended normally
  ABANDONED // Caller hung up
  VOICEMAIL // Went to voicemail
  FAILED // Technical failure
}

enum InboundCallOutcome {
  RESOLVED // Issue resolved
  FOLLOWUP // Needs follow-up
  TRANSFERRED // Transferred elsewhere
  VOICEMAIL // Left voicemail
  ABANDONED // Caller abandoned
  CALLBACK // Callback scheduled
  NOT_INTERESTED // Not interested
  WRONG_NUMBER // Wrong number
}

// Agent Skills for skills-based routing
model AgentSkill {
  id             String @id @default(uuid())
  organizationId String

  name        String
  slug        String
  description String?

  // Skill level requirements
  minLevel Int @default(1) // Minimum skill level (1-10)
  maxLevel Int @default(10)

  // Category
  category String? // "language", "product", "technical"

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
  @@map("agent_skills")
}

// Agent Skill Assignment (linking users to skills)
model AgentSkillAssignment {
  id      String @id @default(uuid())
  userId  String
  skillId String

  // Skill proficiency level (1-10)
  level Int @default(5)

  // Certification
  certifiedAt   DateTime?
  certifiedById String?
  expiresAt     DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
  @@index([skillId, level])
