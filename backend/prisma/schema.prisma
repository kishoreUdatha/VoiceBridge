// Lead Scoring
model LeadScore {
  id     String @id @default(uuid())
  leadId String @unique

  // Scores (0-100)
  overallScore       Int @default(0)
  engagementScore    Int @default(0)
  qualificationScore Int @default(0)
  sentimentScore     Int @default(0)
  intentScore        Int @default(0)

  // AI Analysis
  buyingSignals Json? @default("[]")
  objections    Json? @default("[]")
  interests     Json? @default("[]")

  // Scoring Factors
  callCount       Int       @default(0)
  avgCallDuration Int       @default(0)
  responseRate    Float     @default(0)
  lastInteraction DateTime?

  // Classification
  grade    LeadGrade @default(C)
  priority Int       @default(5)

  // AI Classification (Enterprise Feature)
  aiClassification         String? // hot_lead, warm_lead, cold_lead, not_qualified
  classificationConfidence Float   @default(0)
  demographicScore         Int     @default(0)
  behaviorScore            Int     @default(0)

  // Decay tracking
  lastCalculatedAt DateTime?
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_scores")
}

enum LeadGrade {
  A_PLUS // Hot - Ready to buy
  A // Very interested
  B // Interested
  C // Neutral
  D // Low interest
  F // Not interested
}

// Scheduled Calls & Callbacks
model ScheduledCall {
  id             String  @id @default(uuid())
  organizationId String
  agentId        String
  leadId         String?

  // Contact Info
  phoneNumber String
  contactName String?

  // Schedule
  scheduledAt     DateTime
  timezone        String   @default("Asia/Kolkata")
  reminderMinutes Int      @default(15)

  // Type
  callType ScheduledCallType @default(SCHEDULED)
  priority Int               @default(5)
  notes    String?

  // Status
  status        ScheduledCallStatus @default(PENDING)
  attemptCount  Int                 @default(0)
  lastAttemptAt DateTime?
  completedAt   DateTime?
  resultCallId  String? // Link to OutboundCall when completed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        VoiceAgent   @relation(fields: [agentId], references: [id])

  @@index([organizationId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("scheduled_calls")
}

enum ScheduledCallType {
  SCHEDULED // Admin scheduled
  CALLBACK // Customer requested callback
  FOLLOWUP // AI recommended follow-up
  REMINDER // Appointment reminder
}

enum ScheduledCallStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
  RESCHEDULED
}

// Do Not Call List
model DoNotCallList {
