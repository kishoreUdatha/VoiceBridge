// ==================== RAW IMPORT RECORDS ====================

enum BulkImportStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum RawImportRecordStatus {
  PENDING // Just uploaded
  ASSIGNED // Assigned to telecaller/AI
  CALLING // AI/telecaller calling
  INTERESTED // Contact interested
  NOT_INTERESTED // Not interested
  NO_ANSWER // Could not reach
  CALLBACK_REQUESTED
  CONVERTED // Converted to lead
  REJECTED // Admin rejected
}

// Bulk Import batch tracking
model BulkImport {
  id             String @id @default(uuid())
  organizationId String
  uploadedById   String

  // File info
  fileName String
  fileSize Int     @default(0)
  mimeType String?

  // Stats
  totalRows      Int @default(0)
  validRows      Int @default(0)
  invalidRows    Int @default(0)
  duplicateRows  Int @default(0)
  convertedCount Int @default(0)

  // Status
  status       BulkImportStatus @default(PROCESSING)
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User              @relation("BulkImportUploader", fields: [uploadedById], references: [id])
  records      RawImportRecord[]

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@map("bulk_imports")
}

// Raw imported records - not yet leads
model RawImportRecord {
  id             String @id @default(uuid())
  bulkImportId   String
  organizationId String
  orgBranchId    String? // Organization branch for multi-branch support

  // Contact info
  firstName      String
  lastName       String?
  email          String?
  phone          String
  alternatePhone String?
  customFields   Json?   @default("{}")

  // Assignment
  assignedToId    String? // Telecaller user
  assignedAgentId String? // AI Voice agent
  assignedById    String? // Who assigned
  assignedAt      DateTime?

  // Status tracking
  status RawImportRecordStatus @default(PENDING)

  // Call tracking
  lastCallAt     DateTime?
  callAttempts   Int       @default(0)
  outboundCallId String? // Reference to outbound call if AI called

  // Call outcome data
  interestLevel String? // high, medium, low
  notes         String? @db.Text
  callSummary   String? @db.Text
  callSentiment String? // positive, neutral, negative

  // Conversion tracking
  convertedLeadId String? // Reference to lead if converted
  convertedAt     DateTime?
  convertedById   String? // Who converted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bulkImport    BulkImport   @relation(fields: [bulkImportId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgBranch     Branch?      @relation(fields: [orgBranchId], references: [id])
  assignedTo    User?        @relation("RawImportAssignedTo", fields: [assignedToId], references: [id])
  assignedAgent VoiceAgent?  @relation("RawImportAIAgent", fields: [assignedAgentId], references: [id])
  assignedBy    User?        @relation("RawImportAssignedBy", fields: [assignedById], references: [id])
  convertedBy   User?        @relation("RawImportConvertedBy", fields: [convertedById], references: [id])
  convertedLead Lead?        @relation("RawImportConvertedLead", fields: [convertedLeadId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, orgBranchId])
  @@index([bulkImportId])
  @@index([assignedToId])
  @@index([assignedAgentId])
  @@index([phone])
  @@index([email])
  @@map("raw_import_records")
}

// ==================== ASSIGNMENT SCHEDULE (Automated Raw Import Assignment) ====================

enum ScheduleType {
  DAILY
  HOURLY
  CUSTOM_CRON
}

enum DistributionStrategy {
  ROUND_ROBIN // Equal split
  CAPACITY_BASED // Based on pending count (recommended)
  PRIORITY_BASED // Senior telecallers first
}

model AssignmentSchedule {
  id             String   @id @default(uuid())
  organizationId String
  orgBranchId    String?  // Optional: null = org-wide, set = branch-specific
  name           String // "Morning Assignment", "Afternoon Top-up"
  isActive       Boolean  @default(true)

  // Schedule timing
  scheduleType  ScheduleType @default(DAILY)
  scheduleTimes String[]     @default(["09:00", "13:00", "17:00"]) // Times to run
  timezone      String       @default("Asia/Kolkata")
  cronExpression String?     // For CUSTOM_CRON type

  // Assignment targets
  assignToTelecallers Boolean @default(true)
  assignToVoiceAgents Boolean @default(false)
  voiceAgentId        String? // Specific agent, or null for round-robin

  // Limits
  telecallerDailyLimit Int @default(200)
  voiceAgentDailyLimit Int @default(500)

  // Distribution strategy
  distributionStrategy DistributionStrategy @default(CAPACITY_BASED)

  // Filter settings - which records to assign
  bulkImportIds Json? @default("[]") // Specific bulk imports, or empty for all

  // Tracking
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgBranch    Branch?            @relation("AssignmentScheduleBranch", fields: [orgBranchId], references: [id], onDelete: SetNull)
  voiceAgent   VoiceAgent?        @relation("AssignmentScheduleAgent", fields: [voiceAgentId], references: [id], onDelete: SetNull)
  runLogs      AssignmentRunLog[]

  @@index([organizationId])
  @@index([organizationId, orgBranchId])
  @@index([nextRunAt])
  @@index([isActive, nextRunAt])
  @@map("assignment_schedules")
}

model AssignmentRunLog {
  id             String   @id @default(uuid())
  scheduleId     String
  organizationId String
  orgBranchId    String?  // Branch this run was for (null = org-wide)
  runAt          DateTime @default(now())

  // Results
  totalRecordsAssigned  Int  @default(0)
  telecallerAssignments Json @default("[]") // [{userId, userName, count}]
  voiceAgentAssignments Json @default("[]") // [{agentId, agentName, count}]
  recordsSkipped        Int  @default(0) // Already at limit
  pendingBefore         Int  @default(0) // Records pending before run
  pendingAfter          Int  @default(0) // Records pending after run
  branchBreakdown       Json @default("{}") // Per-branch stats for org-wide runs: {branchId: {assigned, skipped}}
  errors                String?

  // Run metadata
  runDurationMs Int? // How long the run took
  triggeredBy   String? // "scheduler" or userId for manual runs

  schedule AssignmentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([organizationId, runAt])
  @@map("assignment_run_logs")
}

