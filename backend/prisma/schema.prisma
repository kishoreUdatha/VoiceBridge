// ==========================================
// QUOTATION MANAGEMENT
// ==========================================

// Quotation / Proposal
model Quotation {
  id              String   @id @default(uuid())
  organizationId  String
  leadId          String?

  // Quotation Info
  quotationNumber String   @unique
  title           String
  description     String?

  // Client Info (can differ from lead)
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientCompany   String?
  clientAddress   String?
  clientGSTIN     String?  // GST Number for India

  // Dates
  issueDate       DateTime @default(now())
  validUntil      DateTime?

  // Amounts (calculated from items)
  subtotal        Decimal  @db.Decimal(12, 2)
  discountType    String?  // percentage, fixed
  discountValue   Decimal? @db.Decimal(12, 2)
  discountAmount  Decimal? @db.Decimal(12, 2)
  taxType         String?  // GST, VAT, none
  taxPercentage   Decimal? @db.Decimal(5, 2)
  taxAmount       Decimal? @db.Decimal(12, 2)
  totalAmount     Decimal  @db.Decimal(12, 2)
  currency        String   @default("INR")

  // Terms
  termsConditions String?
  notes           String?
  paymentTerms    String?  // e.g., "50% advance, 50% on delivery"

  // Status
  status          QuotationStatus @default(DRAFT)

  // Tracking
  viewedAt        DateTime?
  viewCount       Int      @default(0)

  // E-Signature
  signatureStatus String?  // pending, signed, declined
  signatureUrl    String?
  signedAt        DateTime?
  signedByName    String?
  signedByEmail   String?
  signatureData   Json?    // IP address, user agent, etc.

  // Payment
  paymentLinkId   String?
  paymentLinkUrl  String?
  paymentStatus   String?  // pending, partial, paid
  paidAmount      Decimal? @db.Decimal(12, 2)

  // Conversion tracking
  convertedToInvoice Boolean @default(false)
  invoiceId       String?

  // Created/Modified by
  createdById     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead            Lead?            @relation(fields: [leadId], references: [id])
  items           QuotationItem[]
  versions        QuotationVersion[]
  payments        QuotationPayment[]
  dealIntelligence DealIntelligence[]

  @@index([organizationId, status])
  @@index([leadId])
  @@index([quotationNumber])
  @@map("quotations")
}

// Quotation Line Items
model QuotationItem {
  id              String   @id @default(uuid())
  quotationId     String

  // Item details
  name            String
  description     String?
  sku             String?  // Product SKU if applicable

  // Pricing
  quantity        Decimal  @db.Decimal(10, 2) @default(1)
  unit            String?  // pcs, hrs, kg, etc.
  unitPrice       Decimal  @db.Decimal(12, 2)
  discountPercent Decimal? @db.Decimal(5, 2)
  taxPercent      Decimal? @db.Decimal(5, 2)
  totalPrice      Decimal  @db.Decimal(12, 2)

  // HSN/SAC code (for India GST)
  hsnSacCode      String?

  // Order
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())

  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

// Quotation Version History
model QuotationVersion {
  id              String   @id @default(uuid())
  quotationId     String
  versionNumber   Int

  // Snapshot of quotation at this version
  snapshot        Json

  // Changes
  changeNotes     String?
  changedById     String?

  createdAt       DateTime @default(now())

  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@unique([quotationId, versionNumber])
  @@map("quotation_versions")
}

// Quotation Payment Tracking
model QuotationPayment {
  id              String   @id @default(uuid())
  quotationId     String

  // Payment details
  amount          Decimal  @db.Decimal(12, 2)
  method          String   // razorpay, bank_transfer, cash, cheque
  reference       String?  // Transaction ID / UTR

  // Razorpay specific
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  // Status
  status          String   @default("pending") // pending, completed, failed, refunded

  // Notes
  notes           String?

  receivedAt      DateTime?
  createdAt       DateTime @default(now())

  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([razorpayOrderId])
  @@map("quotation_payments")
}

// Product/Service Catalog for Quotations
model ProductCatalog {
  id              String   @id @default(uuid())
  organizationId  String

  // Product info
  name            String
  description     String?
  sku             String?
  category        String?

  // Pricing
  unitPrice       Decimal  @db.Decimal(12, 2)
  unit            String?  // pcs, hrs, kg, etc.
  currency        String   @default("INR")

  // Tax
  taxable         Boolean  @default(true)
  hsnSacCode      String?
  defaultTaxRate  Decimal? @db.Decimal(5, 2)

  // Status
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@unique([organizationId, sku])
  @@map("product_catalog")
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

// ==================== APPROVAL WORKFLOWS ====================

// Approval Workflow Definition
model ApprovalWorkflow {
  id              String   @id @default(uuid())
  organizationId  String

  name            String
  description     String?

  // What type of items this workflow applies to
  entityType      ApprovalEntityType

  // Conditions for when this workflow is triggered
  conditions      Json?    // e.g., { "amountGreaterThan": 10000, "leadStage": "CONVERTED" }

  // Is this the default workflow for this entity type?
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User?              @relation("WorkflowCreator", fields: [createdById], references: [id])
  steps           ApprovalStep[]
  requests        ApprovalRequest[]

  @@unique([organizationId, name])
  @@index([organizationId, entityType, isActive])
  @@map("approval_workflows")
}

// Approval Step (defines who needs to approve at each level)
model ApprovalStep {
  id              String   @id @default(uuid())
  workflowId      String

  // Step order (1, 2, 3, etc.)
  stepOrder       Int
  name            String
  description     String?

  // Who can approve at this step
  approverType    ApproverType
  approverRoleId  String?  // If approverType is ROLE
  approverUserId  String?  // If approverType is SPECIFIC_USER

  // Can any one approver approve, or do all need to approve?
  approvalMode    ApprovalMode @default(ANY)

  // Auto-approve conditions
  autoApproveConditions Json? // e.g., { "amountLessThan": 5000 }

  // SLA for this step (in hours)
  slaHours        Int?

  // Escalation settings
  escalateAfterHours Int?
  escalateToUserId   String?
  escalateToRoleId   String?

  createdAt       DateTime @default(now())

  workflow        ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approverRole    Role?            @relation("StepApproverRole", fields: [approverRoleId], references: [id])
  approverUser    User?            @relation("StepApproverUser", fields: [approverUserId], references: [id])
  escalateToUser  User?            @relation("StepEscalateUser", fields: [escalateToUserId], references: [id])
  escalateToRole  Role?            @relation("StepEscalateRole", fields: [escalateToRoleId], references: [id])
  actions         ApprovalAction[]

  @@unique([workflowId, stepOrder])
  @@index([workflowId])
  @@map("approval_steps")
}

// Approval Request (actual request for approval)
model ApprovalRequest {
  id              String   @id @default(uuid())
  organizationId  String
  workflowId      String

  // What is being approved
  entityType      ApprovalEntityType
  entityId        String   // ID of lead, payment, admission, etc.

  // Request details
  title           String
  description     String?
  amount          Decimal? @db.Decimal(12, 2) // For payment/fee approvals
  metadata        Json?    // Additional context data

  // Current status
  status          ApprovalStatus @default(PENDING)
  currentStep     Int      @default(1)

  // Timestamps
  submittedAt     DateTime @default(now())
  completedAt     DateTime?

  // Who submitted this request
  submittedById   String

  // Final outcome
  finalDecision   ApprovalDecision?
  finalComments   String?
  decidedById     String?
  decidedAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow        ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  submittedBy     User             @relation("RequestSubmitter", fields: [submittedById], references: [id])
  decidedBy       User?            @relation("RequestDecider", fields: [decidedById], references: [id])
  actions         ApprovalAction[]

  @@index([organizationId, status])
  @@index([organizationId, entityType, entityId])
  @@index([submittedById])
