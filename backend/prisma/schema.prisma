  callId    String
  eventType String // initiated, ringing, answered, speech, ended
  data      Json?
  timestamp DateTime @default(now())

  @@index([callId, timestamp])
  @@map("call_events")
}

// ==================== TELECALLER QUEUE ====================

model TelecallerQueue {
  id             String  @id @default(uuid())
  organizationId String
  leadId         String?
  outboundCallId String? @unique

  // Contact Info
  phoneNumber String
  contactName String?
  email       String?

  // AI Call Context
  aiCallSummary   String?      @db.Text
  aiCallSentiment String? // positive, neutral, negative
  aiCallOutcome   CallOutcome?
  aiCallDuration  Int? // seconds
  qualification   Json?        @default("{}")

  // Queue Management
  priority Int                   @default(5) // 1=highest, 10=lowest
  status   TelecallerQueueStatus @default(PENDING)
  reason   String? // Why in queue (e.g., "Interested", "Callback requested")

  // Assignment
  assignedToId String?
  assignedAt   DateTime?

  // Telecaller Action
  telecallerNotes   String?            @db.Text
  telecallerOutcome TelecallerOutcome?
  callbackScheduled DateTime?

  // Timestamps
  addedAt     DateTime  @default(now())
  claimedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assignedTo User? @relation("TelecallerQueueAssignment", fields: [assignedToId], references: [id])

  @@index([organizationId, status, priority])
  @@index([assignedToId, status])
  @@map("telecaller_queue")
}

enum TelecallerQueueStatus {
  PENDING // In queue, not claimed
  CLAIMED // Telecaller working on it
  IN_CALL // Currently on call
  COMPLETED // Successfully handled
  CALLBACK // Scheduled for callback
  FAILED // Could not reach
  SKIPPED // Telecaller skipped
}

enum TelecallerOutcome {
  CONVERTED // Lead converted/enrolled
  APPOINTMENT_SET // Meeting scheduled
  CALLBACK_SET // Follow-up call scheduled
  NOT_INTERESTED // Lead declined
  WRONG_NUMBER // Invalid contact
  NO_ANSWER // Couldn't reach
  VOICEMAIL // Left voicemail
  DO_NOT_CALL // Requested no calls
}

// Analytics Aggregation
model AnalyticsDaily {
  id             String   @id @default(uuid())
  organizationId String
  agentId        String?
  date           DateTime @db.Date

  // Call Stats
  totalCalls    Int @default(0)
  answeredCalls Int @default(0)
  missedCalls   Int @default(0)
  totalDuration Int @default(0) // seconds
  avgDuration   Int @default(0)

