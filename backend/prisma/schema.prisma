model EmailSequence {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean @default(true)

  // Trigger Conditions
  triggerType    SequenceTriggerType
  triggerStageId String? // Trigger when lead enters this stage
  triggerSource  String? // Trigger for leads from this source
  triggerTags    Json                @default("[]") // Trigger for leads with these tags

  // Settings
  sendOnWeekends Boolean @default(false)
  sendTimeStart  String  @default("09:00") // Start sending after this time
  sendTimeEnd    String  @default("18:00") // Stop sending after this time
