  status InvoiceStatus @default(DRAFT)
  paidAt DateTime?

  // Razorpay
  razorpayPaymentId String?

  // Timestamps
  issuedAt  DateTime  @default(now())
  dueDate   DateTime?
  createdAt DateTime  @default(now())

