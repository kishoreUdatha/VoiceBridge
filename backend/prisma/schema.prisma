// ==================== PHONE NUMBER MANAGEMENT ====================

enum PhoneNumberType {
  LOCAL
  TOLL_FREE
  MOBILE
  VIRTUAL
}

enum PhoneNumberStatus {
  AVAILABLE
  ASSIGNED
  DISABLED
  PENDING
}

enum PhoneNumberProvider {
  EXOTEL
  TWILIO
  PLIVO
  MSG91
  MANUAL
}

// Source of phone number - PLATFORM (from VoiceBridge) or BYOC (customer's own carrier)
enum PhoneNumberSource {
  PLATFORM // Provided by VoiceBridge (master Exotel account)
  BYOC     // Bring Your Own Carrier - customer's own Exotel account
}

model PhoneNumber {
  id             String @id @default(uuid())
  organizationId String

  // Phone number details
  number        String // E.164 format: +919876543210
  displayNumber String? // Formatted for display: +91 98765 43210
  friendlyName  String? // "Sales Line", "Support", etc.

  // Provider info
  provider         PhoneNumberProvider @default(MANUAL)
  providerNumberId String? // External ID from provider (Exotel/Twilio)

  // Source tracking - PLATFORM (VoiceBridge provided) or BYOC (customer's own carrier)
  source      PhoneNumberSource @default(BYOC)
  sourceOrgId String? // For PLATFORM numbers, tracks which org "owns" the master account

  // Type and capabilities
  type          PhoneNumberType @default(LOCAL)
  callDirection CallDirection   @default(HYBRID) // INBOUND, OUTBOUND, or HYBRID
  capabilities  Json            @default("{\"voice\": true, \"sms\": false, \"whatsapp\": false}")

  // Status
  status PhoneNumberStatus @default(AVAILABLE)

  // Assignment
  assignedToAgentId String? // Which voice agent is using this number
  assignedAt        DateTime?

  // Cost tracking
  monthlyRent   Float  @default(0)
  perMinuteRate Float  @default(0)
  currency      String @default("INR")

  // Metadata
  region String? // "IN", "US", etc.
  city   String? // "Mumbai", "Delhi", etc.
  notes  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedAgent VoiceAgent?  @relation(fields: [assignedToAgentId], references: [id], onDelete: SetNull)
  callLogs      AICallLog[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([assignedToAgentId])
  @@map("phone_numbers")
}

// ==================== VOICE AI TEMPLATES (Organization-specific) ====================

model OrganizationVoiceTemplate {
  id             String @id @default(uuid())
  organizationId String

  // Template Info
  name        String
  slug        String
  description String?            @db.Text
  industry    VoiceAgentIndustry
  category    String? // Admissions, Support, Sales, etc.
  icon        String? // Icon name or emoji
  color       String             @default("#3B82F6")

  // AI Configuration
  systemPrompt String @db.Text
  voiceId      String @default("alloy")
  language     String @default("en")
  temperature  Float  @default(0.7)

  // Qualification Questions
  questions Json @default("[]")

  // Knowledge Base
  knowledgeBase String? @db.Text

  // FAQs
  faqs Json @default("[]")

  // Documents
  documents Json @default("[]")

  // Multi-language Greetings
  greetings Json @default("{}")

  // Default Messages
  greeting          String?
  fallbackMessage   String?
  transferMessage   String?
  endMessage        String?
  afterHoursMessage String? @db.Text

  // Behavior Settings
  personality       String @default("professional")
  responseSpeed     String @default("normal")
  interruptHandling String @default("polite")
  maxDuration       Int    @default(300)
  silenceTimeout    Int    @default(30)

  // Working Hours
  workingHoursEnabled Boolean @default(false)
  workingHoursStart   String  @default("09:00")
  workingHoursEnd     String  @default("18:00")
  workingDays         Json    @default("[\"Mon\", \"Tue\", \"Wed\", \"Thu\", \"Fri\"]")

  // Widget Settings
  widgetTitle    String?
  widgetSubtitle String?
  widgetColor    String  @default("#3B82F6")
  widgetPosition String  @default("bottom-right")

  // Lead Settings
  autoCreateLeads    Boolean @default(true)
  deduplicateByPhone Boolean @default(true)
  autoAdvanceStage   Boolean @default(false)

  // Appointment Settings
  appointmentEnabled  Boolean @default(false)
  appointmentType     String?
  appointmentDuration Int     @default(30)

  // CRM Settings
  crmIntegration       String?
  triggerWebhookOnLead Boolean @default(true)

  // Template Status
  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  // Version Control
  version   String @default("1.0.0")
  changelog Json   @default("[]")

  // Usage Stats
  agentsCreated Int       @default(0)
  lastUsedAt    DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, industry])
  @@index([organizationId, isActive])
  @@map("organization_voice_templates")
}

// ==================== VOICE AI AGENT ====================

model VoiceAgent {
  id             String             @id @default(uuid())
  organizationId String
  name           String
  description    String?
  industry       VoiceAgentIndustry
  agentType      AgentType          @default(VOICE) // Type of agent (VOICE, SALES, APPOINTMENT, etc.)
  callDirection  CallDirection      @default(HYBRID) // INBOUND, OUTBOUND, or HYBRID
  isActive       Boolean            @default(true)

  // ==================== PUBLISH STATUS ====================
  status          VoiceAgentPublishStatus @default(DRAFT) // DRAFT or PUBLISHED
  publishedAt     DateTime? // When the agent was last published
  publishedById   String? // Who published it
  publishedConfig Json? // Snapshot of config at publish time
  draftConfig     Json? // Current draft changes (if different from published)
  versionNumber   Int                     @default(1) // Increments on each publish
  versionHistory  Json                    @default("[]") // Array of {version, publishedAt, publishedBy, description}

  // AI Configuration
  systemPrompt String @db.Text
  voiceId      String @default("alloy") // OpenAI voice: alloy, echo, fable, onyx, nova, shimmer
  language     String @default("en")
  temperature  Float  @default(0.7)

  // LLM Model Configuration
  llmProvider String @default("openai") // openai, anthropic, google, groq
  llmModel    String @default("gpt-4o-mini") // gpt-4o, gpt-4o-mini, claude-3-sonnet, gemini-pro, llama-3

  // Qualification Questions
  questions Json @default("[]")

  // Knowledge Base
  knowledgeBase String? @db.Text
  faqs          Json    @default("[]")

  // Documents/Media for WhatsApp sharing
  // Each document: { id, name, type (pdf/image/video), url, description, keywords[] }
  documents Json @default("[]")

  // Behavior Settings
  greeting        String?
  fallbackMessage String?
  transferMessage String?
  endMessage      String?
  maxDuration     Int     @default(300) // seconds

  // AI Behavior Settings
  personality       String @default("professional") // professional, friendly, casual
  responseSpeed     String @default("normal") // fast, normal, thoughtful
  interruptHandling String @default("polite") // wait, polite

  // Call Handling Settings
  workingHoursEnabled Boolean @default(false)
  workingHoursStart   String  @default("09:00")
  workingHoursEnd     String  @default("18:00")
  workingDays         Json    @default("[\"Mon\", \"Tue\", \"Wed\", \"Thu\", \"Fri\"]")
  afterHoursMessage   String? @db.Text
  silenceTimeout      Int     @default(30) // seconds

  // Widget Settings
  widgetTitle    String?
  widgetSubtitle String?
  widgetColor    String  @default("#3B82F6")
  widgetPosition String  @default("bottom-right")

  // Realtime Settings
  realtimeEnabled Boolean @default(false)
  webrtcEnabled   Boolean @default(false)

  // Lead Generation Settings
  autoCreateLeads    Boolean @default(true)
  deduplicateByPhone Boolean @default(true)
  defaultStageId     String?
  defaultAssigneeId  String?
  autoAdvanceStage   Boolean @default(false)

  // Appointment Booking Settings
  appointmentEnabled  Boolean @default(false)
  appointmentType     String? // Default appointment type
  appointmentDuration Int     @default(30) // Default duration in minutes
  appointmentTimezone String  @default("Asia/Kolkata")

  // CRM Integration Settings
  crmIntegration       String? // "internal", "salesforce", "hubspot", "zoho", "custom"
  crmWebhookUrl        String? // Custom webhook URL for external CRM
  triggerWebhookOnLead Boolean @default(true) // Trigger webhooks when lead is created

  // ==================== AGENT TYPE SPECIFIC SETTINGS ====================

  // Sales Agent Settings
  salesPitch        String? @db.Text // Product/service pitch script
  objectionHandling Json    @default("[]") // Array of {objection, response}
  discountAuthority Float   @default(0) // Max discount % agent can offer
  pricingInfo       Json    @default("{}") // Product pricing details
  competitorInfo    Json    @default("[]") // Competitor comparison data
  closingTechniques Json    @default("[]") // Closing strategies

  // Appointment Agent Settings
  calendarIntegration String? // "google", "outlook", "calendly"
  calendarId          String? // Connected calendar ID
  slotDuration        Int     @default(30) // Default slot duration in minutes
  bufferTime          Int     @default(10) // Buffer between appointments
  maxAdvanceBooking   Int     @default(30) // Max days in advance to book
  reminderSchedule    Json    @default("[24, 1]") // Hours before to send reminders

  // Payment Agent Settings
  paymentGateway    String? // "razorpay", "stripe", "payu"
  paymentTypes      Json    @default("[\"full\", \"emi\", \"partial\"]")
  emiOptions        Json    @default("[]") // EMI plans available
  paymentReminders  Json    @default("[7, 3, 1, 0]") // Days before due to remind
  overdueEscalation Int     @default(7) // Days overdue before escalation

  // Support Agent Settings
  ticketSystem     String? // "internal", "freshdesk", "zendesk"
  ticketCategories Json    @default("[]") // Support categories
  escalationRules  Json    @default("[]") // When to escalate
  slaConfig        Json    @default("{}") // SLA settings
  knowledgeBaseId  String? // Link to knowledge base

  // Follow-up Agent Settings
  followupSequence    Json    @default("[]") // Array of {dayOffset, channel, template}
  reengagementTrigger Int     @default(7) // Days of inactivity to trigger
  maxFollowups        Int     @default(5) // Max follow-up attempts
  winbackEnabled      Boolean @default(true) // Enable win-back campaigns

  // Survey Agent Settings
  surveyType      String? @default("NPS") // "NPS", "CSAT", "CES", "custom"
  surveyQuestions Json    @default("[]") // Survey questions
  surveyTrigger   String? @default("post_purchase") // When to trigger
  surveyDelay     Int     @default(7) // Days after trigger to send
  reviewPlatforms Json    @default("[]") // Google, G2, etc.

  // ==================== WORKFLOW SETTINGS ====================
  workflowSteps Json @default("[]") // Array of {id, name, description, color, conditions}

  // ==================== BRANCHES/VERSION CONTROL ====================
  branches      Json   @default("[]") // Array of {id, name, description, active, createdAt}
  activeBranch  String @default("main")
  branchHistory Json   @default("[]") // Array of {action, branch, timestamp, userId}

  // ==================== ANALYSIS/EVALUATION SETTINGS ====================
  evaluationCriteria   Json   @default("[]") // Array of {id, name, weight, description}
  dataCollectionPoints Json   @default("[]") // Array of {id, name, type, extractionRule}
  analysisLanguage     String @default("auto") // auto, en, es, fr, etc.

  // ==================== TEST CASES ====================
  testCases Json @default("[]") // Array of {id, name, description, steps, expectedOutcome, status, lastRun}

  // ==================== SECURITY SETTINGS ====================
  authenticationRequired Boolean @default(false)

  // Pre-chat form settings (for lead capture authentication)
  preChatFormEnabled  Boolean @default(false)
  preChatFormFields   Json    @default("[{\"name\": \"name\", \"label\": \"Name\", \"type\": \"text\", \"required\": true}, {\"name\": \"email\", \"label\": \"Email\", \"type\": \"email\", \"required\": true}, {\"name\": \"phone\", \"label\": \"Phone\", \"type\": \"tel\", \"required\": false}]")
  preChatFormTitle    String  @default("Before we start")
  preChatFormSubtitle String  @default("Please provide your details")
  createLeadFromForm  Boolean @default(true) // Auto-create lead from form data

  rateLimitingEnabled     Boolean @default(true)
  rateLimitRequests       Int     @default(60) // requests per minute
  rateLimitBurst          Int     @default(10) // burst limit
  contentFilteringEnabled Boolean @default(true)
  contentFilterCategories Json    @default("[\"profanity\", \"violence\", \"adult\", \"hate_speech\"]")
  dataRetentionDays       Int     @default(90)
  anonymizeUserData       Boolean @default(true)
  gdprComplianceEnabled   Boolean @default(true)
  allowedDomains          Json    @default("[]") // Array of allowed domains for widget embedding
  ipWhitelist             Json    @default("[]") // Array of allowed IP addresses
  sessionTimeoutMinutes   Int     @default(30)

  // ==================== WHATSAPP FOLLOW-UP SETTINGS ====================
  whatsappFollowupEnabled Boolean @default(false) // Send WhatsApp after call ends
  whatsappFollowupMessage String? @db.Text // Message template: {{name}}, {{summary}}, {{duration}}
  whatsappFollowupDelay   Int     @default(0) // Delay in seconds before sending (0 = immediate)

  // ==================== ADVANCED SETTINGS ====================
  topP              Float   @default(0.9) // Nucleus sampling
  frequencyPenalty  Float   @default(0.0) // Frequency penalty
  presencePenalty   Float   @default(0.0) // Presence penalty
  maxResponseTokens Int     @default(500) // Max tokens in response
  stopSequences     Json    @default("[]") // Array of stop sequences
  speechRate        Float   @default(1.0) // TTS speech rate (0.5-2.0)
  voicePitch        Float   @default(0.0) // Voice pitch adjustment (-1.0 to 1.0)
  silenceDetection  Boolean @default(true)
  debugMode         Boolean @default(false)
  logLevel          String  @default("info") // error, warning, info, debug, trace
  logConversations  Boolean @default(true)

  // ==================== RAG SETTINGS ====================
  ragSettings Json @default("{\"chunkSize\": 1000, \"chunkOverlap\": 200, \"topK\": 5, \"similarityThreshold\": 0.7, \"embeddingModel\": \"text-embedding-ada-002\", \"searchType\": \"semantic\"}")

  // Metadata for extensibility
  metadata Json @default("{}")

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User?                  @relation("VoiceAgentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  publishedBy       User?                  @relation("VoiceAgentPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  sessions          VoiceSession[]
  outboundCampaigns OutboundCallCampaign[]
  outboundCalls     OutboundCall[]
  scheduledCalls    ScheduledCall[]
  rawImportRecords    RawImportRecord[]    @relation("RawImportAIAgent")
  phoneNumbers        PhoneNumber[] // Phone numbers assigned to this agent
  followUps           FollowUp[] // Follow-ups assigned to this AI agent
  assignmentSchedules AssignmentSchedule[] @relation("AssignmentScheduleAgent")

  // Integration Relations
  agentIntegrations  AgentIntegration[]
  customApiEndpoints CustomApiEndpoint[]

  // Call Flow Reference
  callFlowId String?
  callFlow   CallFlow? @relation(fields: [callFlowId], references: [id], onDelete: SetNull)

  // RAG Knowledge Chunks
  knowledgeChunks KnowledgeChunk[]

  @@map("voice_agents")
}

// ==================== CALL FLOW BUILDER ====================

enum CallFlowNodeType {
  START
  GREETING
  QUESTION
  CONDITION
  AI_RESPONSE
  ACTION
  TRANSFER
  END
}

enum CallFlowActionType {
  BOOK_APPOINTMENT
  SEND_SMS
  SEND_WHATSAPP
  SEND_EMAIL
  CREATE_LEAD
  UPDATE_LEAD
  TRIGGER_WEBHOOK
  COLLECT_PAYMENT
  PLAY_AUDIO
}

enum CallOutcome {
  INTERESTED
  NOT_INTERESTED
  CALLBACK_REQUESTED
  APPOINTMENT_BOOKED
  PAYMENT_COLLECTED
  TRANSFERRED
  VOICEMAIL
  NO_ANSWER
  WRONG_NUMBER
  DNC_REQUESTED
  COMPLETED
  DROPPED
  BUSY
  DO_NOT_CALL
  CONVERTED
  NEEDS_FOLLOWUP
}

model CallFlow {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  description    String?
  industry       String? // Target industry for this flow
  isActive       Boolean @default(true)
  isTemplate     Boolean @default(false) // Can be used as template
  version        Int     @default(1)

  // Flow Configuration
  nodes     Json @default("[]") // Array of CallFlowNode data
  edges     Json @default("[]") // Array of {source, target, condition}
  variables Json @default("[]") // Flow variables to collect

  // Default Messages
  defaultGreeting String? @db.Text
  defaultFallback String? @db.Text
  defaultTransfer String? @db.Text
  defaultEnd      String? @db.Text

  // Outcome Configuration
  successOutcomes Json @default("[\"INTERESTED\", \"APPOINTMENT_BOOKED\", \"PAYMENT_COLLECTED\"]")
  failureOutcomes Json @default("[\"NOT_INTERESTED\", \"WRONG_NUMBER\", \"DNC_REQUESTED\"]")

  // Analytics
  totalCalls      Int   @default(0)
  successfulCalls Int   @default(0)
  avgDuration     Float @default(0)
  conversionRate  Float @default(0)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("CallFlowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  voiceAgents  VoiceAgent[]
  callLogs     CallFlowLog[]

  @@index([organizationId, isActive])
  @@index([organizationId, createdAt])
  @@map("call_flows")
}

model CallFlowLog {
  id         String  @id @default(uuid())
  callFlowId String
  sessionId  String? // VoiceSession ID or OutboundCall ID
  leadId     String?

  // Call Details
  phoneNumber String
  direction   String    @default("outbound") // inbound, outbound
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  duration    Int? // seconds

  // Flow Execution
  nodesVisited       Json    @default("[]") // Array of node IDs visited
  variablesCollected Json    @default("{}") // Collected variable values
  currentNodeId      String? // Current/last node

  // Outcome
  outcome       CallOutcome?
  outcomeReason String?
  sentiment     String? // positive, neutral, negative
  qualityScore  Float? // 1-10 AI quality score

  // Transcript
  transcript Json    @default("[]") // Full conversation transcript
  summary    String? @db.Text // AI-generated summary

  // Actions Taken
  actionsTaken Json @default("[]") // Actions executed during call

  createdAt DateTime @default(now())

  callFlow CallFlow @relation(fields: [callFlowId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([callFlowId, startedAt])
  @@index([sessionId])
  @@map("call_flow_logs")
}

model VoiceSession {
  id           String  @id @default(uuid())
  agentId      String
  leadId       String?
  sessionToken String  @unique

  // Visitor Info
  visitorName   String?
  visitorEmail  String?
  visitorPhone  String?
  visitorIp     String?
  visitorDevice String?

  // Session Data
  status        VoiceSessionStatus @default(ACTIVE)
  mode          VoiceSessionMode   @default(BATCH)
  duration      Int? // seconds
  qualification Json?              @default("{}") // Collected qualification data
  sentiment     String? // positive, neutral, negative
  summary       String?            @db.Text

  // Realtime-specific fields
  realtimeSessionId String? // OpenAI realtime session ID
  interruptionCount Int     @default(0)

  // Timestamps
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  agent          VoiceAgent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lead           Lead?             @relation(fields: [leadId], references: [id])
  transcripts    VoiceTranscript[]
  realtimeEvents RealtimeEvent[]

  @@index([agentId, status])
  @@index([realtimeSessionId])
  @@map("voice_sessions")
}

model RealtimeEvent {
  id        String   @id @default(uuid())
  sessionId String
  eventType String // speech_started, response_audio, interruption, etc.
  eventData Json?
  latencyMs Int?
  timestamp DateTime @default(now())

  session VoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@map("realtime_events")
}

model VoiceTranscript {
  id        String   @id @default(uuid())
  sessionId String
  role      String // user or assistant
  content   String   @db.Text
  audioUrl  String?
  duration  Float? // seconds
  timestamp DateTime @default(now())

  session VoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@map("voice_transcripts")
}

enum VoiceAgentIndustry {
  EDUCATION
  IT_RECRUITMENT
  REAL_ESTATE
  CUSTOMER_CARE
  TECHNICAL_INTERVIEW
  HEALTHCARE
  FINANCE
  ECOMMERCE
  CUSTOM
}

// Agent Types for different purposes
enum AgentType {
  VOICE // Voice calling agent (default)
  SALES // Sales/closing agent
  APPOINTMENT // Appointment booking agent
  PAYMENT // Payment collection agent
  SUPPORT // Customer support agent
  FOLLOWUP // Follow-up/nurturing agent
  SURVEY // Survey/feedback agent
}

enum VoiceSessionStatus {
  ACTIVE
  COMPLETED
  TRANSFERRED
  ABANDONED
  ERROR
}

enum VoiceSessionMode {
  BATCH
  REALTIME
  WEBRTC
}

// ==================== OUTBOUND AI CALLING ====================

model OutboundCallCampaign {
  id             String                 @id @default(uuid())
  organizationId String
  agentId        String
  name           String
  description    String?
  status         OutboundCampaignStatus @default(DRAFT)

  // Settings
  callingMode        CallingMode @default(AUTOMATIC) // AUTOMATIC or MANUAL
  maxConcurrentCalls Int         @default(1)
  callsBetweenHours  Json?       @default("{\"start\": 9, \"end\": 18}")
  retryAttempts      Int         @default(2)
  retryDelayMinutes  Int         @default(30)

  // Stats
  totalContacts   Int @default(0)
  completedCalls  Int @default(0)
  successfulCalls Int @default(0)
  failedCalls     Int @default(0)
  leadsGenerated  Int @default(0)

  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agent    VoiceAgent            @relation(fields: [agentId], references: [id])
  contacts OutboundCallContact[]
  calls    OutboundCall[]

  @@map("outbound_call_campaigns")
}

model OutboundCallContact {
  id         String  @id @default(uuid())
  campaignId String
  leadId     String?

  // Contact Info
  phone      String
  name       String?
  email      String?
  customData Json?   @default("{}")

  // Status
  status        OutboundContactStatus @default(PENDING)
  attempts      Int                   @default(0)
  lastAttemptAt DateTime?
  nextAttemptAt DateTime?
  notes         String? // P0 Compliance: Notes for DNC blocks, compliance skips, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign OutboundCallCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  calls    OutboundCall[]

  @@index([campaignId, status])
  @@map("outbound_call_contacts")
}

model OutboundCall {
  id         String  @id @default(uuid())
  campaignId String?
  contactId  String?
  agentId    String
  leadId     String?

  // Call Info
  phoneNumber   String
  twilioCallSid String?            @unique
  direction     CallDirection      @default(OUTBOUND)
  status        OutboundCallStatus @default(INITIATED)

  // Consent Tracking
  consentGiven   Boolean? // null = not asked yet, true/false = answered
  consentAskedAt DateTime?
  language       String?   @default("en-US") // Language used in call

  // Timing
  duration     Int? // seconds
  ringDuration Int? // seconds
  startedAt    DateTime?
  answeredAt   DateTime?
  endedAt      DateTime?

  // Recording
  recordingUrl      String?
  recordingSid      String?
  recordingDuration Int?

  // AI Conversation
  conversationId String? @unique
  transcript     Json?   @default("[]")
  summary        String? @db.Text
  sentiment      String?
  qualification  Json?   @default("{}")

  // Extracted Call Data (structured info captured from conversation)
  extractedData Json? @default("{}") // Course interest, callback time, budget, etc.

  // Enhanced Call Summary Fields
  callQualityScore     Int?
  keyQuestionsAsked    Json?   @default("[]")
  keyIssuesDiscussed   Json?   @default("[]")
  sentimentIntensity   String?
  agentSpeakingTime    Int?    // seconds
  customerSpeakingTime Int?    // seconds
  nonSpeechTime        Int?    // seconds
  enhancedTranscript   Json?   // Per-message timestamps and sentiment

  // AI Coaching Suggestions
  coachingPositiveHighlights Json?   @default("[]") // What agent did well
  coachingAreasToImprove     Json?   @default("[]") // Areas needing improvement
  coachingNextCallTips       Json?   @default("[]") // Tips for next call
  coachingSummary            String? @db.Text       // Overall coaching summary
  coachingTalkListenFeedback String?               // Talk-to-listen ratio feedback
  coachingEmpathyScore       Int?                  // 0-100
  coachingObjectionScore     Int?                  // Objection handling 0-100
  coachingClosingScore       Int?                  // Closing technique 0-100

  // Outcome
  outcome      CallOutcome?
  outcomeNotes String?

  // Lead Generation
  leadGenerated   Boolean @default(false)
  generatedLeadId String?

  // Link to existing lead (for follow-up calls)
  existingLeadId String?
  isFollowUpCall Boolean @default(false)
  followUpNumber Int     @default(1) // 1st call, 2nd call, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign     OutboundCallCampaign? @relation(fields: [campaignId], references: [id])
  contact      OutboundCallContact?  @relation(fields: [contactId], references: [id])
  agent        VoiceAgent            @relation(fields: [agentId], references: [id])
  existingLead Lead?                 @relation("LeadOutboundCalls", fields: [existingLeadId], references: [id])

  @@index([campaignId, status])
  @@index([agentId, createdAt])
  @@index([existingLeadId])
  @@index([phoneNumber])
  @@index([callQualityScore])
  @@map("outbound_calls")
}

enum OutboundCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

enum CallingMode {
  AUTOMATIC // System auto-dials contacts
  MANUAL // User manually triggers each call
}

enum OutboundContactStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  DO_NOT_CALL
  SCHEDULED
  SKIPPED // P0 Compliance: Contact skipped due to DNC or other compliance reason
}

enum OutboundCallStatus {
  INITIATED
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  BUSY
  NO_ANSWER
  FAILED
  CANCELLED
}

// ==================== ADVANCED FEATURES ====================

// Lead Scoring
model LeadScore {
  id     String @id @default(uuid())
  leadId String @unique

  // Scores (0-100)
  overallScore       Int @default(0)
  engagementScore    Int @default(0)
  qualificationScore Int @default(0)
  sentimentScore     Int @default(0)
  intentScore        Int @default(0)

  // AI Analysis
  buyingSignals Json? @default("[]")
  objections    Json? @default("[]")
  interests     Json? @default("[]")

  // Scoring Factors
  callCount       Int       @default(0)
  avgCallDuration Int       @default(0)
  responseRate    Float     @default(0)
  lastInteraction DateTime?

  // Classification
  grade    LeadGrade @default(C)
  priority Int       @default(5)

  // AI Classification (Enterprise Feature)
  aiClassification         String? // hot_lead, warm_lead, cold_lead, not_qualified
  classificationConfidence Float   @default(0)
  demographicScore         Int     @default(0)
  behaviorScore            Int     @default(0)

  // Decay tracking
  lastCalculatedAt DateTime?
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_scores")
}

enum LeadGrade {
  A_PLUS // Hot - Ready to buy
  A // Very interested
  B // Interested
  C // Neutral
  D // Low interest
  F // Not interested
}

// Scheduled Calls & Callbacks
model ScheduledCall {
  id             String  @id @default(uuid())
  organizationId String
  agentId        String
  leadId         String?

  // Contact Info
  phoneNumber String
  contactName String?

  // Schedule
  scheduledAt     DateTime
  timezone        String   @default("Asia/Kolkata")
  reminderMinutes Int      @default(15)

  // Type
  callType ScheduledCallType @default(SCHEDULED)
  priority Int               @default(5)
  notes    String?

  // Status
  status        ScheduledCallStatus @default(PENDING)
  attemptCount  Int                 @default(0)
  lastAttemptAt DateTime?
  completedAt   DateTime?
  resultCallId  String? // Link to OutboundCall when completed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        VoiceAgent   @relation(fields: [agentId], references: [id])

  @@index([organizationId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("scheduled_calls")
}

enum ScheduledCallType {
  SCHEDULED // Admin scheduled
  CALLBACK // Customer requested callback
  FOLLOWUP // AI recommended follow-up
  REMINDER // Appointment reminder
}

enum ScheduledCallStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
  RESCHEDULED
}

// Do Not Call List
model DoNotCallList {
  id             String    @id @default(uuid())
  organizationId String
  phoneNumber    String
  reason         DNCReason @default(CUSTOMER_REQUEST)
  notes          String?
  addedBy        String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, phoneNumber])
  @@index([organizationId, phoneNumber])
  @@map("do_not_call_list")
}

enum DNCReason {
  CUSTOMER_REQUEST
  LEGAL_REQUIREMENT
  WRONG_NUMBER
  DECEASED
  COMPETITOR
  SPAM_COMPLAINT
  OTHER
}

// Auto Follow-up Rules
model FollowUpRule {
  id             String  @id @default(uuid())
  organizationId String
  agentId        String?
  name           String
  isActive       Boolean @default(true)

  // Trigger Conditions
  triggerOutcome   CallOutcome?
  triggerSentiment String?
  minCallDuration  Int? // seconds

  // Action
  actionType   FollowUpActionType
  delayMinutes Int                @default(60)

  // Message Template
  messageTemplate String  @db.Text
  useAI           Boolean @default(false) // AI personalize message

  // Limits
  maxPerDay  Int @default(100)
  todayCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("follow_up_rules")
}

enum FollowUpActionType {
  SMS
  EMAIL
  WHATSAPP
  SCHEDULE_CALL
  CREATE_TASK
}

// Follow-up Log
model FollowUpLog {
  id     String  @id @default(uuid())
  ruleId String
  callId String
  leadId String?

  actionType FollowUpActionType
  status     FollowUpLogStatus  @default(PENDING)
  message    String?            @db.Text

  scheduledAt DateTime
  executedAt  DateTime?
  error       String?

  createdAt DateTime @default(now())

  @@index([ruleId, status])
  @@map("follow_up_logs")
}

enum FollowUpLogStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// Call Transfer Configuration
model TransferConfig {
  id             String  @id @default(uuid())
  organizationId String
  agentId        String?
  name           String
  isActive       Boolean @default(true)

  // Transfer Triggers
  triggerKeywords  Json    @default("[]") // ["speak to human", "real person"]
  triggerSentiment String? // negative
  maxAITurns       Int? // Transfer after X exchanges

  // Transfer Target
  transferType    TransferType @default(PHONE)
  transferTo      String // Phone number or SIP URI
  transferMessage String? // Message before transfer

  // Fallback
  fallbackMessage  String?
  voicemailEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("transfer_configs")
}

enum TransferType {
  PHONE // Transfer to phone number
  SIP // Transfer to SIP endpoint
  QUEUE // Transfer to call queue
  VOICEMAIL // Send to voicemail
}

// Appointment Booking
model Appointment {
  id             String  @id @default(uuid())
  organizationId String
  leadId         String?
  callId         String? // OutboundCall that created this
  voiceSessionId String? // VoiceSession that created this

  // Appointment Details
  title           String
  description     String?
  appointmentType String?

  // Schedule
