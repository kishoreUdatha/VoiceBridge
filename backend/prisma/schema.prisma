// =====================================================
// FEATURE: ADVANCED REPORT BUILDER & SCHEDULING
// =====================================================

model ReportDefinition {
  id                String   @id @default(uuid())
  organizationId    String
  name              String
  description       String?
  type              ReportType
  category          String?  // Sales, Marketing, Operations, etc.

  // Report Configuration
  dataSource        String   // leads, calls, campaigns, etc.
  columns           Json     // Array of column definitions
  filters           Json?    // Filter conditions
  groupBy           Json?    // Grouping configuration
  sortBy            Json?    // Sorting configuration
  aggregations      Json?    // Sum, avg, count, etc.
  chartConfig       Json?    // Visualization settings

  // Access Control
  isPublic          Boolean  @default(false)
  sharedWith        Json?    // Array of user/role IDs
  createdById       String

  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  schedules         ReportSchedule[]
  executions        ReportExecution[]

  @@index([organizationId, type])
  @@index([organizationId, createdById])
  @@map("report_definitions")
}

model ReportSchedule {
  id                String   @id @default(uuid())
  reportDefinitionId String
  organizationId    String

  // Schedule Configuration
  name              String
  frequency         ScheduleFrequency  // DAILY, WEEKLY, MONTHLY
  dayOfWeek         Int?     // 0-6 for weekly
  dayOfMonth        Int?     // 1-31 for monthly
  timeOfDay         String   // HH:mm format
  timezone          String   @default("Asia/Kolkata")

  // Delivery Configuration
  deliveryMethod    DeliveryMethod     // EMAIL, WEBHOOK, STORAGE
  recipients        Json     // Array of email addresses or webhook URLs
  format            ReportFormat       // PDF, EXCEL, CSV

  // Status
  isActive          Boolean  @default(true)
  lastRunAt         DateTime?
  nextRunAt         DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reportDefinition  ReportDefinition @relation(fields: [reportDefinitionId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@index([nextRunAt])
  @@map("report_schedules")
}

model ReportExecution {
  id                String   @id @default(uuid())
  reportDefinitionId String
  scheduleId        String?
  organizationId    String

  // Execution Details
  status            ExecutionStatus  // PENDING, RUNNING, COMPLETED, FAILED
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Int?     // Milliseconds

  // Results
  rowCount          Int?
  fileUrl           String?  // S3/storage URL
  fileSize          Int?     // Bytes
  format            ReportFormat?

  // Error Handling
  errorMessage      String?
  retryCount        Int      @default(0)

  // Triggered By
  triggeredBy       String?  // User ID or 'system' for scheduled

  createdAt         DateTime @default(now())

  reportDefinition  ReportDefinition @relation(fields: [reportDefinitionId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([reportDefinitionId, createdAt])
  @@map("report_executions")
}

enum ReportType {
  TABLE
  CHART
  DASHBOARD
  SUMMARY
  DETAILED
}

enum ScheduleFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum DeliveryMethod {
  EMAIL
  WEBHOOK
  STORAGE
  SLACK
  TEAMS
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
  JSON
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// =====================================================
