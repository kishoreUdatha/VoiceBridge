  organizationId String @unique

  // Branding
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String? @default("#3B82F6")
  secondaryColor String? @default("#1F2937")
  accentColor    String? @default("#10B981")

  // Custom Domain
