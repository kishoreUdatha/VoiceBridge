  @@index([organizationId, visitorId])
  @@index([organizationId, source])
  @@index([organizationId, campaign])
  @@map("visitor_tracking")
}

// ==================== RAW IMPORT RECORDS ====================

enum BulkImportStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum RawImportRecordStatus {
  PENDING // Just uploaded
  ASSIGNED // Assigned to telecaller/AI
  CALLING // AI/telecaller calling
  INTERESTED // Contact interested
  NOT_INTERESTED // Not interested
  NO_ANSWER // Could not reach
  CALLBACK_REQUESTED
  CONVERTED // Converted to lead
  REJECTED // Admin rejected
}

// Bulk Import batch tracking
model BulkImport {
  id             String @id @default(uuid())
  organizationId String
  uploadedById   String

  // File info
  fileName String
  fileSize Int     @default(0)
  mimeType String?

  // Stats
  totalRows      Int @default(0)
  validRows      Int @default(0)
  invalidRows    Int @default(0)
  duplicateRows  Int @default(0)
  convertedCount Int @default(0)

  // Status
  status       BulkImportStatus @default(PROCESSING)
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User              @relation("BulkImportUploader", fields: [uploadedById], references: [id])
  records      RawImportRecord[]

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@map("bulk_imports")
}

// Raw imported records - not yet leads
model RawImportRecord {
  id             String @id @default(uuid())
  bulkImportId   String
  organizationId String

  // Contact info
  firstName      String
  lastName       String?
  email          String?
  phone          String
  alternatePhone String?
  customFields   Json?   @default("{}")

  // Assignment
  assignedToId    String? // Telecaller user
  assignedAgentId String? // AI Voice agent
  assignedById    String? // Who assigned
  assignedAt      DateTime?

  // Status tracking
  status RawImportRecordStatus @default(PENDING)

  // Call tracking
  lastCallAt     DateTime?
  callAttempts   Int       @default(0)
  outboundCallId String? // Reference to outbound call if AI called

  // Call outcome data
  interestLevel String? // high, medium, low
  notes         String? @db.Text
  callSummary   String? @db.Text
  callSentiment String? // positive, neutral, negative

  // Conversion tracking
  convertedLeadId String? // Reference to lead if converted
  convertedAt     DateTime?
  convertedById   String? // Who converted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bulkImport    BulkImport   @relation(fields: [bulkImportId], references: [id], onDelete: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo    User?        @relation("RawImportAssignedTo", fields: [assignedToId], references: [id])
  assignedAgent VoiceAgent?  @relation("RawImportAIAgent", fields: [assignedAgentId], references: [id])
  assignedBy    User?        @relation("RawImportAssignedBy", fields: [assignedById], references: [id])
  convertedBy   User?        @relation("RawImportConvertedBy", fields: [convertedById], references: [id])
  convertedLead Lead?        @relation("RawImportConvertedLead", fields: [convertedLeadId], references: [id])

  @@index([organizationId, status])
  @@index([bulkImportId])
  @@index([assignedToId])
  @@index([assignedAgentId])
  @@index([phone])
  @@index([email])
  @@map("raw_import_records")
}

// ==================== TELECALLER CALLS (Manual Calling with Recording) ====================

model TelecallerCall {
  id             String  @id @default(uuid())
  organizationId String
  telecallerId   String
  leadId         String?

  // Contact Info
  phoneNumber String
  contactName String?

  // Call Status
  status  TelecallerCallStatus   @default(INITIATED)
  outcome TelecallerCallOutcome?

  // Timing
  startedAt DateTime?
  endedAt   DateTime?
  duration  Int? // seconds

  // Recording & Transcript
  recordingUrl String?
  transcript   String? @db.Text
  sentiment    String? // positive, neutral, negative

  // Analysis
  qualification Json?   @default("{}")
  summary       String? @db.Text
  aiAnalyzed    Boolean @default(false) // Whether AI analysis has been completed

  // Notes
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  telecaller User  @relation("TelecallerCalls", fields: [telecallerId], references: [id])
  lead       Lead? @relation("LeadTelecallerCalls", fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId, telecallerId])
  @@index([telecallerId, createdAt])
  @@index([leadId])
  @@map("telecaller_calls")
}

enum TelecallerCallStatus {
  INITIATED // Call started
  IN_PROGRESS // Currently on call
  COMPLETED // Call finished
  MISSED // No answer
  FAILED // Call failed
}

enum TelecallerCallOutcome {
  INTERESTED // Lead interested
  NOT_INTERESTED // Lead not interested
  CALLBACK // Requested callback
  CONVERTED // Lead converted
  NO_ANSWER // Couldn't reach
  WRONG_NUMBER // Invalid number
  BUSY // Line busy
}

// ==================== INBOUND CALL FEATURES ====================

// IVR Flow Configuration
model IvrFlow {
  id             String @id @default(uuid())
  organizationId String

  // Flow Details
  name        String
  description String?
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false)

  // Flow Structure (nodes and edges stored as JSON)
  nodes Json @default("[]") // Array of IvrNode-like objects with positions
  edges Json @default("[]") // Array of connections between nodes

  // Settings
  welcomeMessage      String? @db.Text
  timeoutSeconds      Int     @default(10)
  maxRetries          Int     @default(3)
  invalidInputMessage String?

  // Statistics
  totalCalls     Int @default(0)
  completedCalls Int @default(0)
  avgDuration    Int @default(0)

  // Version control
  version     Int       @default(1)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumbers IvrPhoneNumber[]
  callLogs     InboundCallLog[]

  @@index([organizationId, isActive])
  @@map("ivr_flows")
}

// IVR Node (Individual node in the flow)
model IvrNode {
  id             String @id @default(uuid())
  organizationId String

  // Node Details
  name String
  type IvrNodeType

  // Configuration based on type
  config Json @default("{}")
  // MENU: { options: [{digit: "1", label: "Sales", nextNodeId: "xxx"}] }
  // PLAY: { audioUrl: "...", text: "..." }
  // GATHER: { numDigits: 4, timeout: 5 }
  // ROUTE: { routeType: "skill", skillId: "xxx" }
  // QUEUE: { queueId: "xxx" }
  // TRANSFER: { transferType: "warm|cold", number: "..." }
  // VOICEMAIL: { mailboxId: "xxx" }

  // Text-to-speech or audio
  audioUrl String?
  ttsText  String? @db.Text
  ttsVoice String  @default("alloy")

  // Timeout and error handling
  timeoutSeconds         Int     @default(10)
  timeoutNextNodeId      String?
  invalidInputNextNodeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@map("ivr_nodes")
}

enum IvrNodeType {
  MENU // IVR menu with options
  PLAY // Play audio/TTS
  GATHER // Collect DTMF input
  ROUTE // Route based on skills/rules
  QUEUE // Add to queue
  TRANSFER // Transfer call
  VOICEMAIL // Send to voicemail
  WEBHOOK // Call external webhook
  CONDITION // Conditional branching
  SET_VARIABLE // Set call variable
  END // End call
}

// Map phone numbers to IVR flows
model IvrPhoneNumber {
  id             String @id @default(uuid())
  organizationId String

  phoneNumber   String // E.164 format
  phoneNumberId String? // Reference to PhoneNumber model if using managed numbers
  flowId        String

  isActive Boolean @default(true)

  // Override settings
  welcomeMessage   String? @db.Text
  afterHoursFlowId String? // Different flow for after hours

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flow         IvrFlow      @relation(fields: [flowId], references: [id])

  @@unique([organizationId, phoneNumber])
  @@index([phoneNumber])
  @@map("ivr_phone_numbers")
}

// Call Queue Configuration
model CallQueue {
  id             String @id @default(uuid())
  organizationId String

  // Queue Details
  name        String
  description String?
  isActive    Boolean @default(true)

  // Routing Strategy
  routingStrategy QueueRoutingStrategy @default(ROUND_ROBIN)

  // Queue Settings
  maxWaitTime  Int @default(300) // Max wait in seconds
  maxQueueSize Int @default(50) // Max callers in queue

  // Hold Experience
  holdMusicUrl        String?
  holdMessage         String? @db.Text
  holdMessageInterval Int     @default(60) // Seconds between position announcements
  announcePosition    Boolean @default(true)
  announceWaitTime    Boolean @default(true)

  // Overflow Handling
  overflowAction      OverflowAction @default(VOICEMAIL)
  overflowDestination String? // Phone number, voicemail box, or queue ID

  // Statistics
  totalCalls     Int   @default(0)
  answeredCalls  Int   @default(0)
  abandonedCalls Int   @default(0)
  avgWaitTime    Int   @default(0)
  avgHandleTime  Int   @default(0)
  serviceLevel   Float @default(0) // % answered within SLA

  // SLA Settings
  slaSeconds Int @default(30) // Target answer time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      QueueMember[]
  entries      QueueEntry[]
  schedules    QueueSchedule[]
  inboundCalls InboundCallLog[]

  @@index([organizationId, isActive])
  @@map("call_queues")
}

enum QueueRoutingStrategy {
  ROUND_ROBIN // Distribute evenly
  LONGEST_IDLE // Route to longest idle agent
  LEAST_CALLS // Route to agent with fewest calls
  SKILLS_BASED // Route based on skills matching
  PRIORITY_BASED // Route based on agent priority
  RANDOM // Random distribution
}

enum OverflowAction {
  VOICEMAIL // Send to voicemail
  TRANSFER // Transfer to number
  QUEUE // Move to another queue
  CALLBACK // Offer callback
  DISCONNECT // Disconnect with message
}

// Queue Member (Agent in queue)
model QueueMember {
  id      String @id @default(uuid())
  queueId String
  userId  String

  // Member Settings
  priority           Int @default(1) // 1 = highest priority
  maxConcurrentCalls Int @default(1)
  wrapUpTime         Int @default(30) // Seconds after call

  // Skills for skills-based routing
  skills Json @default("[]") // Array of skill IDs

  // Status
  status          AgentStatus @default(OFFLINE)
  statusChangedAt DateTime?
  lastCallAt      DateTime?

  // Statistics
  callsToday    Int @default(0)
  callsHandled  Int @default(0)
  avgHandleTime Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queue CallQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
  @@index([queueId, status])
  @@index([userId, status])
  @@map("queue_members")
}

enum AgentStatus {
  AVAILABLE // Ready to take calls
  ON_CALL // Currently on a call
  WRAP_UP // Post-call wrap up
  BUSY // Busy with other work
  AWAY // Away/break
  OFFLINE // Not logged in
}

// Queue Entry (Caller waiting in queue)
model QueueEntry {
  id            String  @id @default(uuid())
  queueId       String
  inboundCallId String? // Reference to InboundCallLog

  // Caller Info
  callerNumber String
  callerId     String? // Caller ID name if available
  leadId       String?

  // Queue Position
  position Int
  priority Int @default(5) // 1 = highest

  // Status
  status QueueEntryStatus @default(WAITING)

  // Timing
  enteredAt   DateTime  @default(now())
  answeredAt  DateTime?
  abandonedAt DateTime?

  // Assignment
  assignedAgentId String?
  assignedAt      DateTime?

  // IVR data collected
  ivrData Json @default("{}")

  // Callback option
  callbackRequested Boolean @default(false)
  callbackNumber    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queue CallQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId, status])
  @@index([status, enteredAt])
  @@map("queue_entries")
}

enum QueueEntryStatus {
  WAITING // In queue waiting
  RINGING // Ringing an agent
  CONNECTED // Connected to agent
  ABANDONED // Caller hung up
  CALLBACK // Callback requested
  OVERFLOW // Moved to overflow
}

// Queue Schedule (Business hours)
model QueueSchedule {
  id      String @id @default(uuid())
  queueId String

  // Day of week (0 = Sunday, 6 = Saturday)
  dayOfWeek Int

  // Time range (24-hour format)
  startTime String // "09:00"
  endTime   String // "18:00"

  // Timezone
  timezone String @default("Asia/Kolkata")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queue CallQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@unique([queueId, dayOfWeek])
  @@map("queue_schedules")
}

// Voicemail Box and Messages
model Voicemail {
  id             String @id @default(uuid())
  organizationId String

  // Voicemail Details
  callerNumber String
  callerName   String?
  leadId       String?

  // Source
  queueId     String? // If from queue overflow
  ivrFlowId   String? // If from IVR
  agentUserId String? // If direct to agent

  // Recording
  recordingUrl String
  duration     Int // Seconds

  // Transcription
  transcript          String?   @db.Text
  transcriptionStatus String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  transcribedAt       DateTime?

  // Status
  status VoicemailStatus @default(NEW)

  // Handling
  listenedAt    DateTime?
  listenedById  String?
  respondedAt   DateTime?
  respondedById String?

  // Notes
  notes String? @db.Text

  // Callback created
  callbackId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([queueId])
  @@index([agentUserId, status])
  @@map("voicemails")
}

enum VoicemailStatus {
  NEW // Not listened
  LISTENED // Listened but not responded
  RESPONDED // Response sent/called back
  ARCHIVED // Archived
  DELETED // Soft deleted
}

// Callback Requests
model CallbackRequest {
  id             String @id @default(uuid())
  organizationId String

  // Contact Info
  phoneNumber String
  contactName String?
  leadId      String?

  // Source
  source        CallbackSource
  queueId       String?
  voicemailId   String?
  ivrFlowId     String?
  inboundCallId String?

  // Scheduling
  requestedAt        DateTime  @default(now())
  scheduledAt        DateTime?
  preferredTimeStart DateTime?
  preferredTimeEnd   DateTime?
  timezone           String    @default("Asia/Kolkata")

  // Assignment
  assignedAgentId String?

  // Status
  status CallbackStatus @default(PENDING)

  // Attempts
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  nextAttemptAt DateTime?
  maxAttempts   Int       @default(3)

  // Outcome
  outcomeCallId String? // Reference to the callback call made
  completedAt   DateTime?
  completedById String?
  outcome       String? // CONNECTED, NO_ANSWER, BUSY, CANCELLED
  notes         String?   @db.Text

  // Priority
  priority Int @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([scheduledAt, status])
  @@index([assignedAgentId, status])
  @@map("callback_requests")
}

enum CallbackSource {
  QUEUE_OVERFLOW // From queue overflow
  VOICEMAIL // From voicemail
  IVR // From IVR option
  MANUAL // Manually created
  ABANDONED // From abandoned call
  WEB_FORM // From website form
}

enum CallbackStatus {
  PENDING // Waiting to be called
  SCHEDULED // Scheduled for specific time
  IN_PROGRESS // Currently being called
  COMPLETED // Successfully called back
  FAILED // All attempts failed
  CANCELLED // Cancelled by user/agent
  EXPIRED // Expired without callback
}

// Detailed Inbound Call Log
model InboundCallLog {
  id             String @id @default(uuid())
  organizationId String

  // Call Identifiers
  providerCallSid String? @unique
  provider        String  @default("EXOTEL") // EXOTEL, TWILIO, PLIVO

  // Caller Info
  callerNumber String
  callerName   String?
  calledNumber String // DID/inbound number called
  leadId       String?

  // Call Path
  ivrFlowId        String?
  queueId          String?
  answeredByUserId String?

  // IVR Data
  ivrPath   Json @default("[]") // Path through IVR nodes
  ivrInputs Json @default("{}") // DTMF inputs collected

  // Queue Data
  queueEntryId  String?
  queueWaitTime Int? // Seconds waited in queue

  // Call Status
  status InboundCallStatus @default(INITIATED)

  // Timing
  startedAt  DateTime?
  queuedAt   DateTime?
  answeredAt DateTime?
  endedAt    DateTime?
  duration   Int? // Total duration
  talkTime   Int? // Actual talk time with agent

  // Recording
  recordingUrl String?
  recordingSid String?

  // Transcription
  transcript Json?   @default("[]")
  summary    String? @db.Text
  sentiment  String?

  // Transfer Info
  wasTransferred Boolean   @default(false)
  transferType   String? // warm, cold, queue
  transferredTo  String?
  transferredAt  DateTime?

  // Outcome
  outcome         InboundCallOutcome?
  outcomeNotes    String?
  dispositionCode String?

  // After-call work
  wrapUpTime Int? // Seconds in wrap-up
  tags       Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ivrFlow      IvrFlow?     @relation(fields: [ivrFlowId], references: [id])
  queue        CallQueue?   @relation(fields: [queueId], references: [id])

  @@index([organizationId, createdAt])
  @@index([callerNumber])
  @@index([calledNumber])
  @@index([leadId])
  @@index([queueId, status])
  @@index([answeredByUserId, createdAt])
  @@map("inbound_call_logs")
}

enum InboundCallStatus {
  INITIATED // Call started
  IN_IVR // In IVR flow
  IN_QUEUE // Waiting in queue
  RINGING_AGENT // Ringing an agent
  IN_PROGRESS // Connected to agent
  ON_HOLD // On hold during call
  TRANSFERRING // Being transferred
  COMPLETED // Call ended normally
  ABANDONED // Caller hung up
  VOICEMAIL // Went to voicemail
  FAILED // Technical failure
}

enum InboundCallOutcome {
  RESOLVED // Issue resolved
  FOLLOWUP // Needs follow-up
  TRANSFERRED // Transferred elsewhere
  VOICEMAIL // Left voicemail
  ABANDONED // Caller abandoned
  CALLBACK // Callback scheduled
  NOT_INTERESTED // Not interested
  WRONG_NUMBER // Wrong number
}

