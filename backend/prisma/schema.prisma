// Track ad clicks that may or may not result in form submissions
model AdInteraction {
  id             String            @id @default(uuid())
  organizationId String
  type           AdInteractionType
  visitorId      String // From tracking pixel
  sessionId      String? // Session tracking for deduplication

  // Click IDs from ad platforms
  gclid  String? // Google Click ID
  fbclid String? // Facebook Click ID
  ttclid String? // TikTok Click ID
  twclid String? // Twitter Click ID
  liclid String? // LinkedIn Click ID

  // UTM Parameters
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  // Page info
  landingPage String? @db.Text
  referrer    String? @db.Text

  // Device info
  userAgent  String? @db.Text
  ipAddress  String?
  deviceType String?
  browser    String?

  // Engagement tracking (for impressions and engagement events)
