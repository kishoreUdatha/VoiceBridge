  organizationId String
  phoneNumber    String
  reason         DNCReason @default(CUSTOMER_REQUEST)
  notes          String?
  addedBy        String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

