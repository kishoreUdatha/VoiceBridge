  state              String?
  country            String?
  postalCode         String?
  highestEducation   String?
  currentInstitution String?
  graduationYear     Int?
  preferredCourse    String?
  preferredCountry   String?
  englishProficiency String?
  workExperience     Int?      @default(0)
