  subject  String
  body     String  @db.Text // HTML body with {{placeholders}}
  fromName String? // Override sender name

  // Conditions (optional)
  skipIfOpened  Boolean @default(false) // Skip if previous email opened
  skipIfClicked Boolean @default(false) // Skip if previous email clicked
  skipIfReplied Boolean @default(false) // Skip if lead replied

  // Stats
  sentCount    Int @default(0)
  openedCount  Int @default(0)
  clickedCount Int @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepNumber])
  @@index([sequenceId])
  @@map("email_sequence_steps")
}

model LeadSequenceEnrollment {
