// ==================== EMAIL DRIP CAMPAIGNS ====================

model EmailSequence {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean @default(true)

  // Trigger Conditions
  triggerType    SequenceTriggerType
  triggerStageId String? // Trigger when lead enters this stage
  triggerSource  String? // Trigger for leads from this source
  triggerTags    Json                @default("[]") // Trigger for leads with these tags

  // Settings
  sendOnWeekends Boolean @default(false)
  sendTimeStart  String  @default("09:00") // Start sending after this time
  sendTimeEnd    String  @default("18:00") // Stop sending after this time
  timezone       String  @default("Asia/Kolkata")

  // Stats
  totalEnrolled     Int @default(0)
  totalCompleted    Int @default(0)
  totalUnsubscribed Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        EmailSequenceStep[]
  enrollments  LeadSequenceEnrollment[]

  @@index([organizationId])
  @@map("email_sequences")
}

enum SequenceTriggerType {
  MANUAL // Manually enroll leads
  STAGE_CHANGE // When lead enters a stage
  LEAD_CREATED // When lead is created
  TAG_ADDED // When tag is added to lead
  VOICE_SESSION // After voice AI session
}

model EmailSequenceStep {
  id         String @id @default(uuid())
  sequenceId String
  stepNumber Int // Order in sequence (1, 2, 3...)

  // Timing
  delayDays  Int @default(0) // Days after previous step
  delayHours Int @default(0) // Hours after previous step

  // Email Content
  subject  String
  body     String  @db.Text // HTML body with {{placeholders}}
  fromName String? // Override sender name

  // Conditions (optional)
  skipIfOpened  Boolean @default(false) // Skip if previous email opened
  skipIfClicked Boolean @default(false) // Skip if previous email clicked
  skipIfReplied Boolean @default(false) // Skip if lead replied

  // Stats
  sentCount    Int @default(0)
  openedCount  Int @default(0)
  clickedCount Int @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepNumber])
  @@index([sequenceId])
  @@map("email_sequence_steps")
}

model LeadSequenceEnrollment {
  id         String @id @default(uuid())
  leadId     String
  sequenceId String

  // Progress
  currentStep Int              @default(1)
  status      EnrollmentStatus @default(ACTIVE)

  // Tracking
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?
  pausedAt       DateTime?
  unsubscribedAt DateTime?

  // Next scheduled email
  nextEmailAt DateTime?

  // Engagement tracking
  emailsSent    Int @default(0)
  emailsOpened  Int @default(0)
  emailsClicked Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead     Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([leadId, sequenceId])
  @@index([sequenceId, status])
  @@index([nextEmailAt, status])
  @@map("lead_sequence_enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  UNSUBSCRIBED
  BOUNCED
}

