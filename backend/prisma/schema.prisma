// ==================== RAG KNOWLEDGE CHUNKS ====================

model KnowledgeChunk {
  id             String                       @id @default(uuid())
  voiceAgentId   String                       @map("voice_agent_id")
  sourceType     String                       @map("source_type") // "knowledge_base", "faq", "document"
  sourceId       String?                      @map("source_id")
  sourceName     String?                      @map("source_name")
  content        String                       @db.Text
  chunkIndex     Int                          @map("chunk_index")
  totalChunks    Int                          @map("total_chunks")
  embedding      Unsupported("vector(1536)")?
  embeddingModel String                       @default("text-embedding-3-small") @map("embedding_model")
  metadata       Json                         @default("{}")
  keywords       String[]
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")

  voiceAgent VoiceAgent @relation(fields: [voiceAgentId], references: [id], onDelete: Cascade)

  @@index([voiceAgentId])
  @@index([sourceType])
  @@map("knowledge_chunks")
}

// ==================== MESSAGING ====================

// Message Log for tracking all sent messages (SMS, WhatsApp, Email) during telecaller calls
model MessageLog {
  id             String  @id @default(uuid())
  organizationId String
  leadId         String?
  userId         String?

  // Message Details
  type       TemplateType // SMS, WHATSAPP, EMAIL
  to         String // Phone number or email
  subject    String? // For emails
  content    String       @db.Text
  templateId String?

  // Status
  status     MessageStatus @default(PENDING)
  externalId String? // Provider message ID
  error      String?

