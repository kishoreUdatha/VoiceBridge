model WorkflowDefinition {
  id                String   @id @default(uuid())
  organizationId    String
  name              String
  description       String?
  category          WorkflowCategory

  // Trigger Configuration
  triggerType       WorkflowTriggerType
  triggerConfig     Json?    // Trigger-specific configuration

  // Flow Configuration
  nodes             Json     // Array of workflow nodes
  edges             Json     // Array of connections between nodes
  variables         Json?    // Workflow variables/context

  // Settings
  isActive          Boolean  @default(true)
  version           Int      @default(1)
  maxExecutions     Int?     // Rate limiting
  timeout           Int?     // Max execution time in seconds

  // Metadata
  createdById       String
  publishedAt       DateTime?
  publishedById     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  executions        WorkflowExecution[]

  @@index([organizationId, isActive])
  @@index([organizationId, triggerType])
  @@map("workflow_definitions")
}

model WorkflowExecution {
  id                String   @id @default(uuid())
  workflowId        String
  organizationId    String

  // Trigger Context
  triggeredBy       String?  // User ID, system, or trigger source
  triggerData       Json?    // Data that triggered the workflow
  entityType        String?  // lead, call, campaign, etc.
  entityId          String?  // ID of the entity

  // Execution State
  status            WorkflowExecutionStatus
  currentNodeId     String?
  context           Json?    // Current execution context/variables

  // Timing
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  duration          Int?     // Milliseconds

  // Results
  result            Json?
  errorMessage      String?
  errorNodeId       String?

  // Retries
  retryCount        Int      @default(0)
  maxRetries        Int      @default(3)

  createdAt         DateTime @default(now())

  workflow          WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps             WorkflowExecutionStep[]

  @@index([organizationId, status])
  @@index([workflowId, startedAt])
  @@index([entityType, entityId])
  @@map("workflow_executions")
}

model WorkflowExecutionStep {
  id                String   @id @default(uuid())
  executionId       String
  nodeId            String
  nodeType          String
  nodeName          String?

  // Step Status
  status            WorkflowStepStatus
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Int?

  // Input/Output
  input             Json?
  output            Json?

  // Error Handling
  errorMessage      String?
  retryCount        Int      @default(0)

  createdAt         DateTime @default(now())

  execution         WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, nodeId])
  @@map("workflow_execution_steps")
}

enum WorkflowCategory {
