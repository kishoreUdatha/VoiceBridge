  slug      String   @unique
  channel   String?
  source    String?
  medium    String?
  isEnabled Boolean  @default(true)
  qrCode    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)

