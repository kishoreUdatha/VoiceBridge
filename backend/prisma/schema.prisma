  @@index([organizationId, sessionId])
  @@index([organizationId, type])
  @@index([gclid])
  @@index([fbclid])
  @@index([ttclid])
  @@index([twclid])
  @@index([convertedToLeadId])
  @@map("ad_interactions")
}

