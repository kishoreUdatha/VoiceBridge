}

// Audit Log for Admin Tracking
model AuditLog {
  id String @id @default(uuid())

  // Actor
  actorType  String // user, superadmin, system
  actorId    String?
  actorEmail String?

  // Target
  organizationId String?
  targetType     String? // user, lead, campaign, etc.
  targetId       String?

  // Action
  action      String // created, updated, deleted, login, etc.
  description String?
  changes     Json? // before/after values

  // Context
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ==================== B2B PARTNER & MARKETPLACE ====================

// Partner Types
enum PartnerType {
  RESELLER // Sells to their own customers
  AFFILIATE // Earns commission on referrals
  WHITE_LABEL // Full white-label solution
  AGENCY // Manages multiple clients
}

enum PartnerTier {
  BRONZE // 15% commission, max 10 customers
  SILVER // 20% commission, max 50 customers
  GOLD // 25% commission, max 200 customers
  PLATINUM // 30% commission, unlimited customers
}

enum PartnerStatus {
  PENDING // Application submitted
  APPROVED // Active partner
  SUSPENDED // Temporarily disabled
  REJECTED // Application rejected
  CHURNED // No longer active
}

// Partner/Reseller Organization
model Partner {
  id             String @id @default(uuid())
  organizationId String @unique

  // Partner Details
  partnerType PartnerType   @default(RESELLER)
  tier        PartnerTier   @default(BRONZE)
  status      PartnerStatus @default(PENDING)

  // Company Info
  companyName    String
  companyWebsite String?
  contactPerson  String
  contactEmail   String
  contactPhone   String?

  // Business Details
  businessType      String? // SaaS, Agency, Consultancy, etc.
  targetIndustry    String? // Education, Healthcare, etc.
  expectedCustomers Int? // Expected monthly customers

  // Commission Settings
  commissionRate   Float   @default(15) // Percentage
  customCommission Boolean @default(false)
  minPayout        Float   @default(1000) // Minimum payout threshold
  payoutSchedule   String  @default("MONTHLY") // WEEKLY, MONTHLY

  // Limits
  maxCustomers         Int @default(10)
  maxAgentsPerCustomer Int @default(5)

  // Branding
  brandingEnabled Boolean @default(false)
  customDomain    String? @unique

  // Stats
  totalCustomers  Int   @default(0)
  activeCustomers Int   @default(0)
  totalRevenue    Float @default(0)
  totalCommission Float @default(0)
  pendingPayout   Float @default(0)

  // Approval
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?

  // Agreement
  agreementSigned   Boolean   @default(false)
  agreementSignedAt DateTime?
  agreementVersion  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization  Organization        @relation("PartnerOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  customers     PartnerCustomer[]
  commissions   PartnerCommission[]
  payouts       PartnerPayout[]
  agentLicenses AgentLicense[]

  @@index([status])
  @@index([tier])
  @@map("partners")
}

// Partner's Customers (Organizations under a partner)
model PartnerCustomer {
  id             String @id @default(uuid())
  partnerId      String
  organizationId String @unique

  // Customer Status
  status String @default("ACTIVE") // ACTIVE, SUSPENDED, CHURNED

  // Subscription Info
  planId       String?
  monthlyValue Float   @default(0)

  // Dates
  onboardedAt DateTime  @default(now())
  churnedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner      Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  organization Organization @relation("CustomerOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([partnerId, status])
  @@map("partner_customers")
}

// Commission Tracking
model PartnerCommission {
  id        String @id @default(uuid())
  partnerId String

  // Source
  customerId     String? // PartnerCustomer organizationId
  subscriptionId String?
  invoiceId      String?

  // Transaction
  transactionType String // SUBSCRIPTION, ADDON, AGENT_SALE, REFERRAL
  description     String?

  // Amounts
  grossAmount      Float // Original transaction amount
  commissionRate   Float // Rate at time of transaction
  commissionAmount Float // Calculated commission

  // Status
  status CommissionStatus @default(PENDING)

  // Payout Reference
  payoutId String?

  // Dates
  transactionDate DateTime  @default(now())
  approvedAt      DateTime?
  paidAt          DateTime?

  createdAt DateTime @default(now())

  partner Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  payout  PartnerPayout? @relation(fields: [payoutId], references: [id])

  @@index([partnerId, status])
  @@index([transactionDate])
  @@map("partner_commissions")
}

enum CommissionStatus {
  PENDING // Waiting for payment confirmation
  APPROVED // Approved for payout
  PROCESSING // Payout in progress
  PAID // Paid to partner
  CANCELLED // Transaction reversed
  HELD // On hold for review
}

// Partner Payouts
model PartnerPayout {
  id        String @id @default(uuid())
  partnerId String

  // Payout Details
  payoutNumber String @unique
  amount       Float
  currency     String @default("INR")

  // Period
  periodStart DateTime
  periodEnd   DateTime

  // Status
  status PayoutStatus @default(PENDING)

  // Bank Details (at time of payout)
  bankName      String?
  accountNumber String?
  ifscCode      String?
  accountHolder String?

  // Payment Reference
  paymentMethod    String? // BANK_TRANSFER, UPI, PAYPAL
  paymentReference String?
  transactionId    String?

  // Processing
  processedAt   DateTime?
  processedBy   String?
  failureReason String?

  // Invoice
  invoiceUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner     Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  commissions PartnerCommission[]

  @@index([partnerId, status])
  @@map("partner_payouts")
}

enum PayoutStatus {
  PENDING // Awaiting processing
  PROCESSING // Being processed
  COMPLETED // Successfully paid
  FAILED // Payment failed
  CANCELLED // Cancelled
}

// ==================== AGENT MARKETPLACE ====================

// Agent Template (Marketplace Listing)
model AgentTemplate {
  id String @id @default(uuid())

  // Creator
  creatorId   String // Organization that created this template
  creatorType String @default("PLATFORM") // PLATFORM, PARTNER, ORGANIZATION

  // Basic Info
  name             String
  slug             String  @unique
  description      String  @db.Text
  shortDescription String?

  // Industry & Category
  industry VoiceAgentIndustry
  category String? // Sales, Support, Appointment, etc.
  tags     Json               @default("[]")

  // Agent Configuration (Template)
  systemPrompt    String  @db.Text
  voiceId         String  @default("alloy")
  language        String  @default("en")
  temperature     Float   @default(0.7)
  greeting        String?
  fallbackMessage String?

  // Qualification Questions Template
  questions Json @default("[]")

  // Knowledge Base Template
  knowledgeBase String? @db.Text
  faqs          Json    @default("[]")

  // Customization Options
  customizableFields Json @default("[]") // Which fields can be customized
  requiredSetup      Json @default("[]") // Required setup steps

  // Pricing
  priceType    AgentPriceType @default(FREE)
  oneTimePrice Float? // One-time purchase
  monthlyPrice Float? // Monthly subscription
  yearlyPrice  Float? // Yearly subscription
  currency     String         @default("INR")

  // Revenue Share (for marketplace)
  revenueShare Float @default(70) // Creator gets this percentage

  // Media
  iconUrl      String?
  bannerUrl    String?
  screenshots  Json    @default("[]")
  demoVideoUrl String?

  // Documentation
  documentation String? @db.Text
  setupGuide    String? @db.Text

  // Status
  status     AgentTemplateStatus @default(DRAFT)
  isPublic   Boolean             @default(false)
  isFeatured Boolean             @default(false)
  isVerified Boolean             @default(false) // Platform verified

  // Stats
  viewCount      Int   @default(0)
  installCount   Int   @default(0)
  activeInstalls Int   @default(0)
  totalRevenue   Float @default(0)

  // Ratings
  averageRating Float?
  ratingCount   Int    @default(0)

  // Version Control
  version   String @default("1.0.0")
  changelog Json   @default("[]")

  // Dates
  publishedAt   DateTime?
  lastUpdatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  licenses AgentLicense[]
  reviews  AgentReview[]

  @@index([industry, status])
  @@index([isPublic, isFeatured])
  @@index([creatorId])
  @@map("agent_templates")
}

enum AgentPriceType {
  FREE
  ONE_TIME
  MONTHLY
  YEARLY
  CUSTOM
}

enum AgentTemplateStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
}

// Agent License (Purchase/Subscription)
model AgentLicense {
  id String @id @default(uuid())

  // Parties
  templateId     String
  organizationId String // Buyer
  partnerId      String? // If purchased through partner

  // License Details
  licenseKey  String      @unique @default(uuid())
  licenseType LicenseType @default(STANDARD)

  // Pricing at Purchase
  priceType AgentPriceType
  pricePaid Float
  currency  String         @default("INR")

  // Subscription Period (if applicable)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // Usage Limits
  maxInstances     Int @default(1) // How many agents can be created
  currentInstances Int @default(0)

  // Status
  status LicenseStatus @default(ACTIVE)

  // Payment
  paymentId String?
  invoiceId String?

  // Dates
  purchasedAt DateTime  @default(now())
  expiresAt   DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template AgentTemplate @relation(fields: [templateId], references: [id])
  partner  Partner?      @relation(fields: [partnerId], references: [id])

  @@index([organizationId, status])
  @@index([templateId])
  @@map("agent_licenses")
}

enum LicenseType {
  STANDARD // Normal purchase
  ENTERPRISE // Volume license
  PARTNER // Partner special license
  TRIAL // Trial license
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

// Agent Reviews
model AgentReview {
  id             String @id @default(uuid())
  templateId     String
  organizationId String // Reviewer
  userId         String // User who wrote review

  // Review Content
  rating  Int // 1-5
  title   String?
  content String? @db.Text

  // Helpful Votes
  helpfulCount Int @default(0)

  // Status
  isVerified  Boolean @default(false) // Verified purchase
  isPublished Boolean @default(true)

  // Response from creator
  creatorResponse String?   @db.Text
  respondedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template AgentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, organizationId])
  @@index([templateId, rating])
  @@map("agent_reviews")
}

// Partner Bank Details
model PartnerBankDetails {
  id        String @id @default(uuid())
  partnerId String @unique

  // Bank Account
  accountHolderName String
  accountNumber     String
  bankName          String
  branchName        String?
  ifscCode          String
  accountType       String  @default("SAVINGS") // SAVINGS, CURRENT

  // UPI
  upiId String?

  // International (optional)
  swiftCode String?
  iban      String?

  // Verification
  isVerified Boolean   @default(false)
  verifiedAt DateTime?

  // Documents
  cancelledChequeUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partner_bank_details")
}

// Partner Activity Log
model PartnerActivityLog {
  id        String @id @default(uuid())
  partnerId String

  // Activity
  activityType String // CUSTOMER_ADDED, COMMISSION_EARNED, PAYOUT_RECEIVED, etc.
  description  String
  metadata     Json?

  // Reference
  referenceType String? // customer, commission, payout
  referenceId   String?

  createdAt DateTime @default(now())

  @@index([partnerId, createdAt])
  @@map("partner_activity_logs")
}

// ==================== PUBLIC API SYSTEM ====================

// API Keys for External Access
model ApiKey {
  id             String @id @default(uuid())
  organizationId String

  // Key Details
  name      String
  key       String @unique // The actual API key (hashed)
  keyPrefix String // First 8 chars for identification

  // Permissions
  permissions Json @default("[]") // ["agents:read", "agents:call", "sessions:read"]

  // Allowed Agents
  allowedAgents Json @default("[]") // Empty = all agents, or specific agent IDs

  // Rate Limiting
  rateLimit       Int @default(1000) // Requests per hour
  rateLimitWindow Int @default(3600) // Window in seconds

  // IP Restrictions
  allowedIPs Json @default("[]") // Empty = all IPs allowed

  // Usage Stats
  totalRequests Int       @default(0)
  lastUsedAt    DateTime?

  // Status
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  // Metadata
  description String?
  environment String  @default("production") // production, sandbox

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  usageLogs ApiUsageLog[]

  @@index([organizationId, isActive])
  @@index([key])
  @@index([keyPrefix])
  @@map("api_keys")
}

// API Usage Logging
model ApiUsageLog {
  id       String @id @default(uuid())
  apiKeyId String

  // Request Details
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int // milliseconds

  // Request Info
  ipAddress String?
  userAgent String?

  // Payload Info (for billing)
  agentId   String?
  sessionId String?
  action    String? // call, message, session_start, etc.

  // Cost Tracking
  tokensUsed   Int   @default(0)
  costIncurred Float @default(0)

  // Error Info
  errorMessage String?

  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@index([agentId, createdAt])
  @@map("api_usage_logs")
}

// API Webhooks (for notifying external systems)
model ApiWebhook {
  id             String @id @default(uuid())
  organizationId String

  // Webhook Details
  name   String
  url    String
  secret String // For signature verification

  // Events to subscribe
  events Json @default("[]") // ["call.started", "call.ended", "session.created"]

  // Status
  isActive Boolean @default(true)

  // Stats
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  lastTriggeredAt DateTime?
  lastError       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  deliveryLogs WebhookDeliveryLog[]

  @@index([organizationId, isActive])
  @@map("api_webhooks")
}

model WebhookDeliveryLog {
  id        String @id @default(uuid())
  webhookId String

  // Event details
  eventType String
  eventId   String // Unique ID for the event
  payload   Json

  // Delivery details
  attempt     Int @default(1)
  maxAttempts Int @default(5)

  // Response
  statusCode   Int?
  responseBody String?
  responseTime Int? // in milliseconds

  // Status
  status      WebhookDeliveryStatus @default(PENDING)
  error       String?
  nextRetryAt DateTime?

  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  // Relations
  webhook ApiWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
  @@index([status, nextRetryAt])
  @@map("webhook_delivery_logs")
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

// ==================== MESSAGE TEMPLATES ====================

model MessageTemplate {
  id             String @id @default(uuid())
  organizationId String

  // Template details
  name     String
  type     TemplateType
  category String? // e.g., "marketing", "transactional", "reminder"

  // Content
  subject     String? // For email templates
  content     String // Template body with {{variables}}
  htmlContent String? // HTML version for emails

  // WhatsApp specific
  whatsappTemplateId String? // External WhatsApp template ID
  whatsappStatus     WhatsAppTemplateStatus @default(PENDING)
  whatsappLanguage   String?                @default("en")

  // Variables/placeholders
  variables    Json @default("[]") // ["name", "phone", "date"]
  sampleValues Json @default("{}") // {"name": "John", "phone": "123"}

  // Media attachments (for WhatsApp/Email)
  headerType    String? // "text", "image", "video", "document"
  headerContent String? // URL or text
  footerContent String?
  buttons       Json    @default("[]") // CTA buttons for WhatsApp

  // Status & metadata
  isActive   Boolean   @default(true)
  isDefault  Boolean   @default(false)
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  // Audit
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId, type, isActive])
  @@index([organizationId, category])
  @@map("message_templates")
}

enum TemplateType {
  SMS
  EMAIL
  WHATSAPP
}

enum WhatsAppTemplateStatus {
  PENDING
  APPROVED
  REJECTED
  PAUSED
}

// ==================== SCHEDULED MESSAGES ====================

model ScheduledMessage {
  id             String @id @default(uuid())
  organizationId String

  // Message details
  type        ScheduledMessageType
  recipients  Json // Array of phone numbers or emails
  subject     String? // For emails
  content     String
  htmlContent String? // For emails

  // Template reference (optional)
  templateId String?
  variables  Json    @default("{}") // Variables for template

  // Scheduling
  scheduledAt DateTime
  timezone    String   @default("UTC")

  // Recurring schedule (optional)
  isRecurring    Boolean   @default(false)
  recurringRule  String? // RRULE format or simple: daily, weekly, monthly
  recurringEndAt DateTime?
  nextRunAt      DateTime?

  // Status tracking
  status      ScheduledMessageStatus @default(PENDING)
  processedAt DateTime?

  // Results
  totalRecipients Int     @default(0)
  sentCount       Int     @default(0)
  failedCount     Int     @default(0)
  errorMessage    String?

  // Metadata
  name        String? // Optional name/label for the schedule
  createdById String?
  campaignId  String? // Optional link to campaign

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([status, scheduledAt])
  @@index([organizationId, scheduledAt])
  @@map("scheduled_messages")
}

enum ScheduledMessageType {
  SMS
  EMAIL
  WHATSAPP
}

enum ScheduledMessageStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

// ==================== CONTACT LISTS ====================

model ContactList {
  id             String @id @default(uuid())
  organizationId String

  // List details
  name        String
  description String?
  type        ContactListType @default(STATIC)

  // For dynamic lists - filter criteria
  filterCriteria Json? // {"source": "WEBSITE", "stageId": "xxx"}

  // Stats
  contactCount Int @default(0)
  activeCount  Int @default(0)

  // Metadata
  tags     Json    @default("[]")
  isActive Boolean @default(true)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     ContactListMember[]
  campaigns    CampaignList[]

  @@index([organizationId, isActive])
  @@index([organizationId, type])
  @@map("contact_lists")
}

model ContactListMember {
  id     String @id @default(uuid())
  listId String

  // Contact info (can be lead or standalone)
  leadId String?

  // Standalone contact info (when not linked to lead)
  email        String?
  phone        String?
  firstName    String?
  lastName     String?
  customFields Json    @default("{}")

  // Status
  status         ContactStatus @default(ACTIVE)
  unsubscribedAt DateTime?
  bouncedAt      DateTime?

  // Engagement tracking
  lastContactedAt DateTime?
  contactCount    Int       @default(0)

  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  list ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, leadId])
  @@unique([listId, email])
  @@index([listId, status])
  @@map("contact_list_members")
}

model CampaignList {
  id         String @id @default(uuid())
  campaignId String
  listId     String

  addedAt DateTime @default(now())

  list ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([campaignId, listId])
  @@map("campaign_lists")
}

enum ContactListType {
  STATIC // Manually managed contacts
  DYNAMIC // Auto-updated based on criteria
  IMPORTED // Imported from file
  SYNCED // Synced from external source
}

enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  INACTIVE
}

// ==================== CONVERSATION TRACKING ====================

model Conversation {
  id             String @id @default(uuid())
  organizationId String

  // Conversation participants
  leadId       String?
  contactPhone String?
  contactEmail String?
  contactName  String?

  // Channel
  channel   ConversationChannel
  channelId String? // External channel ID (WhatsApp, etc.)

  // Status
  status   ConversationState    @default(OPEN)
  priority ConversationPriority @default(NORMAL)

  // Assignment
  assignedToId String?
  assignedAt   DateTime?

  // Metadata
  subject      String?
  tags         Json    @default("[]")
  customFields Json    @default("{}")

  // Stats
  messageCount    Int               @default(0)
  lastMessageAt   DateTime?
  lastMessageType MessageDirection?

  // Resolution
  resolvedAt   DateTime?
  resolvedById String?
  resolution   String?

  // SLA tracking
  firstResponseAt   DateTime?
  firstResponseTime Int? // seconds

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     ConversationMessage[]

  @@index([organizationId, status])
  @@index([organizationId, channel])
  @@index([leadId])
  @@index([contactPhone])
  @@index([contactEmail])
  @@index([assignedToId, status])
  @@map("conversations")
}

model ConversationMessage {
  id             String @id @default(uuid())
  conversationId String

  // Message details
  direction   MessageDirection
  content     String             @db.Text
  contentType MessageContentType @default(TEXT)

  // Media attachments
  attachments Json @default("[]") // [{url, type, name, size}]

  // Sender info
  senderType SenderType
  senderId   String? // User ID if from agent
  senderName String?

  // External references
  externalId     String? // Provider message ID
  providerStatus String? // Provider delivery status

  // Delivery status
  status        MessageDeliveryStatus @default(PENDING)
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  failedAt      DateTime?
  failureReason String?

  // Metadata
  metadata Json @default("{}")

  createdAt DateTime @default(now())

  // Relations
  conversation  Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  statusUpdates MessageStatusUpdate[]

  @@index([conversationId, createdAt])
  @@index([externalId])
  @@index([status])
  @@map("conversation_messages")
}

model MessageStatusUpdate {
  id        String @id @default(uuid())
  messageId String

  // Status info
  status    MessageDeliveryStatus
  timestamp DateTime              @default(now())

  // Provider info
  providerStatus String?
  providerData   Json?

  // Error info
  errorCode    String?
  errorMessage String?

  // Webhook delivery
  webhookSent   Boolean   @default(false)
  webhookSentAt DateTime?

  // Relations
  message ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, timestamp])
  @@map("message_status_updates")
}

enum ConversationChannel {
  SMS
  WHATSAPP
  EMAIL
  VOICE
  WEBCHAT
  FACEBOOK
  INSTAGRAM
}

enum ConversationState {
  OPEN
  PENDING
  WAITING_CUSTOMER
  WAITING_AGENT
  RESOLVED
  CLOSED
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MessageContentType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  CONTACT
  TEMPLATE
  INTERACTIVE
}

enum SenderType {
  CUSTOMER
  AGENT
  SYSTEM
  BOT
}

enum MessageDeliveryStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  REJECTED
}

// ==================== LEAD TRACKING ====================

// Visitor tracking for analytics and lead attribution
model VisitorTracking {
  id             String @id @default(uuid())
  organizationId String
  visitorId      String // Unique visitor identifier from cookie/localStorage

  // UTM Parameters
  source   String? // utm_source (google, facebook, instagram, etc.)
  medium   String? // utm_medium (cpc, organic, social, email, etc.)
  campaign String? // utm_campaign
  content  String? // utm_content
  term     String? // utm_term

  // Ad Click IDs
