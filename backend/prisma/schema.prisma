// Admission Records
model Admission {
  id                String   @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  admissionNumber   String   @unique

  leadId            String
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  universityId      String
  university        University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  // Course details
  courseName        String?
  branch            String?
  academicYear      String          // "2024-25"

  // Admission type & fees
  admissionType     AdmissionType
  totalFee          Decimal  @db.Decimal(12, 2)
  donationAmount    Decimal  @default(0) @db.Decimal(12, 2)

  // Payment tracking
  paidAmount        Decimal  @default(0) @db.Decimal(12, 2)
  pendingAmount     Decimal  @db.Decimal(12, 2)
  paymentStatus     String   @default("PENDING") // PENDING, PARTIAL, PAID

  // Commission
  commissionPercent Decimal  @db.Decimal(5, 2)
  commissionAmount  Decimal  @db.Decimal(12, 2)
  commissionStatus  String   @default("PENDING") // PENDING, RECEIVED
  commissionReceivedAt DateTime?

  // Closed by
  closedById        String
  closedBy          User     @relation("AdmissionClosedBy", fields: [closedById], references: [id])
  closedAt          DateTime @default(now())

  // Payment reminders
  lastPaymentReminderAt DateTime?
  paymentReminderCount  Int      @default(0)

  // Status
  status            String   @default("ACTIVE") // ACTIVE, CANCELLED, REFUNDED

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  payments          AdmissionPayment[]

  @@index([organizationId])
  @@index([leadId])
  @@index([universityId])
  @@index([organizationId, academicYear])
  @@index([organizationId, admissionType])
  @@index([organizationId, closedAt])
  @@map("admissions")
}

// Admission Payment Records (for installments)
model AdmissionPayment {
  id                String   @id @default(uuid())
  admissionId       String
  admission         Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  paymentNumber     Int              // 1, 2, 3... for installments
  amount            Decimal  @db.Decimal(12, 2)
  paymentType       String           // FEE, DONATION, MISCELLANEOUS
  paymentMode       String?          // CASH, CHEQUE, ONLINE, UPI
  referenceNumber   String?

  paidAt            DateTime?
  receivedById      String?
  receivedBy        User?    @relation("PaymentReceivedBy", fields: [receivedById], references: [id])

  notes             String?
  receiptUrl        String?

  createdAt         DateTime @default(now())

  @@index([admissionId])
  @@index([admissionId, paymentNumber])
  @@map("admission_payments")
}

// Business Expenses (General expenses, not visit-specific)
model BusinessExpense {
  id                String   @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  category          String           // MARKETING, SALARY, RENT, TRAVEL, UTILITIES, OTHER
  description       String
  amount            Decimal  @db.Decimal(12, 2)
  expenseDate       DateTime

