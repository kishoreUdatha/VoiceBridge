}

// ==================== B2B PARTNER & MARKETPLACE ====================

// Partner Types
enum PartnerType {
  RESELLER // Sells to their own customers
  AFFILIATE // Earns commission on referrals
  WHITE_LABEL // Full white-label solution
  AGENCY // Manages multiple clients
}

enum PartnerTier {
  BRONZE // 15% commission, max 10 customers
  SILVER // 20% commission, max 50 customers
  GOLD // 25% commission, max 200 customers
  PLATINUM // 30% commission, unlimited customers
}

enum PartnerStatus {
  PENDING // Application submitted
  APPROVED // Active partner
  SUSPENDED // Temporarily disabled
  REJECTED // Application rejected
  CHURNED // No longer active
}

// Partner/Reseller Organization
model Partner {
  id             String @id @default(uuid())
  organizationId String @unique

  // Partner Details
  partnerType PartnerType   @default(RESELLER)
  tier        PartnerTier   @default(BRONZE)
  status      PartnerStatus @default(PENDING)

  // Company Info
  companyName    String
  companyWebsite String?
  contactPerson  String
  contactEmail   String
  contactPhone   String?

  // Business Details
  businessType      String? // SaaS, Agency, Consultancy, etc.
  targetIndustry    String? // Education, Healthcare, etc.
  expectedCustomers Int? // Expected monthly customers

  // Commission Settings
  commissionRate   Float   @default(15) // Percentage
  customCommission Boolean @default(false)
  minPayout        Float   @default(1000) // Minimum payout threshold
  payoutSchedule   String  @default("MONTHLY") // WEEKLY, MONTHLY

  // Limits
  maxCustomers         Int @default(10)
  maxAgentsPerCustomer Int @default(5)

  // Branding
  brandingEnabled Boolean @default(false)
  customDomain    String? @unique

  // Stats
  totalCustomers  Int   @default(0)
  activeCustomers Int   @default(0)
  totalRevenue    Float @default(0)
  totalCommission Float @default(0)
  pendingPayout   Float @default(0)

  // Approval
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?

  // Agreement
  agreementSigned   Boolean   @default(false)
  agreementSignedAt DateTime?
  agreementVersion  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization  Organization        @relation("PartnerOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  customers     PartnerCustomer[]
  commissions   PartnerCommission[]
  payouts       PartnerPayout[]
  agentLicenses AgentLicense[]

  @@index([status])
  @@index([tier])
  @@map("partners")
}

// Partner's Customers (Organizations under a partner)
model PartnerCustomer {
  id             String @id @default(uuid())
  partnerId      String
  organizationId String @unique

  // Customer Status
  status String @default("ACTIVE") // ACTIVE, SUSPENDED, CHURNED

  // Subscription Info
  planId       String?
  monthlyValue Float   @default(0)

  // Dates
  onboardedAt DateTime  @default(now())
  churnedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner      Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  organization Organization @relation("CustomerOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([partnerId, status])
  @@map("partner_customers")
}

// Commission Tracking
model PartnerCommission {
  id        String @id @default(uuid())
  partnerId String

  // Source
  customerId     String? // PartnerCustomer organizationId
  subscriptionId String?
  invoiceId      String?

  // Transaction
  transactionType String // SUBSCRIPTION, ADDON, AGENT_SALE, REFERRAL
  description     String?

  // Amounts
  grossAmount      Float // Original transaction amount
  commissionRate   Float // Rate at time of transaction
  commissionAmount Float // Calculated commission

  // Status
  status CommissionStatus @default(PENDING)

  // Payout Reference
  payoutId String?

  // Dates
  transactionDate DateTime  @default(now())
  approvedAt      DateTime?
  paidAt          DateTime?

  createdAt DateTime @default(now())

  partner Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  payout  PartnerPayout? @relation(fields: [payoutId], references: [id])

  @@index([partnerId, status])
  @@index([transactionDate])
  @@map("partner_commissions")
}

enum CommissionStatus {
  PENDING // Waiting for payment confirmation
  APPROVED // Approved for payout
  PROCESSING // Payout in progress
  PAID // Paid to partner
  CANCELLED // Transaction reversed
  HELD // On hold for review
}

// Partner Payouts
model PartnerPayout {
  id        String @id @default(uuid())
  partnerId String

  // Payout Details
  payoutNumber String @unique
  amount       Float
  currency     String @default("INR")

  // Period
  periodStart DateTime
  periodEnd   DateTime

  // Status
  status PayoutStatus @default(PENDING)

  // Bank Details (at time of payout)
  bankName      String?
  accountNumber String?
  ifscCode      String?
  accountHolder String?

  // Payment Reference
  paymentMethod    String? // BANK_TRANSFER, UPI, PAYPAL
  paymentReference String?
  transactionId    String?

  // Processing
  processedAt   DateTime?
  processedBy   String?
  failureReason String?

  // Invoice
  invoiceUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner     Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  commissions PartnerCommission[]

  @@index([partnerId, status])
  @@map("partner_payouts")
}

enum PayoutStatus {
  PENDING // Awaiting processing
  PROCESSING // Being processed
  COMPLETED // Successfully paid
  FAILED // Payment failed
  CANCELLED // Cancelled
}

// ==================== AGENT MARKETPLACE ====================

// Agent Template (Marketplace Listing)
model AgentTemplate {
  id String @id @default(uuid())

  // Creator
  creatorId   String // Organization that created this template
  creatorType String @default("PLATFORM") // PLATFORM, PARTNER, ORGANIZATION

  // Basic Info
  name             String
  slug             String  @unique
  description      String  @db.Text
  shortDescription String?

  // Industry & Category
  industry VoiceAgentIndustry
  category String? // Sales, Support, Appointment, etc.
  tags     Json               @default("[]")

  // Agent Configuration (Template)
  systemPrompt    String  @db.Text
  voiceId         String  @default("alloy")
  language        String  @default("en")
  temperature     Float   @default(0.7)
  greeting        String?
  fallbackMessage String?

  // Qualification Questions Template
  questions Json @default("[]")

  // Knowledge Base Template
  knowledgeBase String? @db.Text
  faqs          Json    @default("[]")

  // Customization Options
  customizableFields Json @default("[]") // Which fields can be customized
  requiredSetup      Json @default("[]") // Required setup steps

  // Pricing
  priceType    AgentPriceType @default(FREE)
  oneTimePrice Float? // One-time purchase
  monthlyPrice Float? // Monthly subscription
  yearlyPrice  Float? // Yearly subscription
  currency     String         @default("INR")

  // Revenue Share (for marketplace)
  revenueShare Float @default(70) // Creator gets this percentage

  // Media
  iconUrl      String?
  bannerUrl    String?
  screenshots  Json    @default("[]")
  demoVideoUrl String?

  // Documentation
  documentation String? @db.Text
  setupGuide    String? @db.Text

  // Status
  status     AgentTemplateStatus @default(DRAFT)
  isPublic   Boolean             @default(false)
  isFeatured Boolean             @default(false)
  isVerified Boolean             @default(false) // Platform verified

  // Stats
  viewCount      Int   @default(0)
  installCount   Int   @default(0)
  activeInstalls Int   @default(0)
  totalRevenue   Float @default(0)

  // Ratings
  averageRating Float?
  ratingCount   Int    @default(0)

  // Version Control
  version   String @default("1.0.0")
  changelog Json   @default("[]")

  // Dates
  publishedAt   DateTime?
  lastUpdatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  licenses AgentLicense[]
  reviews  AgentReview[]

  @@index([industry, status])
  @@index([isPublic, isFeatured])
  @@index([creatorId])
  @@map("agent_templates")
}

enum AgentPriceType {
  FREE
  ONE_TIME
  MONTHLY
  YEARLY
  CUSTOM
}

enum AgentTemplateStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
}

// Agent License (Purchase/Subscription)
model AgentLicense {
  id String @id @default(uuid())

  // Parties
  templateId     String
  organizationId String // Buyer
  partnerId      String? // If purchased through partner

  // License Details
  licenseKey  String      @unique @default(uuid())
  licenseType LicenseType @default(STANDARD)

  // Pricing at Purchase
  priceType AgentPriceType
  pricePaid Float
  currency  String         @default("INR")

  // Subscription Period (if applicable)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // Usage Limits
  maxInstances     Int @default(1) // How many agents can be created
  currentInstances Int @default(0)

  // Status
  status LicenseStatus @default(ACTIVE)

  // Payment
  paymentId String?
  invoiceId String?

  // Dates
  purchasedAt DateTime  @default(now())
  expiresAt   DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template AgentTemplate @relation(fields: [templateId], references: [id])
  partner  Partner?      @relation(fields: [partnerId], references: [id])

  @@index([organizationId, status])
  @@index([templateId])
  @@map("agent_licenses")
}

enum LicenseType {
  STANDARD // Normal purchase
  ENTERPRISE // Volume license
  PARTNER // Partner special license
  TRIAL // Trial license
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

// Agent Reviews
model AgentReview {
  id             String @id @default(uuid())
  templateId     String
  organizationId String // Reviewer
  userId         String // User who wrote review

  // Review Content
  rating  Int // 1-5
  title   String?
  content String? @db.Text

  // Helpful Votes
  helpfulCount Int @default(0)

  // Status
  isVerified  Boolean @default(false) // Verified purchase
  isPublished Boolean @default(true)

  // Response from creator
  creatorResponse String?   @db.Text
  respondedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

