  errorMessage      String?

  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())

  @@index([organizationId, userId])
  @@index([status])
  @@map("export_jobs")
}

model BIConnector {
  id                String   @id @default(uuid())
  organizationId    String

  name              String
  type              BIConnectorType

  // Connection
  connectionString  String?
  apiKey            String?
  credentials       Json?

  // Sync Settings
  syncEnabled       Boolean  @default(false)
  syncFrequency     String?  // cron expression
  lastSyncAt        DateTime?

  // Tables/Datasets
  enabledTables     Json?    // Which tables to sync

  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId, isActive])
  @@map("bi_connectors")
}

enum ExportFormat {
  CSV
  EXCEL
  PDF
  JSON
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

enum BIConnectorType {
  BIGQUERY
  SNOWFLAKE
  REDSHIFT
  TABLEAU
  POWER_BI
  LOOKER
  CUSTOM
}
