  @@index([organizationId, createdAt])
  @@index([provider, createdAt])
  @@index([phoneNumberId])
  @@map("ai_call_logs")
}

// Plan Definitions (for reference, can also be in code)
model PlanDefinition {
  id          String  @id @default(uuid())
  slug        String  @unique // starter, pro, enterprise
  name        String
  description String?

  // Pricing
  monthlyPrice Float
  yearlyPrice  Float
