generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core Tables
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  email     String
  phone     String?
  address   String?
  logo      String?
  settings  Json?    @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription fields
  activePlanId       String?   @default("starter")
  subscriptionStatus String?   @default("TRIAL") // TRIAL, ACTIVE, CANCELLED, EXPIRED
  trialEndsAt        DateTime?

  // Voice Minutes Pool
  voiceMinutesLimit   Int? // Override plan limit (null = use plan default)
  voiceMinutesUsed    Float     @default(0) // Total minutes used this month
  voiceMinutesResetAt DateTime? // When usage was last reset

  // Wallet for Phone Number Purchases
  walletBalance     Float     @default(0) // Prepaid wallet balance in USD
  walletCurrency    String    @default("USD")
  kycVerified       Boolean   @default(false) // KYC verification status for Indian numbers
  kycVerifiedAt     DateTime?
  kycDocuments      Json?     @default("{}") // Store KYC document references

  // Language Settings
  preferredLanguage String? @default("te-IN") // Default language for transcription (te-IN, hi-IN, en-IN, etc.)

  // Industry Configuration
  industry OrganizationIndustry? @default(GENERAL)

  users                  User[]
  roles                  Role[]
  leads                  Lead[]
  customForms            CustomForm[]
  landingPages           LandingPage[]
  campaigns              Campaign[]
  adCampaigns            AdCampaign[]
  instagramIntegrations  InstagramIntegration[]
  facebookIntegrations   FacebookIntegration[]
  linkedinIntegrations   LinkedInIntegration[]
  googleAdsIntegrations  GoogleAdsIntegration[]
  youtubeAdsIntegrations YouTubeAdsIntegration[]
  twitterAdsIntegrations TwitterAdsIntegration[]
  tiktokAdsIntegrations  TikTokAdsIntegration[]
  chatbotConversations   ChatbotConversation[]
  payments               Payment[]
  leadStages             LeadStage[]
  taxonomies             Taxonomy[]
  channels               Channel[]
  customFields           CustomField[]
  voiceAgents            VoiceAgent[]
  voiceTemplates         OrganizationVoiceTemplate[]
  subscriptions          Subscription[]

  // B2B Partner Relations
  partner         Partner?         @relation("PartnerOrganization")
  partnerCustomer PartnerCustomer? @relation("CustomerOrganization")

  // Raw Import Records
  bulkImports      BulkImport[]
  rawImportRecords RawImportRecord[]

  // Phone Numbers
  phoneNumbers PhoneNumber[]

  // Inbound Call Features
  ivrFlows         IvrFlow[]
  ivrNodes         IvrNode[]
  callFlows        CallFlow[]
  callQueues       CallQueue[]
  voicemails       Voicemail[]
  callbackRequests CallbackRequest[]
  inboundCallLogs  InboundCallLog[]
  agentSkills      AgentSkill[]

  // Compliance & Analytics
  consentRecords            ConsentRecord[]
  complianceAuditLogs       ComplianceAuditLog[]
  recordingDisclosureConfig RecordingDisclosureConfig?
  funnelEvents              FunnelEvent[]
  agentPerformanceDaily     AgentPerformanceDaily[]
  telecallerPerformanceDaily TelecallerPerformanceDaily[]

  // Billing & Usage
  usageTracking      UsageTracking[]
  invoices           Invoice[]
  walletTransactions WalletTransaction[]

  // Scheduled Calls & Appointments
  scheduledCalls ScheduledCall[]
  appointments   Appointment[]

  // Call Management
  doNotCallLists  DoNotCallList[]
  followUpRules   FollowUpRule[]
  transferConfigs TransferConfig[]
  analyticsDaily  AnalyticsDaily[]

  // Enterprise Features
  whiteLabelSettings WhiteLabelSettings?
  emailSettings      EmailSettings?

  // Messaging
  scheduledMessages ScheduledMessage[]
  contactLists      ContactList[]
  conversations     Conversation[]

  // Tracking
  visitorTracking VisitorTracking[]
  adInteractions  AdInteraction[]

  // IVR & Monitoring
  ivrPhoneNumbers        IvrPhoneNumber[]
  callMonitoringSessions CallMonitoringSession[]

  // Integrations
  emailSequences      EmailSequence[]
  crmIntegrations     CrmIntegration[]
  paymentIntegrations PaymentIntegration[]
  customApiEndpoints  CustomApiEndpoint[]

  // Apify Web Scraping
  apifyIntegration ApifyIntegration?

  // Indian Lead Source Integrations
  justDialIntegration    JustDialIntegration?
  indiaMartIntegration   IndiaMartIntegration?
  sulekhaIntegration     SulekhaIntegration?
  tawkToIntegration      TawkToIntegration?
  realEstateIntegrations RealEstateIntegration[]

  // Zapier Automation
  zapierSubscriptions    ZapierSubscription[]

  // Live Chat
  chatWidget             ChatWidget?
  chatSessions           ChatSession[]

  // Call Logs (Multi-tenancy)
  callLogs CallLog[]
  ivrsLogs IvrsLog[]

  // Push Notifications
  deviceTokens DeviceToken[]

  // Assignment Schedules
  assignmentSchedules AssignmentSchedule[]

  // Field Sales Management
  colleges        College[]
  collegeVisits   CollegeVisit[]
  collegeDeals    CollegeDeal[]
  collegeExpenses CollegeExpense[]

  // User Security & Activity
  loginHistory LoginHistory[]
  userSessions UserSession[]

  // Multi-Branch Support
  branches Branch[]

  // Education Admission Management
  universities        University[]
  studentVisits       StudentVisit[]
  admissions          Admission[]
  businessExpenses    BusinessExpense[]

  // Lead Management Features
  leadTags               LeadTag[]
  leadRoutingRules       LeadRoutingRule[]
  routingGroups          RoutingGroup[]
  leadSlaConfigs         LeadSlaConfig[]
  leadScoringRules       LeadScoringRule[]
  leadWorkflows          LeadWorkflow[]
  leadViews              LeadView[]
  leadSourceAttributions LeadSourceAttribution[]
  leadDuplicateGroups    LeadDuplicateGroup[]

  // Quotation Management
  quotations             Quotation[]
  productCatalog         ProductCatalog[]

  // Approval Workflows
  approvalWorkflows      ApprovalWorkflow[]
  approvalRequests       ApprovalRequest[]

  // QA Module
  qaScoreTemplates       QAScoreTemplate[]
  qaReviews              QAReview[]

  // Field-Level Permissions
  fieldPermissions       FieldPermission[]

  // Team Collaboration
  activityFeed           ActivityFeed[]
  mentions               Mention[]
  leadComments           LeadComment[]

  // Commission Tracking
  commissionRules        CommissionRule[]
  commissions            Commission[]

  @@map("organizations")
}

model User {
  id                   String    @id @default(uuid())
  organizationId       String
  email                String
  password             String
  firstName            String
  lastName             String
  phone                String?
  avatar               String?
  roleId               String
  managerId            String?   // Manager assigned to this user (for telecallers/counselors)
  branchId             String?   // Branch this user belongs to (for multi-branch support)
  isActive             Boolean   @default(true)
  lastLoginAt          DateTime?
  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Voice Minutes Management
  voiceMinutesLimit   Int? // Max minutes per month (null = unlimited within org pool)
  voiceMinutesUsed    Float     @default(0) // Minutes used this month
  voiceMinutesResetAt DateTime? // When usage was last reset

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role             Role              @relation(fields: [roleId], references: [id])
  manager          User?             @relation("ManagerTeam", fields: [managerId], references: [id])
  teamMembers      User[]            @relation("ManagerTeam")
  branch           Branch?           @relation("UserBranch", fields: [branchId], references: [id])
  managedBranches  Branch[]          @relation("BranchManager")
  leadAssignments  LeadAssignment[]  @relation("AssignedTo")
  assignedBy       LeadAssignment[]  @relation("AssignedBy")
  studentProfile   StudentProfile?
  callLogs         CallLog[]         @relation("Caller")
  smsLogs          SmsLog[]
  emailLogs        EmailLog[]
  whatsappLogs     WhatsappLog[]
  createdCampaigns Campaign[]        @relation("CampaignCreator")
  paymentsCreated  Payment[]         @relation("PaymentCreator")
  leadNotes        LeadNote[]
  leadTasks        LeadTask[]        @relation("TaskAssignee")
  createdTasks     LeadTask[]        @relation("TaskCreator")
  followUps        FollowUp[]        @relation("FollowUpAssignee")
  createdFollowUps FollowUp[]        @relation("FollowUpCreator")
  leadActivities   LeadActivity[]
  telecallerQueue  TelecallerQueue[] @relation("TelecallerQueueAssignment")
  telecallerCalls  TelecallerCall[]  @relation("TelecallerCalls")

  // Raw Import Records
  bulkImportsUploaded   BulkImport[]      @relation("BulkImportUploader")
  rawImportsAssignedTo  RawImportRecord[] @relation("RawImportAssignedTo")
  rawImportsAssignedBy  RawImportRecord[] @relation("RawImportAssignedBy")
  rawImportsConvertedBy RawImportRecord[] @relation("RawImportConvertedBy")

  // Field Sales Management
  collegesAssigned          College[]        @relation("CollegeAssignedTo")
  collegesSecondary         College[]        @relation("CollegeSecondaryAssignee")
  collegeVisits             CollegeVisit[]   @relation("CollegeVisitUser")
  collegeDealsOwned         CollegeDeal[]    @relation("CollegeDealOwner")
  collegeExpensesSubmitted  CollegeExpense[] @relation("CollegeExpenseUser")
  collegeExpensesApproved   CollegeExpense[] @relation("CollegeExpenseApprover")
  expenseLogs               ExpenseLog[]     @relation("ExpenseLogUser")

  // Voice Agents
  voiceAgentsCreated   VoiceAgent[] @relation("VoiceAgentCreator")
  voiceAgentsPublished VoiceAgent[] @relation("VoiceAgentPublisher")
  callFlowsCreated     CallFlow[]   @relation("CallFlowCreator")

  // Messaging
  messageLogs MessageLog[]

  // Push Notifications
  deviceTokens DeviceToken[]

  // User settings (includes notification preferences)
  settings Json? @default("{}")

  // Lead Distribution Settings (for location/language-based routing)
  assignedRegions  Json?  // Array of regions/cities: ["Mumbai", "Pune", "Delhi"]
  spokenLanguages  Json?  // Array of language codes: ["en", "hi", "mr", "te"]

  // Security & Activity Tracking
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  loginHistory     LoginHistory[]
  userSessions     UserSession[]

  // Education Admission Management
  leadsAdmissionsClosed       Lead[]              @relation("AdmissionClosedBy")
  visitsArranged              StudentVisit[]      @relation("VisitArrangedBy")
  visitsAccompanied           StudentVisit[]      @relation("VisitAccompaniedBy")
  admissionsClosed            Admission[]         @relation("AdmissionClosedBy")
  admissionPaymentsReceived   AdmissionPayment[]  @relation("PaymentReceivedBy")
  businessExpensesCreated     BusinessExpense[]   @relation("ExpenseCreatedBy")

  // Approval Workflows
  approvalWorkflowsCreated    ApprovalWorkflow[]  @relation("WorkflowCreator")
  approvalStepsAsApprover     ApprovalStep[]      @relation("StepApproverUser")
  approvalStepsAsEscalate     ApprovalStep[]      @relation("StepEscalateUser")
  approvalRequestsSubmitted   ApprovalRequest[]   @relation("RequestSubmitter")
  approvalRequestsDecided     ApprovalRequest[]   @relation("RequestDecider")
  approvalActionsPerformed    ApprovalAction[]    @relation("ActionActor")

  // QA Module
  qaReviewsAsReviewer         QAReview[]          @relation("QAReviewer")
  qaReviewsAsAgent            QAReview[]          @relation("QAAgent")

  // Team Collaboration
  activityFeed                ActivityFeed[]
  mentionsReceived            Mention[]           @relation("MentionedUser")
  leadCommentsAuthored        LeadComment[]       @relation("CommentAuthor")

  // Commission Tracking
  commissions                 Commission[]        @relation("UserCommissions")
  commissionsApproved         Commission[]        @relation("CommissionApprover")
  approvalActionsEscalatedFrom ApprovalAction[]   @relation("ActionEscalatedFrom")

  @@unique([organizationId, email])
  @@map("users")
}

// Multi-Branch Support
model Branch {
  id                String   @id @default(uuid())
  organizationId    String
  name              String
  code              String   // Unique code like "HYD-01", "BNG-02"
  isHeadquarters    Boolean  @default(false)
  isActive          Boolean  @default(true)

  // Location
  address           String
  city              String
  state             String
  country           String   @default("India")
  pincode           String?
  latitude          Float?
  longitude         Float?

  // Contact
  phone             String?
  email             String?

  // Management
  branchManagerId   String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branchManager        User?        @relation("BranchManager", fields: [branchManagerId], references: [id])
  users                User[]       @relation("UserBranch")
  leads                Lead[]
  campaigns            Campaign[]
  colleges             College[]
  rawImportRecords     RawImportRecord[]
  assignmentSchedules  AssignmentSchedule[] @relation("AssignmentScheduleBranch")

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@map("branches")
}

// Login History for Activity Tracking
model LoginHistory {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  ipAddress      String?
  userAgent      String?
  device         String?  // desktop, mobile, tablet
  browser        String?
  os             String?
  location       String?  // City, Country (from IP)
  status         String   @default("success") // success, failed, blocked
  failReason     String?  // invalid_password, account_locked, etc.
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@map("login_history")
}

// Active User Sessions
model UserSession {
  id             String    @id @default(uuid())
  userId         String
  organizationId String
  token          String    @unique
  ipAddress      String?
  userAgent      String?
  device         String?
  browser        String?
  os             String?
  location       String?
  isActive       Boolean   @default(true)
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([organizationId])
  @@index([token])
  @@map("user_sessions")
}

// Device Token for Push Notifications
model DeviceToken {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  token          String   @unique
  platform       String   // 'android' or 'ios'
  deviceId       String?
  isActive       Boolean  @default(true)
  lastActiveAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@map("device_tokens")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String?
  name           String
  slug           String
  description    String?
  permissions    Json     @default("[]")
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users        User[]

  // Approval Workflows
  approvalStepsAsApprover  ApprovalStep[] @relation("StepApproverRole")
  approvalStepsAsEscalate  ApprovalStep[] @relation("StepEscalateRole")

  // Field-Level Permissions
  fieldPermissions         FieldPermission[]

  @@unique([organizationId, slug])
  @@map("roles")
}

// Lead Stages with Sub-Stages
model LeadStage {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  slug            String
  color           String?  @default("#3B82F6")
  order           Int      @default(0)
  requireFollowUp Boolean  @default(false)
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Industry-specific lead stage fields
  isSystemStage   Boolean  @default(false)  // True if created from industry template
  templateSlug    String?                    // Original template slug reference
  autoSyncStatus  String?                    // "WON" or "LOST" - auto-syncs lead status
  journeyOrder    Int?     @default(0)       // Order in journey tracker visualization
  icon            String?                    // Icon name for display (e.g., "AcademicCapIcon")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subStages    LeadSubStage[]
  leads        Lead[]

  @@unique([organizationId, slug])
  @@map("lead_stages")
}

model LeadSubStage {
  id        String   @id @default(uuid())
  stageId   String
  name      String
  slug      String
  color     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stage LeadStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@unique([stageId, slug])
  @@map("lead_sub_stages")
}

// Taxonomy (Courses, Branches, etc.)
model Taxonomy {
  id             String       @id @default(uuid())
  organizationId String
  type           TaxonomyType
  name           String
  slug           String
  parentId       String?
  order          Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Taxonomy?    @relation("TaxonomyHierarchy", fields: [parentId], references: [id])
  children     Taxonomy[]   @relation("TaxonomyHierarchy")
  leads        Lead[]       @relation("LeadCourse")
  leadBranches Lead[]       @relation("LeadBranch")

  @@unique([organizationId, type, slug])
  @@map("taxonomies")
}

// Channels/Sources
model Channel {
  id             String      @id @default(uuid())
  organizationId String
  name           String
  slug           String
  type           ChannelType @default(OTHER)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@unique([organizationId, slug])
  @@map("channels")
}

// Custom Fields
model CustomField {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  slug           String
  fieldType      FieldType
  options        Json?     @default("[]")
  isRequired     Boolean   @default(false)
  order          Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@map("custom_fields")
}

model Lead {
  id             String       @id @default(uuid())
  organizationId String
  orgBranchId    String?      // Organization branch for multi-branch support
  firstName      String
  lastName       String?
  email          String?
  phone          String
  alternatePhone String?
  alternateEmail String?
  source         LeadSource   @default(MANUAL)
  sourceDetails  String?
  channelId      String?
  stageId        String?
  subStageId     String?
  priority       LeadPriority @default(MEDIUM)

  // Education specific fields
  courseId     String?
  branchId     String?
  centerName   String?
  gender       String?
  dateOfBirth  DateTime?
  fatherName   String?
  fatherMobile String?
  motherName   String?
  motherMobile String?
  address      String?
  city         String?
  state        String?
  country      String?
  pincode      String?

  // Fee related
  totalFees     Decimal? @db.Decimal(10, 2)
  paidAmount    Decimal? @default(0) @db.Decimal(10, 2)
  paymentStatus String?
  installment1  Decimal? @db.Decimal(10, 2)
  installment2  Decimal? @db.Decimal(10, 2)
  installment3  Decimal? @db.Decimal(10, 2)

  // Dates
  walkinDate DateTime?
  lineupDate DateTime?

  // Assignment
  agentName         String?
  facultyName       String?
  preferredLocation String?

  // Additional
  interests     Json?   @default("[]")
  customFields  Json?   @default("{}")
  phoneVerified Boolean @default(false)
  isReEnquiry   Boolean @default(false)

  // AI Lead Scoring 2.0
  aiScore          Int?      // 0-100 score
  aiGrade          String?   // A, B, C, D, F
  aiConfidence     Int?      // 0-100 confidence level
  aiScoreFactors   Json?     // Detailed scoring factors
  aiScoreUpdatedAt DateTime? // Last score calculation
  isDoNotCall      Boolean   @default(false)

  isConverted Boolean   @default(false)
  convertedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization              Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orgBranch                 Branch?                  @relation(fields: [orgBranchId], references: [id])
  channel                   Channel?                 @relation(fields: [channelId], references: [id])
  stage                     LeadStage?               @relation(fields: [stageId], references: [id])
  subStage                  LeadSubStage?            @relation(fields: [subStageId], references: [id])
  course                    Taxonomy?                @relation("LeadCourse", fields: [courseId], references: [id])
  branch                    Taxonomy?                @relation("LeadBranch", fields: [branchId], references: [id])
  assignments               LeadAssignment[]
  formSubmission            FormSubmission?
  studentProfile            StudentProfile?
  callLogs                  CallLog[]
  smsLogs                   SmsLog[]
  emailLogs                 EmailLog[]
  whatsappLogs              WhatsappLog[]
  ivrsLogs                  IvrsLog[]
  adLead                    AdLead?
  notes                     LeadNote[]
  tasks                     LeadTask[]
  followUps                 FollowUp[]
  activities                LeadActivity[]
  attachments               LeadAttachment[]
  queries                   LeadQuery[]
  applications              LeadApplication[]
  leadPayments              LeadPayment[]
  leadDocuments             LeadDocument[]
  voiceSessions             VoiceSession[]
  telecallerCalls           TelecallerCall[]         @relation("LeadTelecallerCalls")
  rawImportRecordsConverted RawImportRecord[]        @relation("RawImportConvertedLead")
  sequenceEnrollments       LeadSequenceEnrollment[]
  callFlowLogs              CallFlowLog[]
  leadScore                 LeadScore?
  consentRecords            ConsentRecord[]
  funnelEvents              FunnelEvent[]
  otpVerifications          OtpVerification[]
  adInteractionConversion   AdInteraction?           @relation("AdInteractionConversion")
  outboundCalls             OutboundCall[]           @relation("LeadOutboundCalls")
  messageLogs               MessageLog[]

  // Education Admission Management
  preferredUniversities   Json?           // Array of university IDs
  admissionType           AdmissionType?
  admissionStatus         AdmissionStatus @default(INQUIRY)
  expectedFee             Decimal?        @db.Decimal(12, 2)
  actualFee               Decimal?        @db.Decimal(12, 2)
  commissionPercentage    Decimal?        @db.Decimal(5, 2)
  commissionAmount        Decimal?        @db.Decimal(12, 2)
  donationAmount          Decimal?        @db.Decimal(12, 2)
  admissionClosedAt       DateTime?
  admissionClosedById     String?
  enrollmentNumber        String?
  academicYear            String?         // e.g., "2024-25"
  admissionClosedBy       User?           @relation("AdmissionClosedBy", fields: [admissionClosedById], references: [id])
  studentVisits           StudentVisit[]
  admissions              Admission[]

  // Interaction tracking
  totalCalls      Int       @default(0)
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?

  // Lead Deduplication
  isDuplicate     Boolean   @default(false)
  mergedIntoId    String?   // If merged, points to primary lead
  duplicateScore  Float?    // Confidence score for duplicate detection
  mergedAt        DateTime?

  // Lead Scoring (enhanced)
  qualificationScore  Int?      @default(0)  // 0-100 qualification score
  engagementScore     Int?      @default(0)  // Based on interactions
  intentScore         Int?      @default(0)  // Based on high-intent actions
  totalScore          Int?      @default(0)  // Combined score
  scoreLastUpdatedAt  DateTime?
  scoreDecayAppliedAt DateTime?

  // SLA Tracking
  slaDeadline       DateTime?  // When lead must be contacted by
  slaBreached       Boolean    @default(false)
  firstResponseAt   DateTime?  // When lead was first contacted
  responseTimeMs    Int?       // Time to first response in milliseconds

  // Lead Qualification
  qualificationStatus  String?   // MQL, SQL, SAL, etc.
  qualifiedAt          DateTime?
  qualifiedById        String?
  disqualifiedReason   String?

  // Lead Enrichment
  enrichedAt           DateTime?
  companyName          String?
  companySize          String?
  jobTitle             String?
  linkedinUrl          String?
  websiteUrl           String?
  annualRevenue        String?
  employeeCount        Int?
  industryType         String?

  // Web Tracking
  lastPageVisited      String?
  totalPageViews       Int       @default(0)
  lastWebActivityAt    DateTime?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  utmContent           String?
  utmTerm              String?
  referrerUrl          String?
  landingPageUrl       String?

  // Recycling & Re-engagement
  isRecycled           Boolean   @default(false)
  recycledAt           DateTime?
  recycledFromStatus   String?
  lastEngagementAt     DateTime?
  dormantSince         DateTime?

  // Relations for new features
  mergedInto           Lead?              @relation("LeadMerge", fields: [mergedIntoId], references: [id])
  mergedLeads          Lead[]             @relation("LeadMerge")
  tagAssignments       LeadTagAssignment[]
  webActivities        LeadWebActivity[]
  workflowEnrollments  LeadWorkflowEnrollment[]

  // Quotation Management
  quotations           Quotation[]

  // Team Collaboration
  comments             LeadComment[]

  // Predictive Analytics & AI
  prediction           LeadPrediction?
  customerLtv          CustomerLTV?

  // Customer Health
  customerHealth       CustomerHealth?
  surveys              CustomerSurvey[]

  // Customer Segmentation
  segmentMemberships   SegmentMembership[]
  rfmAnalysis          RFMAnalysis?

  // Sentiment Analysis
  sentimentAnalyses    SentimentAnalysis[]
  sentimentTrends      SentimentTrend[]

  // Deal Intelligence
  dealIntelligence     DealIntelligence?
  winLossAnalysis      WinLossAnalysis?

  // Pipeline & Deal Velocity
  dealVelocity         DealVelocity?

  // Territory & Account Management
  territoryId          String?
  accountId            String?
  territory            Territory?  @relation("TerritoryLeads", fields: [territoryId], references: [id])
  account              Account?    @relation("AccountLeads", fields: [accountId], references: [id])

  @@index([organizationId, phone])
  @@index([organizationId, email])
  @@index([organizationId, stageId])
  @@index([organizationId, nextFollowUpAt])
  @@index([organizationId, source])
  @@index([organizationId, createdAt])
  @@index([organizationId, priority])
  @@index([organizationId, isConverted])
  @@index([organizationId, lastContactedAt])
  @@index([organizationId, orgBranchId])
  @@map("leads")
}

model LeadAssignment {
  id           String    @id @default(uuid())
  leadId       String
  assignedToId String
  assignedById String?
  isActive     Boolean   @default(true)
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  lead       Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User  @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedBy User? @relation("AssignedBy", fields: [assignedById], references: [id])

  @@index([leadId, isActive])
  @@index([assignedToId, isActive])
  @@map("lead_assignments")
}

// Lead Notes
model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("lead_notes")
}

// Lead Tasks
model LeadTask {
  id          String       @id @default(uuid())
  leadId      String
  assigneeId  String
  createdById String
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee  User @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User @relation("TaskCreator", fields: [createdById], references: [id])

  @@map("lead_tasks")
}

// Follow-ups
model FollowUp {
  id              String         @id @default(uuid())
  leadId          String
  assigneeId      String
  createdById     String
  scheduledAt     DateTime
  message         String?
  notes           String?
  status          FollowUpStatus @default(UPCOMING)
  completedAt     DateTime?
  rescheduledFrom String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Follow-up type and AI call settings
  followUpType   FollowUpType @default(MANUAL)
  voiceAgentId   String? // AI agent to use for AI_CALL type
  outboundCallId String? // Resulting outbound call ID
  sourceCallId   String? // The call that triggered this follow-up
  attemptCount   Int          @default(0)
  maxAttempts    Int          @default(3)
  lastAttemptAt  DateTime?

  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee   User        @relation("FollowUpAssignee", fields: [assigneeId], references: [id])
  createdBy  User        @relation("FollowUpCreator", fields: [createdById], references: [id])
  voiceAgent VoiceAgent? @relation(fields: [voiceAgentId], references: [id])

  @@index([assigneeId, status, scheduledAt])
  @@index([followUpType, status, scheduledAt])
  @@map("follow_ups")
}

// Lead Activity Timeline
model LeadActivity {
  id          String       @id @default(uuid())
  leadId      String
  userId      String?
  type        ActivityType
  title       String
  description String?
  metadata    Json?        @default("{}")
  createdAt   DateTime     @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

// Lead Attachments
model LeadAttachment {
  id         String   @id @default(uuid())
  leadId     String
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_attachments")
}

// Lead Queries
model LeadQuery {
  id          String      @id @default(uuid())
  leadId      String
  query       String
  response    String?
  status      QueryStatus @default(OPEN)
  respondedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_queries")
}

// Lead Applications
model LeadApplication {
  id            String            @id @default(uuid())
  leadId        String
  applicationNo String
  programName   String?
  status        ApplicationStatus @default(DRAFT)
  submittedAt   DateTime?
  documents     Json?             @default("[]")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_applications")
}

// Lead Payments - Track payments from leads
model LeadPayment {
  id            String             @id @default(uuid())
  leadId        String
  amount        Decimal            @db.Decimal(10, 2)
  currency      String             @default("INR")
  paymentType   LeadPaymentType    @default(OTHER)
  paymentMethod LeadPaymentMethod  @default(CASH)
  status        LeadPaymentStatus  @default(PENDING)
  transactionId String?
  receiptNo     String?
  paidAt        DateTime?
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_payments")
}

enum LeadPaymentType {
  REGISTRATION
  TUITION
  EXAM
  HOSTEL
  OTHER
}

enum LeadPaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum LeadPaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL
}

// Lead Documents - Track documents uploaded by/for leads
model LeadDocument {
  id              String             @id @default(uuid())
  leadId          String
  documentType    LeadDocumentType   @default(OTHER)
  documentName    String
  fileName        String
  fileUrl         String
  fileSize        Int
  status          LeadDocumentStatus @default(PENDING)
  verifiedAt      DateTime?
  verifiedById    String?
  rejectionReason String?
  uploadedAt      DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  lead       Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_documents")
}

enum LeadDocumentType {
  ID_PROOF
  ADDRESS_PROOF
  PHOTO
  CERTIFICATE
  MARKSHEET
  OTHER
}

enum LeadDocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

// =====================================================
// LEAD MANAGEMENT FEATURES
// =====================================================

// Lead Tags for categorization
model LeadTag {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  slug           String
  color          String   @default("#6B7280")
  description    String?
  isSystem       Boolean  @default(false)  // System tags can't be deleted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadAssignments LeadTagAssignment[]

  @@unique([organizationId, slug])
  @@map("lead_tags")
}

model LeadTagAssignment {
  id        String   @id @default(uuid())
  leadId    String
  tagId     String
  assignedAt DateTime @default(now())

  lead Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  LeadTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@map("lead_tag_assignments")
}

// Lead Web Activity Tracking
model LeadWebActivity {
  id             String   @id @default(uuid())
  leadId         String
  organizationId String
  sessionId      String?
  pageUrl        String
  pageTitle      String?
  referrerUrl    String?
  duration       Int?     // Time spent in seconds
  eventType      String   @default("page_view") // page_view, form_submit, button_click, etc.
  eventData      Json?    @default("{}")
  ipAddress      String?
  userAgent      String?
  deviceType     String?  // desktop, mobile, tablet
  browser        String?
  os             String?
  country        String?
  city           String?
  createdAt      DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([organizationId, createdAt])
  @@map("lead_web_activities")
}

// Lead Routing Rules
model LeadRoutingRule {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  priority       Int      @default(0)  // Higher priority rules evaluated first
  isActive       Boolean  @default(true)

  // Rule Conditions (JSON structure)
  conditions     Json     @default("[]")  // [{field, operator, value}]
  conditionLogic String   @default("AND") // AND, OR

  // Rule Action
  actionType     String   // ASSIGN_USER, ASSIGN_TEAM, ROUND_ROBIN, LOAD_BALANCE
  assignToUserId String?  // For ASSIGN_USER
  assignToTeamId String?  // For ASSIGN_TEAM (roleId)
  routingGroupId String?  // For ROUND_ROBIN

  // Statistics
  matchCount     Int      @default(0)
  lastMatchedAt  DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  routingGroup   RoutingGroup?  @relation(fields: [routingGroupId], references: [id])

  @@index([organizationId, isActive, priority])
  @@map("lead_routing_rules")
}

// Routing Groups for Round-Robin Assignment
model RoutingGroup {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)

  // Round-robin tracking
  currentIndex   Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        RoutingGroupMember[]
  routingRules   LeadRoutingRule[]

  @@map("routing_groups")
}

model RoutingGroupMember {
  id             String   @id @default(uuid())
  groupId        String
  userId         String
  isActive       Boolean  @default(true)
  weight         Int      @default(1)   // For weighted round-robin
  maxLeads       Int?     // Max leads per day/period
  currentLeads   Int      @default(0)   // Current assigned leads count
  lastAssignedAt DateTime?
  createdAt      DateTime @default(now())

  group RoutingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("routing_group_members")
}

// SLA Configuration
model LeadSlaConfig {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  isDefault      Boolean  @default(false)

  // SLA Timing
  firstResponseMinutes Int     @default(60)    // Time to first contact
  followUpMinutes      Int     @default(1440)  // Time between follow-ups (24h default)
  resolutionMinutes    Int?                     // Time to resolution

  // Working Hours
  workingHoursOnly     Boolean @default(true)
  workingHoursStart    String  @default("09:00")
  workingHoursEnd      String  @default("18:00")
  workingDays          Json    @default("[1,2,3,4,5]") // Mon-Fri

  // Escalation
  escalationEnabled    Boolean @default(false)
  escalationMinutes    Int?
  escalationUserId     String?

  // Conditions (when to apply this SLA)
  conditions           Json    @default("[]")  // [{field, operator, value}]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("lead_sla_configs")
}

// Lead Scoring Rules
model LeadScoringRule {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)

  // Scoring Type
  scoreType      String   // DEMOGRAPHIC, BEHAVIORAL, ENGAGEMENT, INTENT

  // Condition and Score
  conditions     Json     @default("[]")  // [{field, operator, value}]
  scoreValue     Int      @default(0)     // Points to add/subtract
  scoreAction    String   @default("ADD") // ADD, SUBTRACT, SET

  // Decay Settings (for behavioral scores)
  decayEnabled   Boolean  @default(false)
  decayDays      Int?     // Days after which score starts decaying
  decayPercent   Int?     // Percentage to decay

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("lead_scoring_rules")
}

// Lead Workflows/Automation
model LeadWorkflow {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)

  // Trigger Configuration
  triggerType    String   // LEAD_CREATED, STAGE_CHANGED, SCORE_THRESHOLD, TAG_ADDED, FORM_SUBMITTED, TIME_BASED
  triggerConfig  Json     @default("{}")  // Trigger-specific config

  // Actions (executed in order)
  actions        Json     @default("[]")  // [{type, config, delayMinutes}]

  // Statistics
  executionCount Int      @default(0)
  lastExecutedAt DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollments    LeadWorkflowEnrollment[]

  @@map("lead_workflows")
}

model LeadWorkflowEnrollment {
  id           String    @id @default(uuid())
  workflowId   String
  leadId       String
  status       String    @default("ACTIVE")  // ACTIVE, COMPLETED, CANCELLED, PAUSED
  currentStep  Int       @default(0)
  nextStepAt   DateTime?
  completedAt  DateTime?
  enrolledAt   DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workflow LeadWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  lead     Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([workflowId, leadId])
  @@index([status, nextStepAt])
  @@map("lead_workflow_enrollments")
}

// Saved Lead Views
model LeadView {
  id             String   @id @default(uuid())
  organizationId String
  userId         String?  // null = shared view
  name           String
  description    String?
  isDefault      Boolean  @default(false)
  isShared       Boolean  @default(false)

  // Filter Configuration
  filters        Json     @default("[]")   // [{field, operator, value}]
  sortField      String   @default("createdAt")
  sortOrder      String   @default("desc")

  // Display Configuration
  columns        Json     @default("[]")   // Column IDs to display
  groupBy        String?                   // Field to group by

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("lead_views")
}

// Lead Source Attribution
model LeadSourceAttribution {
  id             String   @id @default(uuid())
  organizationId String
  leadId         String   @unique

  // First Touch
  firstTouchSource    String?
  firstTouchMedium    String?
  firstTouchCampaign  String?
  firstTouchAt        DateTime?

  // Last Touch
  lastTouchSource     String?
  lastTouchMedium     String?
  lastTouchCampaign   String?
  lastTouchAt         DateTime?

  // All Touches (for multi-touch attribution)
  touchPoints         Json     @default("[]")  // [{source, medium, campaign, timestamp}]

  // Attribution Model Results
  firstTouchRevenue   Decimal? @db.Decimal(12, 2)
  lastTouchRevenue    Decimal? @db.Decimal(12, 2)
  linearRevenue       Decimal? @db.Decimal(12, 2)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("lead_source_attributions")
}

// Lead Duplicate Groups (for managing duplicates)
model LeadDuplicateGroup {
  id             String   @id @default(uuid())
  organizationId String
  status         String   @default("PENDING")  // PENDING, MERGED, IGNORED
  confidence     Float    @default(0)
  matchedFields  Json     @default("[]")  // Fields that matched
  primaryLeadId  String?  // Selected primary lead after merge
  mergedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        LeadDuplicateGroupMember[]

  @@map("lead_duplicate_groups")
}

model LeadDuplicateGroupMember {
  id        String  @id @default(uuid())
  groupId   String
  leadId    String
  isPrimary Boolean @default(false)

  group LeadDuplicateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, leadId])
  @@map("lead_duplicate_group_members")
}

// Forms & Landing Pages
model CustomForm {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  description    String?
  fields         Json      @default("[]")
  settings       Json?     @default("{}")
  embedCode      String?
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
