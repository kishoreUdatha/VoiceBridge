{
  "name": "crm-lead-generation-backend",
  "version": "1.0.0",
  "description": "CRM Lead Generation System - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "postinstall": "prisma generate",
    "prestart:prod": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:lead-lifecycle": "ts-node scripts/test-lead-lifecycle.ts",
    "test:lead-api": "ts-node scripts/test-lead-lifecycle-api.ts",
    "test:followup": "ts-node scripts/test-followup-system.ts",
    "test:auto-assign": "ts-node scripts/test-auto-assign.ts",
    "test:lead-all": "ts-node scripts/run-lead-tests.ts all",
    "test:lead-all:cleanup": "ts-node scripts/run-lead-tests.ts all --cleanup",
    "prod:build": "npm run typecheck && npm run build",
    "prod:deploy": "npm run prisma:migrate:deploy && npm run start:prod"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/client-ses": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.10.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/json2csv": "^5.0.7",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "ffmpeg-static": "^5.3.0",
    "firebase-admin": "^13.7.0",
    "fluent-ffmpeg": "^2.1.3",
    "google-ads-api": "^23.0.0",
    "googleapis": "^171.4.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^7.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.9",
    "openai": "^4.28.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "plivo": "^4.75.6",
    "razorpay": "^2.9.6",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "wrtc": "^0.4.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.19",
    "@types/nodemailer": "^6.4.14",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
