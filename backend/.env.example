# =============================================================================
# CRM LEAD GENERATION - BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/crm_lead_generation

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate secure secrets using: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Base URL for webhooks (use ngrok URL for local development)
BASE_URL=https://your-ngrok-subdomain.ngrok-free.dev

# CORS Origins (comma-separated for multiple origins in production)
# Example: https://example.com,https://www.example.com
CORS_ORIGINS=

# =============================================================================
# TWILIO - SMS, WhatsApp, Voice
# Get credentials: https://console.twilio.com/
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# =============================================================================
# PLIVO - SMS, Voice (Alternative provider - CHEAPER FOR INDIA)
# Get credentials: https://console.plivo.com/
# Plivo India calling rates: ~₹0.50/min (vs Twilio ~₹1.50/min)
# =============================================================================
PLIVO_AUTH_ID=MAXXXXXXXXXXXXXXXXXX
PLIVO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLIVO_PHONE_NUMBER=+919876543210

# Provider Selection: 'twilio', 'plivo', or 'exotel'
# Use 'plivo' or 'exotel' for cheaper India calling
SMS_PROVIDER=twilio
VOICE_PROVIDER=twilio

# Test recipient (your verified number for testing)
TEST_PHONE_NUMBER=+919876543210

# =============================================================================
# INDIA CALLING CONFIGURATION
# =============================================================================
# Default language for calls (hi-IN, ta-IN, te-IN, kn-IN, ml-IN, mr-IN, bn-IN, gu-IN, pa-IN, en-IN)
DEFAULT_CALL_LANGUAGE=en-IN

# Enable regional language detection from phone number
AUTO_DETECT_LANGUAGE=true

# Business hours (IST) - calls will only be made during these hours
INDIA_BUSINESS_HOURS_START=9
INDIA_BUSINESS_HOURS_END=18

# Skip national holidays
SKIP_NATIONAL_HOLIDAYS=true

# =============================================================================
# OPENAI - AI Voice Agents, Chatbot
# Get API key: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# RAZORPAY - Payment Processing & Subscriptions
# Get credentials: https://dashboard.razorpay.com/
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# EMAIL - SMTP Configuration
# Gmail: Enable 2FA, create App Password at https://myaccount.google.com/apppasswords
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=noreply@yourcompany.com

# =============================================================================
# SENDGRID - Email Delivery (Optional, for SendGrid users)
# Get credentials: https://app.sendgrid.com/settings/api_keys
# Webhook security: https://app.sendgrid.com/settings/mail_settings (Event Webhook)
# =============================================================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook verification key (get from SendGrid Event Webhook settings when enabling Signed Event Webhook)
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# =============================================================================
# WHATSAPP WEBHOOK VERIFICATION
# Used for WhatsApp Cloud API webhook subscription verification
# =============================================================================
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token

# =============================================================================
# FACEBOOK ADS
# Create app: https://developers.facebook.com/apps/
# =============================================================================
FACEBOOK_APP_ID=123456789012345
FACEBOOK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FACEBOOK_VERIFY_TOKEN=your-webhook-verify-token

# =============================================================================
# LINKEDIN ADS
# Create app: https://www.linkedin.com/developers/apps/
# =============================================================================
LINKEDIN_CLIENT_ID=xxxxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# =============================================================================
# GOOGLE ADS
# Create app: https://console.cloud.google.com/
# =============================================================================
GOOGLE_ADS_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_ADS_DEVELOPER_TOKEN=xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# GOOGLE CALENDAR INTEGRATION
# Enable Google Calendar API: https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
# Create OAuth 2.0 Client ID: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3001/api/calendar/oauth/callback
# =============================================================================
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/calendar/oauth/callback

# =============================================================================
# AWS S3 - File Storage (Optional)
# Get credentials: https://console.aws.amazon.com/iam/
# =============================================================================
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_BUCKET_NAME=your-bucket-name
AWS_REGION=ap-south-1

# =============================================================================
# EXOTEL - India Voice & SMS (Best for India calling)
# Get credentials: https://my.exotel.com/apisettings/site
# Documentation: https://developer.exotel.com/api/
# =============================================================================
EXOTEL_ACCOUNT_SID=your_exotel_sid
EXOTEL_API_KEY=your_api_key
EXOTEL_API_TOKEN=your_api_token
EXOTEL_CALLER_ID=your_exophone_number
# Subdomain: api.exotel.com (Singapore) or api.in.exotel.com (Mumbai)
EXOTEL_SUBDOMAIN=api.exotel.com
# Optional: Exotel App IDs for IVR flows
# EXOTEL_VOICEBOT_APP_ID: For Voice Bot with WebSocket (real-time AI conversations)
# EXOTEL_APP_ID: For ExoML Passthru (webhook-based AI conversations)
# Create flows in Exotel Dashboard > App Bazaar > Create Flow
EXOTEL_VOICEBOT_APP_ID=
EXOTEL_APP_ID=
# SMS Configuration (DLT required for India)
EXOTEL_SMS_SENDER_ID=YOURCO
EXOTEL_DLT_ENTITY_ID=your_dlt_entity_id
EXOTEL_DLT_TEMPLATE_ID=your_dlt_template_id

# =============================================================================
# REDIS - Job Queue (Optional, falls back to in-memory queue)
# =============================================================================
REDIS_URL=redis://localhost:6379
