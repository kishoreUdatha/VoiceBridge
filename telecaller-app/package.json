{
  "name": "crm-telecaller-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:dev": "react-native run-android --variant=devDebug",
    "android:staging": "react-native run-android --variant=stagingDebug",
    "android:prod": "react-native run-android --variant=prodDebug",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "build:android:dev": "cd android && ./gradlew assembleDevRelease",
    "build:android:staging": "cd android && ./gradlew assembleStagingRelease",
    "build:android:prod": "cd android && ./gradlew assembleProdRelease",
    "build:android:bundle": "cd android && ./gradlew bundleProdRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "clean:android": "cd android && ./gradlew clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-native-community/datetimepicker": "^7.6.2",
    "@react-native-community/netinfo": "^11.2.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.2",
    "react": "18.2.0",
    "react-native": "0.73.1",
    "react-native-config": "^1.5.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.16.2",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "^3.31.1",
    "react-native-vector-icons": "^10.0.3",
    "react-redux": "^9.0.4",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/runtime": "^7.23.6",
    "@react-native/babel-preset": "0.73.18",
    "@react-native/eslint-config": "0.73.1",
    "@react-native/metro-config": "0.73.2",
    "@react-native/typescript-config": "0.73.1",
    "@types/react": "^18.2.45",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "3.1.1",
    "react-test-renderer": "18.2.0",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
