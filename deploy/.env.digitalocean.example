# ================================================================
# VoiceBridge - DigitalOcean Environment Variables
# ================================================================
# Copy this file and fill in your actual values
# These need to be added in DigitalOcean App Platform Settings > Environment Variables
# ================================================================

# ===================
# DATABASE (Required)
# ===================
# Get this from: DigitalOcean > Databases > your-db > Connection Details
DATABASE_URL=postgresql://user:password@your-db-host:25060/defaultdb?sslmode=require

# ===================
# REDIS (Required)
# ===================
# Get this from: DigitalOcean > Databases > your-redis > Connection Details
REDIS_URL=rediss://default:password@your-redis-host:25061

# ===================
# JWT AUTHENTICATION (Required)
# ===================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# ===================
# AI SERVICES (Required for AI features)
# ===================
# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=whisper-1

# Deepgram - https://console.deepgram.com/
DEEPGRAM_API_KEY=your-deepgram-api-key

# Sarvam AI (Indian languages) - https://www.sarvam.ai/
SARVAM_API_KEY=your-sarvam-api-key

# ElevenLabs (Premium TTS) - https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ===================
# DIGITALOCEAN SPACES (File Storage)
# ===================
# Create at: DigitalOcean > API > Spaces Keys
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=voicebridge-uploads
DO_SPACES_REGION=blr1
DO_SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com

# ===================
# TELEPHONY (For voice calls)
# ===================
# Plivo - https://console.plivo.com/
PLIVO_AUTH_ID=your-plivo-auth-id
PLIVO_AUTH_TOKEN=your-plivo-auth-token
PLIVO_PHONE_NUMBER=+91xxxxxxxxxx

# OR Exotel - https://my.exotel.com/
EXOTEL_SID=your-exotel-sid
EXOTEL_API_KEY=your-exotel-api-key
EXOTEL_API_TOKEN=your-exotel-api-token

# ===================
# WHATSAPP (Optional)
# ===================
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# ===================
# SMS (Optional)
# ===================
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=VOICEB

# ===================
# EMAIL (Optional)
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@voicebridge.com

# ===================
# APPLICATION SETTINGS
# ===================
NODE_ENV=production
PORT=8080
FRONTEND_URL=https://your-app.ondigitalocean.app
CORS_ORIGINS=https://your-app.ondigitalocean.app

# ===================
# OPTIONAL SERVICES
# ===================
# Google AI (Gemini)
GOOGLE_AI_API_KEY=your-google-ai-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-key

# Groq (Fast inference)
GROQ_API_KEY=your-groq-key

# Facebook/Instagram Ads
FACEBOOK_APP_ID=your-fb-app-id
FACEBOOK_APP_SECRET=your-fb-app-secret

# Google Ads
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-dev-token
