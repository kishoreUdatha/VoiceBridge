# ============================================================
# VoiceBridge Production Environment Variables
# ============================================================
# Copy this to .env.production in the project root
# Fill in your actual values below
# ============================================================

# ---------- DATABASE ----------
POSTGRES_USER=voicebridge
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=voicebridge

# ---------- JWT SECRETS ----------
# Generate with: openssl rand -base64 32
JWT_SECRET=GENERATE_A_32_CHAR_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_32_CHAR_SECRET

# ---------- SERVER ----------
PORT=3000
FRONTEND_URL=https://yourdomain.com
BASE_URL=https://yourdomain.com
VITE_API_URL=https://yourdomain.com/api
CORS_ORIGINS=https://yourdomain.com

# ---------- AI SERVICES ----------
# OpenAI (Required for AI features)
OPENAI_API_KEY=sk-your-openai-key

# Deepgram (Required for voice transcription)
DEEPGRAM_API_KEY=your-deepgram-key

# Sarvam AI (Optional - Indian languages)
SARVAM_API_KEY=

# ---------- TELEPHONY ----------
# Plivo (Recommended for India)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=

# OR Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

SMS_PROVIDER=plivo
VOICE_PROVIDER=plivo

# ---------- FILE STORAGE ----------
# AWS S3 or DigitalOcean Spaces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=voicebridge-uploads
AWS_REGION=ap-south-1

# ---------- PAYMENTS ----------
# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---------- EMAIL ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ---------- SOCIAL INTEGRATIONS (Optional) ----------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
